LF nat : type =
| z : nat
| s : nat -> nat
;

LF bool : type =
| btrue  : bool
| bfalse : bool
;

LF add : nat -> nat -> nat -> type =
| add-z : add z N N
| add-s : add M N P -> add (s M) N (s P)
;

LF mul : nat -> nat -> nat -> type =
| mul-z : mul z N z
| mul-s : mul M N P -> add P N Q -> mul (s M) N Q
;

LF leq : nat -> nat -> type =
| leq-z : leq z N
| leq-s : leq M N -> leq (s M) (s N)
;

LF lt : nat -> nat -> type =
| lt-z : lt z (s N)
| lt-s : lt M N -> lt (s M) (s N)
;

LF eq-nat : nat -> nat -> type =
| eq-nat-refl : eq-nat N N
;

LF f32val : type =
| mk-f32 : f32val
;

LF reg-state : type =
| reg-alive  : nat -> bool -> reg-state
| reg-freed  : reg-state
;

LF transition : reg-state -> reg-state -> type =
| tr-acquire       : transition (reg-alive N bfalse) (reg-alive (s N) bfalse)
| tr-release-live  : transition (reg-alive (s N) bfalse) (reg-alive N bfalse)
| tr-release-dying : transition (reg-alive (s (s N)) btrue) (reg-alive (s N) btrue)
| tr-release-final : transition (reg-alive (s z) btrue) reg-freed
| tr-destroy-live  : transition (reg-alive (s N) bfalse) (reg-alive (s N) btrue)
| tr-destroy-zero  : transition (reg-alive z bfalse) reg-freed
;

LF reachable : reg-state -> reg-state -> type =
| reach-refl : reachable S S
| reach-step : transition S T -> reachable T U -> reachable S U
;

LF tensor-valid : nat -> nat -> nat -> type =
| tv-intro : mul R C Total -> tensor-valid R C Total
;

LF index-in-bounds : nat -> nat -> nat -> nat -> nat -> nat -> type =
| iib-intro :
    lt B Rows ->
    lt D Cols ->
    mul Rows Cols Total ->
    mul B Cols PB ->
    add PB D Idx ->
    lt Idx Total ->
    index-in-bounds B D Rows Cols Total Idx
;

LF split-valid : nat -> nat -> nat -> nat -> type =
| sv-intro :
    add Dim Dim TwoD ->
    mul B TwoD Full ->
    mul B Dim Half ->
    split-valid B Dim Full Half
;

LF merge-valid : nat -> nat -> nat -> nat -> type =
| mv-intro :
    add Dim Dim TwoD ->
    mul B Dim Half ->
    mul B TwoD Full ->
    merge-valid B Dim Half Full
;

LF is-acquirable : reg-state -> type =
| acquirable-alive : is-acquirable (reg-alive N bfalse)
;

LF is-core-valid : reg-state -> type =
| cv-alive-false : is-core-valid (reg-alive N bfalse)
| cv-alive-true  : is-core-valid (reg-alive N btrue)
;

LF layer-shape-inv : nat -> nat -> nat -> nat -> type =
| lsi-intro :
    mul Dim Dim DimSq ->
    mul (s z) Dim Dim ->
    layer-shape-inv Dim DimSq (s z) Dim
;

LF grad-shape-inv : nat -> nat -> nat -> nat -> type =
| gsi-intro :
    mul Dim Dim DimSq ->
    mul (s z) Dim Dim ->
    grad-shape-inv Dim DimSq (s z) Dim
;

LF model-shape-inv : nat -> nat -> nat -> nat -> nat -> type =
| msi-intro :
    add Dim Dim TwoD ->
    mul Batch TwoD Full ->
    mul Batch Dim Half ->
    model-shape-inv Batch Dim TwoD Full Half
;

LF backward-valid : nat -> nat -> nat -> nat -> type =
| bv-intro :
    add Dim Dim TwoD ->
    mul Batch TwoD Full ->
    backward-valid Batch Dim TwoD Full
;

LF checkedmul-result : nat -> nat -> nat -> type =
| cmr-ok       : mul A B P -> checkedmul-result A B P
| cmr-overflow : checkedmul-result A B z
;

LF slice-valid : nat -> nat -> nat -> type =
| slv-intro :
    add Start Len End ->
    leq End Total ->
    slice-valid Start Len Total
;

inductive AddW : {M : [|- nat]} {N : [|- nat]} ctype =
| AddW : {P : [|- nat]} [|- add M N P] -> AddW [|- M] [|- N]
;

inductive MulW : {M : [|- nat]} {N : [|- nat]} ctype =
| MulW : {P : [|- nat]} [|- mul M N P] -> MulW [|- M] [|- N]
;

inductive AddUniqueW : {M : [|- nat]} {N : [|- nat]} {P : [|- nat]} {Q : [|- nat]} ctype =
| AddUniqueW : [|- eq-nat P Q] -> AddUniqueW [|- M] [|- N] [|- P] [|- Q]
;

inductive MulUniqueW : {M : [|- nat]} {N : [|- nat]} {P : [|- nat]} {Q : [|- nat]} ctype =
| MulUniqueW : [|- eq-nat P Q] -> MulUniqueW [|- M] [|- N] [|- P] [|- Q]
;

inductive AddCommW : {M : [|- nat]} {N : [|- nat]} {P : [|- nat]} ctype =
| AddCommW : [|- add N M P] -> AddCommW [|- M] [|- N] [|- P]
;

inductive AddZeroRightW : {N : [|- nat]} ctype =
| AddZeroRightW : [|- add N z N] -> AddZeroRightW [|- N]
;

inductive AddSuccRightW : {M : [|- nat]} {N : [|- nat]} {P : [|- nat]} ctype =
| AddSuccRightW : [|- add M (s N) (s P)] -> AddSuccRightW [|- M] [|- N] [|- P]
;

inductive AddAssocW : {A : [|- nat]} {B : [|- nat]} {C : [|- nat]} {ABC : [|- nat]} ctype =
| AddAssocW : {BC : [|- nat]} [|- add B C BC] -> [|- add A BC ABC]
           -> AddAssocW [|- A] [|- B] [|- C] [|- ABC]
;

inductive RevAssocW : {A : [|- nat]} {C : [|- nat]} {B : [|- nat]} {CB : [|- nat]} {R : [|- nat]} ctype =
| RevAssocW : {AC : [|- nat]} [|- add A C AC] -> [|- add AC B R]
           -> RevAssocW [|- A] [|- C] [|- B] [|- CB] [|- R]
;

inductive LeqAddW : {A : [|- nat]} {B : [|- nat]} {C : [|- nat]} ctype =
| LeqAddW : [|- leq B C] -> LeqAddW [|- A] [|- B] [|- C]
;

inductive IndexBoundW : {B : [|- nat]} {D : [|- nat]} {Rows : [|- nat]} {Cols : [|- nat]} ctype =
| IndexBoundW : {Total : [|- nat]} {PB : [|- nat]} {Idx : [|- nat]}
    [|- mul Rows Cols Total] ->
    [|- mul B Cols PB] ->
    [|- add PB D Idx] ->
    [|- lt Idx Total] ->
    IndexBoundW [|- B] [|- D] [|- Rows] [|- Cols]
;

inductive EqNatSymW : {M : [|- nat]} {N : [|- nat]} ctype =
| EqNatSymW : [|- eq-nat N M] -> EqNatSymW [|- M] [|- N]
;

inductive EqNatTransW : {A : [|- nat]} {B : [|- nat]} {C : [|- nat]} ctype =
| EqNatTransW : [|- eq-nat A C] -> EqNatTransW [|- A] [|- B] [|- C]
;

inductive LeqTransW : {A : [|- nat]} {B : [|- nat]} {C : [|- nat]} ctype =
| LeqTransW : [|- leq A C] -> LeqTransW [|- A] [|- B] [|- C]
;

inductive LtLeqTransW : {A : [|- nat]} {B : [|- nat]} {C : [|- nat]} ctype =
| LtLeqTransW : [|- lt A C] -> LtLeqTransW [|- A] [|- B] [|- C]
;

inductive LeqSuccW : {A : [|- nat]} {B : [|- nat]} ctype =
| LeqSuccW : [|- leq A (s B)] -> LeqSuccW [|- A] [|- B]
;

inductive LtSuccLeqW : {A : [|- nat]} {B : [|- nat]} ctype =
| LtSuccLeqW : [|- lt A (s B)] -> LtSuccLeqW [|- A] [|- B]
;

inductive AddRightPreservesLtW : {A : [|- nat]} {B : [|- nat]} {C : [|- nat]} {AC : [|- nat]} {BC : [|- nat]} ctype =
| AddRightPreservesLtW : [|- lt AC BC] -> AddRightPreservesLtW [|- A] [|- B] [|- C] [|- AC] [|- BC]
;

inductive AddLeftPreservesLtW : {A : [|- nat]} {B : [|- nat]} {C : [|- nat]} {CA : [|- nat]} {CB : [|- nat]} ctype =
| AddLeftPreservesLtW : [|- lt CA CB] -> AddLeftPreservesLtW [|- A] [|- B] [|- C] [|- CA] [|- CB]
;

inductive MulPreservesLeqW : {A : [|- nat]} {B : [|- nat]} {C : [|- nat]} {AC : [|- nat]} {BC : [|- nat]} ctype =
| MulPreservesLeqW : [|- leq AC BC] -> MulPreservesLeqW [|- A] [|- B] [|- C] [|- AC] [|- BC]
;

inductive AddMonoRightW : {A : [|- nat]} {B : [|- nat]} {C : [|- nat]} {AC : [|- nat]} {BC : [|- nat]} ctype =
| AddMonoRightW : [|- leq AC BC] -> AddMonoRightW [|- A] [|- B] [|- C] [|- AC] [|- BC]
;

inductive SplitIndexFirstW : {B : [|- nat]} {D : [|- nat]} {Batch : [|- nat]} {Dim : [|- nat]} ctype =
| SplitIndexFirstW : {TwoD : [|- nat]} {Full : [|- nat]} {Half : [|- nat]} {PB2 : [|- nat]} {Idx : [|- nat]}
    [|- lt Idx Full] ->
    SplitIndexFirstW [|- B] [|- D] [|- Batch] [|- Dim]
;

inductive SplitIndexSecondW : {B : [|- nat]} {D : [|- nat]} {Batch : [|- nat]} {Dim : [|- nat]} ctype =
| SplitIndexSecondW : {TwoD : [|- nat]} {Full : [|- nat]} {Half : [|- nat]} {PB2 : [|- nat]} {PB2D : [|- nat]} {Idx : [|- nat]}
    [|- lt Idx Full] ->
    SplitIndexSecondW [|- B] [|- D] [|- Batch] [|- Dim]
;

inductive MergeIndexW : {B : [|- nat]} {D : [|- nat]} {Batch : [|- nat]} {Dim : [|- nat]} ctype =
| MergeIndexW : {TwoD : [|- nat]} {Full : [|- nat]} {Half : [|- nat]} {PBH : [|- nat]} {Idx : [|- nat]}
    [|- lt Idx Half] ->
    MergeIndexW [|- B] [|- D] [|- Batch] [|- Dim]
;

inductive MergeOutputIndexW : {B : [|- nat]} {D : [|- nat]} {Batch : [|- nat]} {Dim : [|- nat]} ctype =
| MergeOutputIndexW : {TwoD : [|- nat]} {Full : [|- nat]} {Half : [|- nat]} {PB2 : [|- nat]} {Idx : [|- nat]}
    [|- lt Idx Full] ->
    MergeOutputIndexW [|- B] [|- D] [|- Batch] [|- Dim]
;

inductive MergeOutputSecondIndexW : {B : [|- nat]} {D : [|- nat]} {Batch : [|- nat]} {Dim : [|- nat]} ctype =
| MergeOutputSecondIndexW : {TwoD : [|- nat]} {Full : [|- nat]} {Half : [|- nat]} {PB2 : [|- nat]} {PB2D : [|- nat]} {Idx : [|- nat]}
    [|- lt Idx Full] ->
    MergeOutputSecondIndexW [|- B] [|- D] [|- Batch] [|- Dim]
;

inductive RegistryAcquireW : {N : [|- nat]} ctype =
| RegistryAcquireW : [|- transition (reg-alive N bfalse) (reg-alive (s N) bfalse)]
                  -> RegistryAcquireW [|- N]
;

inductive RegistryReleaseW : {N : [|- nat]} ctype =
| RegistryReleaseW : [|- transition (reg-alive (s N) bfalse) (reg-alive N bfalse)]
                  -> RegistryReleaseW [|- N]
;

inductive RegistryDestroyW : {N : [|- nat]} ctype =
| RegistryDestroyW : [|- transition (reg-alive (s N) bfalse) (reg-alive (s N) btrue)]
                  -> RegistryDestroyW [|- N]
;

inductive EventualCleanupW : {N : [|- nat]} ctype =
| EventualCleanupW : [|- reachable (reg-alive N btrue) reg-freed]
                  -> EventualCleanupW [|- N]
;

inductive ForwardShapeW : {R : [|- nat]} {C : [|- nat]} {Total : [|- nat]} ctype =
| ForwardShapeW : [|- tensor-valid R C Total] -> ForwardShapeW [|- R] [|- C] [|- Total]
;

inductive InverseShapeW : {R : [|- nat]} {C : [|- nat]} {Total : [|- nat]} ctype =
| InverseShapeW : [|- tensor-valid R C Total] -> InverseShapeW [|- R] [|- C] [|- Total]
;

inductive BackwardGradShapeW : {Batch : [|- nat]} {TwoD : [|- nat]} {Full : [|- nat]} ctype =
| BackwardGradShapeW : [|- tensor-valid Batch TwoD Full]
                    -> BackwardGradShapeW [|- Batch] [|- TwoD] [|- Full]
;

inductive SplitShapeW : {Batch : [|- nat]} {Dim : [|- nat]} {TwoD : [|- nat]} {Full : [|- nat]} {Half : [|- nat]} ctype =
| SplitShapeW : [|- tensor-valid Batch Dim Half]
             -> SplitShapeW [|- Batch] [|- Dim] [|- TwoD] [|- Full] [|- Half]
;

inductive MergeShapeW : {Batch : [|- nat]} {Dim : [|- nat]} {TwoD : [|- nat]} {Full : [|- nat]} {Half : [|- nat]} ctype =
| MergeShapeW : [|- tensor-valid Batch TwoD Full]
             -> MergeShapeW [|- Batch] [|- Dim] [|- TwoD] [|- Full] [|- Half]
;

inductive SplitMergeRoundtripW : {Batch : [|- nat]} {Dim : [|- nat]} {TwoD : [|- nat]} {Full : [|- nat]} {Half : [|- nat]} ctype =
| SplitMergeRoundtripW : [|- tensor-valid Batch TwoD Full]
                      -> SplitMergeRoundtripW [|- Batch] [|- Dim] [|- TwoD] [|- Full] [|- Half]
;

inductive LayerInitShapeW : {Dim : [|- nat]} {DimSq : [|- nat]} ctype =
| LayerInitShapeW :
    [|- tensor-valid Dim Dim DimSq] ->
    [|- tensor-valid Dim Dim DimSq] ->
    [|- tensor-valid (s z) Dim Dim] ->
    [|- tensor-valid (s z) Dim Dim] ->
    LayerInitShapeW [|- Dim] [|- DimSq]
;

inductive GradShapeW : {Dim : [|- nat]} {DimSq : [|- nat]} ctype =
| GradShapeW :
    [|- tensor-valid Dim Dim DimSq] ->
    [|- tensor-valid Dim Dim DimSq] ->
    [|- tensor-valid (s z) Dim Dim] ->
    [|- tensor-valid (s z) Dim Dim] ->
    GradShapeW [|- Dim] [|- DimSq]
;

inductive ValidatePairW : {Batch : [|- nat]} {Dim : [|- nat]} {BD : [|- nat]} ctype =
| ValidatePairW :
    [|- lt z (s Batch)] ->
    [|- tensor-valid Batch Dim BD] ->
    [|- tensor-valid Batch Dim BD] ->
    ValidatePairW [|- Batch] [|- Dim] [|- BD]
;

inductive ForwardInnerLoopW : {B : [|- nat]} {D : [|- nat]} {J : [|- nat]} {Batch : [|- nat]} {Dim : [|- nat]} {BD : [|- nat]} ctype =
| ForwardInnerLoopW :
    [|- lt B Batch] ->
    [|- lt D Dim] ->
    [|- lt J Dim] ->
    [|- tensor-valid Batch Dim BD] ->
    ForwardInnerLoopW [|- B] [|- D] [|- J] [|- Batch] [|- Dim] [|- BD]
;

inductive ScaleComputeW : {B : [|- nat]} {D : [|- nat]} {Batch : [|- nat]} {Dim : [|- nat]} {BD : [|- nat]} ctype =
| ScaleComputeW :
    [|- lt B Batch] ->
    [|- lt D Dim] ->
    [|- tensor-valid Batch Dim BD] ->
    ScaleComputeW [|- B] [|- D] [|- Batch] [|- Dim] [|- BD]
;

inductive TranslationComputeW : {B : [|- nat]} {D : [|- nat]} {Batch : [|- nat]} {Dim : [|- nat]} {BD : [|- nat]} ctype =
| TranslationComputeW :
    [|- lt B Batch] ->
    [|- lt D Dim] ->
    [|- tensor-valid Batch Dim BD] ->
    TranslationComputeW [|- B] [|- D] [|- Batch] [|- Dim] [|- BD]
;

inductive BackwardLoopW : {B : [|- nat]} {D : [|- nat]} {Batch : [|- nat]} {Dim : [|- nat]} {BD : [|- nat]} ctype =
| BackwardLoopW :
    [|- lt B Batch] ->
    [|- lt D Dim] ->
    [|- tensor-valid Batch Dim BD] ->
    BackwardLoopW [|- B] [|- D] [|- Batch] [|- Dim] [|- BD]
;

inductive GradScaleW : {Batch : [|- nat]} ctype =
| GradScaleW : [|- lt z (s Batch)] -> GradScaleW [|- Batch]
;

inductive ModelLayerInductionW : {L : [|- nat]} {NumLayers : [|- nat]} ctype =
| ModelLayerInductionW : [|- lt L (s NumLayers)] -> ModelLayerInductionW [|- L] [|- NumLayers]
;

inductive BackwardStageW : {L : [|- nat]} {NumLayers : [|- nat]} {Batch : [|- nat]} {Dim : [|- nat]} {BD : [|- nat]} ctype =
| BackwardStageW :
    [|- lt L (s NumLayers)] ->
    [|- tensor-valid Batch Dim BD] ->
    [|- tensor-valid Batch Dim BD] ->
    BackwardStageW [|- L] [|- NumLayers] [|- Batch] [|- Dim] [|- BD]
;

inductive ForwardStageW : {L : [|- nat]} {NumLayers : [|- nat]} {Batch : [|- nat]} {Dim : [|- nat]} {BD : [|- nat]} ctype =
| ForwardStageW :
    [|- lt L (s NumLayers)] ->
    [|- tensor-valid Batch Dim BD] ->
    [|- tensor-valid Batch Dim BD] ->
    ForwardStageW [|- L] [|- NumLayers] [|- Batch] [|- Dim] [|- BD]
;

inductive CheckedMulResultW : {A : [|- nat]} {B : [|- nat]} ctype =
| CheckedMulResultW : {P : [|- nat]} [|- mul A B P] -> CheckedMulResultW [|- A] [|- B]
;

inductive SliceValidW : {Start : [|- nat]} {Len : [|- nat]} {Total : [|- nat]} ctype =
| SliceValidW : [|- slice-valid Start Len Total] -> SliceValidW [|- Start] [|- Len] [|- Total]
;

inductive RowSliceW : {B : [|- nat]} {Dim : [|- nat]} {Batch : [|- nat]} {BD : [|- nat]} ctype =
| RowSliceW : [|- slice-valid (s z) Dim BD] -> RowSliceW [|- B] [|- Dim] [|- Batch] [|- BD]
;

inductive WeightRowSliceW : {D : [|- nat]} {Dim : [|- nat]} {DimSq : [|- nat]} ctype =
| WeightRowSliceW : [|- lt D Dim] -> [|- slice-valid (s z) Dim DimSq] -> WeightRowSliceW [|- D] [|- Dim] [|- DimSq]
;

inductive SnapshotShapeW : {NumLayers : [|- nat]} {Dim : [|- nat]} {DimSq : [|- nat]} ctype =
| SnapshotShapeW :
    [|- tensor-valid NumLayers Dim DimSq] ->
    [|- tensor-valid NumLayers Dim DimSq] ->
    [|- tensor-valid NumLayers (s z) Dim] ->
    [|- tensor-valid NumLayers (s z) Dim] ->
    SnapshotShapeW [|- NumLayers] [|- Dim] [|- DimSq]
;

inductive SaveVersionW : ctype =
| SaveVersionW : [|- eq-nat (s (s (s (s z)))) (s (s (s (s z))))] -> SaveVersionW
;

inductive LoadVersionCheckW : ctype =
| LoadVersionCheckW : [|- leq z (s (s (s (s z))))] -> LoadVersionCheckW
;

inductive CrcStateW : {NumLayers : [|- nat]} {Dim : [|- nat]} ctype =
| CrcStateW : [|- leq z NumLayers] -> [|- leq z Dim] -> CrcStateW [|- NumLayers] [|- Dim]
;

inductive WriteTensorW : {R : [|- nat]} {C : [|- nat]} {Total : [|- nat]} ctype =
| WriteTensorW : [|- tensor-valid R C Total] -> WriteTensorW [|- R] [|- C] [|- Total]
;

inductive ReadTensorW : {R : [|- nat]} {C : [|- nat]} {Total : [|- nat]} ctype =
| ReadTensorW : [|- tensor-valid R C Total] -> ReadTensorW [|- R] [|- C] [|- Total]
;

inductive GpuSyncW : {Dim : [|- nat]} {DimSq : [|- nat]} ctype =
| GpuSyncW :
    [|- tensor-valid Dim Dim DimSq] ->
    [|- tensor-valid Dim Dim DimSq] ->
    GpuSyncW [|- Dim] [|- DimSq]
;

inductive GpuCompatW : {NumLayers : [|- nat]} {Dim : [|- nat]} ctype =
| GpuCompatW : [|- leq z NumLayers] -> [|- leq z Dim] -> GpuCompatW [|- NumLayers] [|- Dim]
;

inductive F16BufW : {Dim : [|- nat]} {DimSq : [|- nat]} ctype =
| F16BufW : [|- mul Dim Dim DimSq] -> F16BufW [|- Dim] [|- DimSq]
;

inductive XavierBoundW : {Dim : [|- nat]} ctype =
| XavierBoundW : [|- lt z (s (s Dim))] -> XavierBoundW [|- Dim]
;

inductive SeedOffsetW : {Seed : [|- nat]} {Offset : [|- nat]} ctype =
| SeedOffsetW : {Result : [|- nat]} [|- add Seed Offset Result] -> SeedOffsetW [|- Seed] [|- Offset]
;

inductive VersionRangeW : ctype =
| VersionRangeW :
    [|- leq (s z) (s (s (s (s z))))] ->
    [|- leq (s (s (s (s z)))) (s (s (s (s z))))] ->
    VersionRangeW
;

inductive DimSqLeqW : {Dim : [|- nat]} {DimSq : [|- nat]} ctype =
| DimSqLeqW : [|- leq Dim DimSq] -> DimSqLeqW [|- Dim] [|- DimSq]
;

inductive TwoDLeqFullW : {Dim : [|- nat]} {TwoD : [|- nat]} {Batch : [|- nat]} {Full : [|- nat]} ctype =
| TwoDLeqFullW : [|- leq TwoD Full] -> TwoDLeqFullW [|- Dim] [|- TwoD] [|- Batch] [|- Full]
;

inductive BatchDimBDW : {Batch : [|- nat]} {Dim : [|- nat]} {BD : [|- nat]} ctype =
| BatchDimBDW : [|- mul Batch Dim BD] -> BatchDimBDW [|- Batch] [|- Dim] [|- BD]
;

inductive BatchTwoDFullW : {Batch : [|- nat]} {TwoD : [|- nat]} {Full : [|- nat]} ctype =
| BatchTwoDFullW : [|- mul Batch TwoD Full] -> BatchTwoDFullW [|- Batch] [|- TwoD] [|- Full]
;

inductive LayerForwardShapeInvariantW : {Batch : [|- nat]} {Dim : [|- nat]} {BD : [|- nat]} ctype =
| LayerForwardShapeInvariantW :
    [|- tensor-valid Batch Dim BD] ->
    [|- tensor-valid Batch Dim BD] ->
    LayerForwardShapeInvariantW [|- Batch] [|- Dim] [|- BD]
;

inductive LayerInverseShapeInvariantW : {Batch : [|- nat]} {Dim : [|- nat]} {BD : [|- nat]} ctype =
| LayerInverseShapeInvariantW :
    [|- tensor-valid Batch Dim BD] ->
    [|- tensor-valid Batch Dim BD] ->
    LayerInverseShapeInvariantW [|- Batch] [|- Dim] [|- BD]
;

inductive LayerBackwardShapeInvariantW : {Batch : [|- nat]} {Dim : [|- nat]} {BD : [|- nat]} ctype =
| LayerBackwardShapeInvariantW :
    [|- tensor-valid Batch Dim BD] ->
    [|- tensor-valid Batch Dim BD] ->
    [|- tensor-valid Batch Dim BD] ->
    [|- tensor-valid Batch Dim BD] ->
    LayerBackwardShapeInvariantW [|- Batch] [|- Dim] [|- BD]
;

inductive ModelForwardShapeInvariantW : {Batch : [|- nat]} {Dim : [|- nat]} {TwoD : [|- nat]} {Full : [|- nat]} ctype =
| ModelForwardShapeInvariantW :
    [|- tensor-valid Batch TwoD Full] ->
    ModelForwardShapeInvariantW [|- Batch] [|- Dim] [|- TwoD] [|- Full]
;

inductive ModelInverseShapeInvariantW : {Batch : [|- nat]} {Dim : [|- nat]} {TwoD : [|- nat]} {Full : [|- nat]} ctype =
| ModelInverseShapeInvariantW :
    [|- tensor-valid Batch TwoD Full] ->
    ModelInverseShapeInvariantW [|- Batch] [|- Dim] [|- TwoD] [|- Full]
;

inductive ModelBackwardShapeInvariantW : {Batch : [|- nat]} {Dim : [|- nat]} {TwoD : [|- nat]} {Full : [|- nat]} ctype =
| ModelBackwardShapeInvariantW :
    [|- tensor-valid Batch TwoD Full] ->
    [|- tensor-valid Batch TwoD Full] ->
    ModelBackwardShapeInvariantW [|- Batch] [|- Dim] [|- TwoD] [|- Full]
;

inductive RegistryNoUseAfterFreeW : {S : [|- reg-state]} ctype =
| RegistryNoUseAfterFreeW :
    ({T : [|- reg-state]} [|- reachable reg-freed T] -> [|- is-acquirable T] -> [|- eq-nat z (s z)]) ->
    RegistryNoUseAfterFreeW [|- S]
;

inductive RegistryNoDoubleAcquireAfterDestroyW : {N : [|- nat]} ctype =
| RegistryNoDoubleAcquireAfterDestroyW :
    ({S : [|- reg-state]} [|- transition (reg-alive N btrue) S] -> [|- is-acquirable S] -> [|- eq-nat z (s z)]) ->
    RegistryNoDoubleAcquireAfterDestroyW [|- N]
;

inductive RegistryEventualFreeW : {N : [|- nat]} ctype =
| RegistryEventualFreeW :
    [|- reachable (reg-alive N btrue) reg-freed] ->
    RegistryEventualFreeW [|- N]
;

inductive RegistryFreedTerminalW : ctype =
| RegistryFreedTerminalW :
    ({S : [|- reg-state]} [|- reachable reg-freed S] -> [|- eq-nat z z]) ->
    RegistryFreedTerminalW
;

inductive AcquireReleaseBalanceW : {N : [|- nat]} ctype =
| AcquireReleaseBalanceW :
