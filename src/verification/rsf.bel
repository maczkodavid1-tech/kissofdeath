| RSFCoreInitW :
    [|- lt z (s Dim)] ->
    [|- lt z (s NumLayers)] ->
    [|- mul Dim Dim DimSq] ->
    ({L : [|- nat]} [|- lt L NumLayers] ->
     [|- tensor-valid Dim Dim DimSq] *
