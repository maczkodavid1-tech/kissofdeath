| InverseCPUCompleteW :
    [|- tensor-valid Batch TwoD Full] ->
    [|- lt z (s NumLayers)] ->
    InverseCPUCompleteW [|- Batch] [|- Dim] [|- TwoD] [|- Full] [|- NumLayers]
;

