     [|- mul B Dim PBH] -> [|- add PBH D Idx] ->
     [|- lt Idx Half]) ->
    ({B : [|- nat]} {D : [|- nat]}
     [|- lt B Batch] -> [|- lt D Dim] ->
     {PB2 : [|- nat]} {Idx : [|- nat]}
