    [|- tensor-valid Dim Dim DimSq] ->
    [|- tensor-valid Dim Dim DimSq] ->
    [|- tensor-valid (s z) Dim Dim] ->
    [|- tensor-valid (s z) Dim Dim] ->
    [|- is-acquirable (reg-alive z bfalse)] ->
    RSFLayerInitW [|- Dim] [|- DimSq]
;

