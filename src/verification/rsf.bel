rec reachable_from_alive : {N : [|- nat]} {B : [|- bool]} {S : [|- reg-state]}
                            [|- reachable (reg-alive N B) S] ->
                            [|- is-core-valid (reg-alive N B)] =
/ total d (reachable_from_alive _ _ _ d) /
mlam N => mlam B => mlam S =>
fn d =>
case [|- B] of
| [|- bfalse] => [|- cv-alive-false]
| [|- btrue]  => [|- cv-alive-true]
;

rec transition_alive_to_alive : {N : [|- nat]} {M : [|- nat]} {B1 : [|- bool]} {B2 : [|- bool]}
                                 [|- transition (reg-alive N B1) (reg-alive M B2)] ->
                                 [|- is-core-valid (reg-alive M B2)] =
/ total d (transition_alive_to_alive _ _ _ _ d) /
mlam N => mlam M => mlam B1 => mlam B2 =>
fn d =>
case d of
| [|- tr-acquire]       => [|- cv-alive-false]
| [|- tr-release-live]  => [|- cv-alive-false]
| [|- tr-release-dying] => [|- cv-alive-true]
| [|- tr-destroy-live]  => [|- cv-alive-true]
;

rec acquire_then_release_reachable : {N : [|- nat]}
                                     [|- reachable (reg-alive N bfalse) (reg-alive N bfalse)] =
/ total n (acquire_then_release_reachable n) /
mlam N =>
[|- reach-step tr-acquire (reach-step tr-release-live reach-refl)]
;

rec destroy_after_zero_ops : [|- reachable (reg-alive z bfalse) reg-freed] =
/ total (destroy_after_zero_ops) /
[|- reach-step tr-destroy-zero reach-refl]
;

rec destroy_after_one_op : [|- reachable (reg-alive (s z) bfalse) reg-freed] =
/ total (destroy_after_one_op) /
[|- reach-step tr-acquire
    (reach-step tr-destroy-live
    (reach-step tr-release-final reach-refl))]
;

rec active_ops_increases_on_acquire : {N : [|- nat]}
                                      [|- is-acquirable (reg-alive N bfalse)] ->
                                      [|- is-core-valid (reg-alive (s N) bfalse)] =
/ total d (active_ops_increases_on_acquire _ d) /
mlam N =>
fn d =>
case d of
| [|- acquirable-alive] => [|- cv-alive-false]
;

rec active_ops_decreases_on_release : {N : [|- nat]} {B : [|- bool]}
                                      [|- lt z (s N)] ->
                                      [|- is-core-valid (reg-alive (s N) B)] =
/ total d (active_ops_decreases_on_release _ _ d) /
mlam N => mlam B =>
fn d =>
case [|- B] of
| [|- bfalse] => [|- cv-alive-false]
| [|- btrue]  => [|- cv-alive-true]
;

rec destroyed_flag_monotone : {N : [|- nat]} {S : [|- reg-state]}
                               [|- transition (reg-alive N btrue) S] ->
                               [|- is-core-valid S] =
/ total d (destroyed_flag_monotone _ _ d) /
mlam N => mlam S =>
fn d =>
case d of
| [|- tr-release-dying] => [|- cv-alive-true]
| [|- tr-release-final] => [|- cv-alive-false]
| [|- tr-destroy-live]  => [|- cv-alive-true]
;

