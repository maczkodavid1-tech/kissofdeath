mlam Batch => mlam Dim => mlam TwoD => mlam Full => mlam NumLayers =>
fn dadd => fn dmul => fn dlt => fn dacq =>
(BackwardCPUCompleteW
   [|- tv-intro dmul]
   [|- tv-intro dmul]
   [|- tv-intro dmul]
   dlt,
 [|- tr-acquire],
 [|- tr-release-live])
;

