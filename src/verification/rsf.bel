     [|- mul B TwoD PB2] -> [|- add PB2 Dim PB2D] -> [|- add PB2D D Idx] ->
     [|- lt Idx Full]) ->
    MergeFromIndexSafetyW [|- Batch] [|- Dim] [|- TwoD] [|- Full] [|- Half]
;

