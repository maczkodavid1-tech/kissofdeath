                             [|- split-valid Batch Dim Full Half] ->
                             [|- merge-valid Batch Dim Half Full] ->
                             [|- tensor-valid Batch TwoD Full] ->
                             SplitMergeRoundtripW [|- Batch] [|- Dim] [|- TwoD] [|- Full] [|- Half] =
/ total dsv (split_merge_roundtrip _ _ _ _ _ dsv _ _) /
mlam Batch => mlam Dim => mlam TwoD => mlam Full => mlam Half =>
fn dsv => fn dmv => fn dtv =>
SplitMergeRoundtripW dtv
;

rec split_index_first_half : {B : [|- nat]} {D : [|- nat]} {Batch : [|- nat]} {Dim : [|- nat]} {TwoD : [|- nat]} {Full : [|- nat]} {Half : [|- nat]}
                              [|- split-valid Batch Dim Full Half] ->
                              [|- lt B Batch] ->
                              [|- lt D Dim] ->
                              [|- mul B TwoD PB2] ->
                              [|- add PB2 D Idx] ->
                              [|- lt Idx Full] =
/ total dsv (split_index_first_half _ _ _ _ _ _ _ dsv _ _ _ _) /
mlam B => mlam D => mlam Batch => mlam Dim => mlam TwoD => mlam Full => mlam Half =>
fn dsv => fn dltb => fn dltd => fn dmulb2 => fn dadd =>
case dsv of
| [|- sv-intro Ddd Dbtd Dbdh] =>
  let LeqAddW [|- DleqDT] = leq_add [|- Dim] [|- Dim] [|- TwoD] [|- Ddd] in
  let [|- DltDT] = lt_leq_trans [|- D] [|- Dim] [|- TwoD] [|- dltd] [|- DleqDT] in
  index_bound [|- B] [|- D] [|- Batch] [|- TwoD]
              [|- dltb] [|- DltDT] [|- Dbtd] [|- dmulb2] [|- dadd]
;

rec split_index_second_half : {B : [|- nat]} {D : [|- nat]} {Batch : [|- nat]} {Dim : [|- nat]} {TwoD : [|- nat]} {Full : [|- nat]} {Half : [|- nat]}
                               [|- split-valid Batch Dim Full Half] ->
                               [|- lt B Batch] ->
                               [|- lt D Dim] ->
                               [|- mul B TwoD PB2] ->
                               [|- add PB2 Dim PB2D] ->
                               [|- add PB2D D Idx] ->
                               [|- lt Idx Full] =
/ total dsv (split_index_second_half _ _ _ _ _ _ _ dsv _ _ _ _ _) /
mlam B => mlam D => mlam Batch => mlam Dim => mlam TwoD => mlam Full => mlam Half =>
fn dsv => fn dltb => fn dltd => fn dmulb2 => fn doff => fn dadd =>
case dsv of
| [|- sv-intro Ddd Dbtd Dbdh] =>
  let AddAssocW [|- DimD] [|- DdimD] [|- Dpb2imd] =
    add_assoc [|- _] [|- Dim] [|- D] [|- _] [|- _] [|- doff] [|- dadd]
  in
  let [|- DltDiD] =
    add_right_preserves_lt [|- D] [|- Dim] [|- Dim] [|- _] [|- _]
                           [|- dltd] [|- dltd] [|- Ddd]
  in
  let LeqAddW [|- DleqTD] = leq_add [|- Dim] [|- D] [|- DimD] [|- DdimD] in
  let LeqAddW [|- DleqDD] = leq_add [|- Dim] [|- Dim] [|- TwoD] [|- Ddd] in
  index_bound [|- B] [|- DimD] [|- Batch] [|- TwoD]
              [|- dltb]
              (leq_to_lt_succ [|- DimD] [|- TwoD]
                 (leq_trans [|- DimD] [|- _] [|- TwoD]
                    [|- DleqTD]
                    [|- DleqDD]))
              [|- Dbtd] [|- dmulb2] [|- Dpb2imd]
;

rec merge_src_index_safe : {B : [|- nat]} {D : [|- nat]} {Batch : [|- nat]} {Dim : [|- nat]} {TwoD : [|- nat]} {Full : [|- nat]} {Half : [|- nat]}
                            [|- merge-valid Batch Dim Half Full] ->
                            [|- lt B Batch] ->
                            [|- lt D Dim] ->
                            [|- mul B Dim PBH] ->
                            [|- add PBH D Idx] ->
                            [|- lt Idx Half] =
/ total dmv (merge_src_index_safe _ _ _ _ _ _ _ dmv _ _ _ _) /
mlam B => mlam D => mlam Batch => mlam Dim => mlam TwoD => mlam Full => mlam Half =>
fn dmv => fn dltb => fn dltd => fn dmulbh => fn dadd =>
case dmv of
| [|- mv-intro Ddd Dbdh Dbtd] =>
  index_bound [|- B] [|- D] [|- Batch] [|- Dim]
              [|- dltb] [|- dltd] [|- Dbdh] [|- dmulbh] [|- dadd]
;

rec merge_dst_first_index_safe : {B : [|- nat]} {D : [|- nat]} {Batch : [|- nat]} {Dim : [|- nat]} {TwoD : [|- nat]} {Full : [|- nat]} {Half : [|- nat]}
                                  [|- merge-valid Batch Dim Half Full] ->
                                  [|- lt B Batch] ->
                                  [|- lt D Dim] ->
                                  [|- mul B TwoD PB2] ->
