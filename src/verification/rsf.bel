fn dmv => fn dltb => fn dltd => fn dmulb2 => fn dadd =>
case dmv of
| [|- mv-intro Ddd Dbdh Dbtd] =>
  let LeqAddW [|- DleqDT] = leq_add [|- Dim] [|- Dim] [|- TwoD] [|- Ddd] in
  let [|- DltDT] = lt_leq_trans [|- D] [|- Dim] [|- TwoD] [|- dltd] [|- DleqDT] in
  index_bound [|- B] [|- D] [|- Batch] [|- TwoD]
              [|- dltb] [|- DltDT] [|- Dbtd] [|- dmulb2] [|- dadd]
;

rec merge_dst_second_index_safe : {B : [|- nat]} {D : [|- nat]} {Batch : [|- nat]} {Dim : [|- nat]} {TwoD : [|- nat]} {Full : [|- nat]} {Half : [|- nat]}
                                   [|- merge-valid Batch Dim Half Full] ->
                                   [|- lt B Batch] ->
                                   [|- lt D Dim] ->
                                   [|- mul B TwoD PB2] ->
                                   [|- add PB2 Dim PB2D] ->
                                   [|- add PB2D D Idx] ->
                                   [|- lt Idx Full] =
/ total dmv (merge_dst_second_index_safe _ _ _ _ _ _ _ dmv _ _ _ _ _) /
mlam B => mlam D => mlam Batch => mlam Dim => mlam TwoD => mlam Full => mlam Half =>
fn dmv => fn dltb => fn dltd => fn dmulb2 => fn doff => fn dadd =>
case dmv of
| [|- mv-intro Ddd Dbdh Dbtd] =>
  let AddAssocW [|- DimD] [|- DdimD] [|- Dpb2imd] =
    add_assoc [|- _] [|- Dim] [|- D] [|- _] [|- _] [|- doff] [|- dadd]
  in
  let LeqAddW [|- DleqTD] = leq_add [|- Dim] [|- D] [|- DimD] [|- DdimD] in
  let LeqAddW [|- DleqDD] = leq_add [|- Dim] [|- Dim] [|- TwoD] [|- Ddd] in
  index_bound [|- B] [|- DimD] [|- Batch] [|- TwoD]
              [|- dltb]
              (leq_to_lt_succ [|- DimD] [|- TwoD]
                 (leq_trans [|- DimD] [|- _] [|- TwoD]
                    [|- DleqTD]
                    [|- DleqDD]))
              [|- Dbtd] [|- dmulb2] [|- Dpb2imd]
;

rec split_into_index_safety : {Batch : [|- nat]} {Dim : [|- nat]} {TwoD : [|- nat]} {Full : [|- nat]} {Half : [|- nat]}
                               [|- split-valid Batch Dim Full Half] ->
                               SplitIntoIndexSafetyW [|- Batch] [|- Dim] [|- TwoD] [|- Full] [|- Half] =
/ total dsv (split_into_index_safety _ _ _ _ _ dsv) /
mlam Batch => mlam Dim => mlam TwoD => mlam Full => mlam Half =>
fn dsv =>
SplitIntoIndexSafetyW
  (mlam B => mlam D => fn dltb => fn dltd => mlam PB2 => mlam Idx => fn dmulb2 => fn dadd =>
   split_index_first_half [|- B] [|- D] [|- Batch] [|- Dim] [|- TwoD] [|- Full] [|- Half]
                           dsv dltb dltd [|- dmulb2] [|- dadd])
  (mlam B => mlam D => fn dltb => fn dltd => mlam PB2 => mlam PB2D => mlam Idx => fn dmulb2 => fn doff => fn dadd =>
   split_index_second_half [|- B] [|- D] [|- Batch] [|- Dim] [|- TwoD] [|- Full] [|- Half]
                            dsv dltb dltd [|- dmulb2] [|- doff] [|- dadd])
  (mlam B => mlam D => fn dltb => fn dltd => mlam PBH => mlam Idx => fn dmulbh => fn dadd =>
   merge_src_index_safe [|- B] [|- D] [|- Batch] [|- Dim] [|- TwoD] [|- Full] [|- Half]
                        (case dsv of
                         | [|- sv-intro Ddd Dbtd Dbdh] =>
                           [|- mv-intro Ddd Dbdh Dbtd])
                        dltb dltd [|- dmulbh] [|- dadd])
;

rec merge_from_index_safety : {Batch : [|- nat]} {Dim : [|- nat]} {TwoD : [|- nat]} {Full : [|- nat]} {Half : [|- nat]}
                               [|- merge-valid Batch Dim Half Full] ->
                               MergeFromIndexSafetyW [|- Batch] [|- Dim] [|- TwoD] [|- Full] [|- Half] =
/ total dmv (merge_from_index_safety _ _ _ _ _ dmv) /
mlam Batch => mlam Dim => mlam TwoD => mlam Full => mlam Half =>
fn dmv =>
MergeFromIndexSafetyW
  (mlam B => mlam D => fn dltb => fn dltd => mlam PBH => mlam Idx => fn dmulbh => fn dadd =>
   merge_src_index_safe [|- B] [|- D] [|- Batch] [|- Dim] [|- TwoD] [|- Full] [|- Half]
                        dmv dltb dltd [|- dmulbh] [|- dadd])
  (mlam B => mlam D => fn dltb => fn dltd => mlam PB2 => mlam Idx => fn dmulb2 => fn dadd =>
   merge_dst_first_index_safe [|- B] [|- D] [|- Batch] [|- Dim] [|- TwoD] [|- Full] [|- Half]
                               dmv dltb dltd [|- dmulb2] [|- dadd])
  (mlam B => mlam D => fn dltb => fn dltd => mlam PB2 => mlam PB2D => mlam Idx => fn dmulb2 => fn doff => fn dadd =>
   merge_dst_second_index_safe [|- B] [|- D] [|- Batch] [|- Dim] [|- TwoD] [|- Full] [|- Half]
                                dmv dltb dltd [|- dmulb2] [|- doff] [|- dadd])
;

