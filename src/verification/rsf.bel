| ForwardCPUCompleteW :
    [|- tensor-valid Batch TwoD Full] ->
    [|- lt z (s NumLayers)] ->
    ForwardCPUCompleteW [|- Batch] [|- Dim] [|- TwoD] [|- Full] [|- NumLayers]
;

