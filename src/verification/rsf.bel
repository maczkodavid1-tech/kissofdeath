rec row_index_safe : {B : [|- nat]} {Batch : [|- nat]} {Dim : [|- nat]} {BD : [|- nat]}
                     [|- lt B Batch] ->
                     [|- mul Batch Dim BD] ->
                     {PB : [|- nat]}
                     [|- mul B Dim PB] ->
                     [|- leq PB BD] =
/ total d1 (row_index_safe _ _ _ _ d1 _ _ _) /
mlam B => mlam Batch => mlam Dim => mlam BD =>
fn dltb => fn dmul_bd => mlam PB => fn dmul_pb =>
let LeqAddW [|- Dlq] = leq_add [|- PB] [|- Dim] [|- BD]
  (let MulW [|- Q] [|- Dq] = mul_total [|- B] [|- Dim] in
   let MulUniqueW [|- eq-nat-refl] = mul_unique [|- B] [|- Dim] [|- Q] [|- PB] [|- Dq] [|- dmul_pb] in
   let AddW [|- BD'] [|- Dadd'] = add_total [|- PB] [|- Dim] in
   let MulUniqueW [|- eq-nat-refl] = mul_unique [|- Batch] [|- Dim] [|- BD'] [|- BD] [|- dmul_bd] [|- dmul_bd] in
   [|- Dadd'])
in
Dlq
;

