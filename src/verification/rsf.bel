                             [|- lt D Cols] =
/ total d (index_bound_batch_one _ _ d _ _) /
mlam D => mlam Cols =>
fn dlt => fn dmul => fn dadd => dlt
;

rec mul_succ_left_unfold : {M : [|- nat]} {N : [|- nat]} {P : [|- nat]} {Q : [|- nat]}
                            [|- mul M N P] -> [|- add P N Q] -> [|- mul (s M) N Q] =
/ total d (mul_succ_left_unfold _ _ _ _ d _) /
mlam M => mlam N => mlam P => mlam Q =>
fn dm => fn da =>
[|- mul-s dm da]
;

rec add_both_sides_leq : {A : [|- nat]} {B : [|- nat]} {C : [|- nat]} {AC : [|- nat]} {BC : [|- nat]}
                          [|- leq A B] -> [|- add A C AC] -> [|- add B C BC] -> [|- leq AC BC] =
/ total d (add_both_sides_leq _ _ _ _ _ d _ _) /
mlam A => mlam B => mlam C => mlam AC => mlam BC =>
fn dleq => fn dac => fn dbc =>
add_mono_right [|- A] [|- B] [|- C] [|- AC] [|- BC] dleq dac dbc
;

rec lt_succ_implies_leq : {A : [|- nat]} {B : [|- nat]}
                           [|- lt A (s B)] -> [|- leq A B] =
/ total d (lt_succ_implies_leq _ _ d) /
mlam A => mlam B =>
fn d =>
case d of
| [|- lt-z] => [|- leq-z]
| [|- lt-s D'] =>
  let [|- D''] = lt_succ_implies_leq [|- _] [|- _] [|- D'] in
  [|- leq-s D'']
;

rec leq_pred : {A : [|- nat]} {B : [|- nat]}
               [|- leq (s A) (s B)] -> [|- leq A B] =
/ total d (leq_pred _ _ d) /
mlam A => mlam B =>
fn d =>
case d of
| [|- leq-s D'] => [|- D']
;

rec lt_pred : {A : [|- nat]} {B : [|- nat]}
              [|- lt (s A) (s B)] -> [|- lt A B] =
/ total d (lt_pred _ _ d) /
mlam A => mlam B =>
fn d =>
case d of
| [|- lt-s D'] => [|- D']
;

rec leq_zero_is_zero : {N : [|- nat]}
                        [|- leq N z] -> [|- eq-nat N z] =
/ total d (leq_zero_is_zero _ d) /
mlam N =>
fn d =>
case d of
| [|- leq-z] => [|- eq-nat-refl]
;

rec lt_zero_impossible : {N : [|- nat]}
                          [|- lt N z] -> [|- eq-nat z (s z)] =
/ total d (lt_zero_impossible _ d) /
mlam N =>
fn d =>
case d of
;

rec add_zero_left : {N : [|- nat]} [|- add z N N] =
/ total n (add_zero_left n) /
mlam N => [|- add-z]
;

rec mul_zero_right : {M : [|- nat]} [|- mul M z z] =
/ total m (mul_zero_right m) /
mlam M =>
case [|- M] of
| [|- z]    => [|- mul-z]
| [|- s M'] =>
  let [|- D'] = mul_zero_right [|- M'] in
  [|- mul-s D' add-z]
;

rec mul_one_right : {M : [|- nat]} [|- mul M (s z) M] =
/ total m (mul_one_right m) /
mlam M =>
case [|- M] of
| [|- z]    => [|- mul-z]
| [|- s M'] =>
  let [|- D'] = mul_one_right [|- M'] in
  [|- mul-s D' (add-s add-z)]
;

rec mul_comm : {M : [|- nat]} {N : [|- nat]} {P : [|- nat]}
               [|- mul M N P] -> [|- mul N M P] =
/ total d (mul_comm _ _ _ d) /
mlam M => mlam N => mlam P =>
fn d =>
case d of
| [|- mul-z] =>
  mul_zero_right [|- N]
| [|- mul-s Dm Da] =>
  let [|- Dm_comm] = mul_comm [|- _] [|- N] [|- _] [|- Dm] in
  let AddCommW [|- Da_comm] = add_comm [|- _] [|- N] [|- _] [|- Da] in
  let MulUniqueW [|- eq-nat-refl] =
    mul_unique [|- _] [|- N] [|- _] [|- _] [|- Dm_comm] [|- Dm_comm]
  in
  [|- mul-s Dm_comm Da_comm]
;

rec split_valid_implies_merge_valid : {Batch : [|- nat]} {Dim : [|- nat]} {Full : [|- nat]} {Half : [|- nat]}
                                      [|- split-valid Batch Dim Full Half] ->
                                      [|- merge-valid Batch Dim Half Full] =
/ total d (split_valid_implies_merge_valid _ _ _ _ d) /
mlam Batch => mlam Dim => mlam Full => mlam Half =>
