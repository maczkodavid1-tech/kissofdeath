rec add_assoc_four : {A : [|- nat]} {B : [|- nat]} {C : [|- nat]} {D : [|- nat]}
                     {AB : [|- nat]} {ABC : [|- nat]} {ABCD : [|- nat]}
                     [|- add A B AB] ->
                     [|- add AB C ABC] ->
                     [|- add ABC D ABCD] ->
                     AddAssocW [|- A] [|- B] [|- s z] [|- ABCD] =
/ total d1 (add_assoc_four _ _ _ _ _ _ _ d1 _ _) /
mlam A => mlam B => mlam C => mlam D => mlam AB => mlam ABC => mlam ABCD =>
fn dab => fn dabc => fn dabcd =>
let AddAssocW [|- BCD] [|- Dbcd] [|- Da] =
  add_assoc [|- AB] [|- C] [|- D] [|- ABC] [|- ABCD] [|- dabc] [|- dabcd]
in
let AddAssocW [|- BCD'] [|- Dbcd'] [|- Da'] =
  add_assoc [|- A] [|- B] [|- BCD] [|- AB] [|- ABCD]
            [|- dab]
            (let AddW [|- ABCD'] [|- Dabcd'] = add_total [|- AB] [|- BCD] in
             let AddUniqueW [|- eq-nat-refl] =
               add_unique [|- AB] [|- BCD] [|- ABCD'] [|- ABCD]
                          [|- Dabcd']
                          (let AddAssocW [|- BCD''] [|- Dbcd''] [|- _] =
                             add_assoc [|- A] [|- B] [|- BCD] [|- AB] [|- ABCD'] [|- dab] [|- Dabcd']
                           in [|- Dabcd'])
             in [|- Dabcd'])
in
AddAssocW [|- BCD] [|- Dbcd] [|- Da]
;

rec mul_zero_right : {M : [|- nat]} [|- mul M z z] =
/ total m (mul_zero_right m) /
mlam M =>
case [|- M] of
| [|- z]    => [|- mul-z]
| [|- s M'] =>
  let [|- D'] = mul_zero_right [|- M'] in
  let AddZeroRightW [|- Dz] = add_zero_right [|- z] in
  [|- mul-s D' add-z]
;

rec mul_one_right : {M : [|- nat]} [|- mul M (s z) M] =
/ total m (mul_one_right m) /
mlam M =>
case [|- M] of
| [|- z]    => [|- mul-z]
| [|- s M'] =>
  let [|- D'] = mul_one_right [|- M'] in
  [|- mul-s D' (add-s add-z)]
;

rec mul_comm : {M : [|- nat]} {N : [|- nat]} {P : [|- nat]}
               [|- mul M N P] -> [|- mul N M P] =
/ total d (mul_comm _ _ _ d) /
mlam M => mlam N => mlam P =>
fn d =>
case d of
| [|- mul-z] =>
  mul_zero_right [|- N]
| [|- mul-s Dm Da] =>
  let [|- Dm_comm] = mul_comm [|- _] [|- N] [|- _] [|- Dm] in
  let AddCommW [|- Da_comm] = add_comm [|- _] [|- N] [|- _] [|- Da] in
  let AddW [|- NP] [|- DNP] = add_total [|- N] [|- _] in
  let MulUniqueW [|- eq-nat-refl] = mul_unique [|- _] [|- N] [|- _] [|- _] [|- Dm_comm] [|- Dm_comm] in
  let AddUniqueW [|- eq-nat-refl] = add_unique [|- _] [|- N] [|- NP] [|- P] [|- DNP] [|- Da_comm] in
  [|- mul-s Dm_comm Da_comm]
;

rec mul_succ_right : {M : [|- nat]} {N : [|- nat]} {P : [|- nat]} {Q : [|- nat]}
                     [|- mul M N P] -> [|- add P M Q] -> [|- mul M (s N) Q] =
/ total d (mul_succ_right _ _ _ _ d _) /
mlam M => mlam N => mlam P => mlam Q =>
fn dm => fn da =>
case dm of
| [|- mul-z] =>
  (case da of
   | [|- add-z] => [|- mul-z])
| [|- mul-s Dm' Da'] =>
  let AddW [|- PM'] [|- DPM'] = add_total [|- _] [|- M] in
  let AddW [|- NQ'] [|- DNQ'] = add_total [|- N] [|- _] in
  let [|- Dm''] = mul_succ_right [|- _] [|- N] [|- _] [|- PM'] [|- Dm'] [|- DPM'] in
  let AddAssocW [|- MA] [|- Dma] [|- Drr] =
    add_assoc [|- _] [|- M] [|- s z] [|- PM'] [|- _] [|- DPM'] [|- add-s add-z]
  in
  [|- mul-s Dm'' da]
;

rec mul_dist_add : {A : [|- nat]} {B : [|- nat]} {C : [|- nat]} {AB : [|- nat]} {ABC : [|- nat]}
                   [|- add A B AB] -> [|- mul AB C ABC] -> [|- mul A C AC] -> [|- mul B C BC] -> [|- add AC BC ABC] =
/ total d1 (mul_dist_add _ _ _ _ _ d1 _ _ _) /
mlam A => mlam B => mlam C => mlam AB => mlam ABC =>
fn dadd => fn dmul_ab => fn dmul_a => fn dmul_b =>
case dadd of
| [|- add-z] =>
  (case dmul_a of
   | [|- mul-z] =>
     (case dmul_ab of
      | [|- mul-z] =>
        (case dmul_b of
         | [|- mul-z] => [|- add-z]
         | [|- mul-s Dmb' Dab'] =>
           let MulUniqueW [|- eq-nat-refl] =
             mul_unique [|- _] [|- C] [|- _] [|- _] [|- dmul_ab] [|- dmul_b]
           in
           [|- add-z])
      | [|- mul-s Dmab' Daab'] =>
        let MulUniqueW [|- eq-nat-refl] =
          mul_unique [|- _] [|- C] [|- _] [|- _] [|- dmul_ab] [|- dmul_b]
        in
        [|- add-z]))
| [|- add-s Dadd'] =>
  let MulW [|- AC] [|- DmAC] = mul_total [|- A] [|- C] in
  let MulW [|- BC] [|- DmBC] = mul_total [|- B] [|- C] in
  let MulUniqueW [|- eq-nat-refl] = mul_unique [|- A] [|- C] [|- AC] [|- _] [|- DmAC] [|- dmul_a] in
  let MulUniqueW [|- eq-nat-refl] = mul_unique [|- B] [|- C] [|- BC] [|- _] [|- DmBC] [|- dmul_b] in
  let AddW [|- ACBC] [|- DacbC] = add_total [|- AC] [|- BC] in
  let MulUniqueW [|- eq-nat-refl] = mul_unique [|- AB] [|- C] [|- _] [|- ABC] [|- dmul_ab] [|- dmul_ab] in
  [|- DacbC]
;

