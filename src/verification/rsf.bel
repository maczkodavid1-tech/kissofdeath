rec rsf_forward_complete :
    {Batch : [|- nat]} {Dim : [|- nat]} {TwoD : [|- nat]} {Full : [|- nat]} {NumLayers : [|- nat]}
    [|- add Dim Dim TwoD] ->
    [|- mul Batch TwoD Full] ->
    [|- lt z (s NumLayers)] ->
    [|- is-acquirable (reg-alive z bfalse)] ->
    ForwardCPUCompleteW [|- Batch] [|- Dim] [|- TwoD] [|- Full] [|- NumLayers] *
    [|- transition (reg-alive z bfalse) (reg-alive (s z) bfalse)] *
    [|- transition (reg-alive (s z) bfalse) (reg-alive z bfalse)] =
/ total d1 (rsf_forward_complete _ _ _ _ _ d1 _ _ _) /
mlam Batch => mlam Dim => mlam TwoD => mlam Full => mlam NumLayers =>
fn dadd => fn dmul => fn dlt => fn dacq =>
(ForwardCPUCompleteW [|- tv-intro dmul] dlt,
 [|- tr-acquire],
 [|- tr-release-live])
;

rec rsf_backward_complete :
    {Batch : [|- nat]} {Dim : [|- nat]} {TwoD : [|- nat]} {Full : [|- nat]} {NumLayers : [|- nat]}
    [|- add Dim Dim TwoD] ->
    [|- mul Batch TwoD Full] ->
    [|- lt z (s NumLayers)] ->
    [|- is-acquirable (reg-alive z bfalse)] ->
    BackwardCPUCompleteW [|- Batch] [|- Dim] [|- TwoD] [|- Full] [|- NumLayers] *
    [|- transition (reg-alive z bfalse) (reg-alive (s z) bfalse)] *
    [|- transition (reg-alive (s z) bfalse) (reg-alive z bfalse)] =
