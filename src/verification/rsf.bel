                      [|- mul Dim Dim DimSq] ->
                      [|- lt D Dim] ->
                      [|- lt J Dim] ->
                      GradAccumSafeW [|- Dim] [|- DimSq] [|- D] [|- J] =
/ total d1 (grad_accum_safe _ _ _ _ d1 _ _) /
mlam Dim => mlam DimSq => mlam D => mlam J =>
fn dmul => fn dltd => fn dltj =>
let MulW [|- PDJ] [|- Dpdj] = mul_total [|- D] [|- Dim] in
let AddW [|- Idx] [|- Dadd] = add_total [|- PDJ] [|- J] in
let [|- DltIdx] =
  index_bound [|- D] [|- J] [|- Dim] [|- Dim]
              [|- dltd] [|- dltj] [|- dmul] [|- Dpdj] [|- Dadd]
in
GradAccumSafeW dltd dltj [|- PDJ] [|- Dpdj] [|- Idx] [|- Dadd] [|- DltIdx]
;

