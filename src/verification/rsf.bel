rec full_arithmetic_safety :
    ({M : [|- nat]} {N : [|- nat]} AddW [|- M] [|- N]) *
    ({M : [|- nat]} {N : [|- nat]} MulW [|- M] [|- N]) *
    ({A : [|- nat]} {B : [|- nat]} {C : [|- nat]} {P : [|- nat]} {Q : [|- nat]}
     [|- add A B P] -> [|- add A B Q] -> AddUniqueW [|- A] [|- B] [|- P] [|- Q]) *
    ({M : [|- nat]} {N : [|- nat]} {P : [|- nat]} {Q : [|- nat]}
     [|- mul M N P] -> [|- mul M N Q] -> MulUniqueW [|- M] [|- N] [|- P] [|- Q]) *
    ({A : [|- nat]} {B : [|- nat]} [|- leq A B] -> [|- leq A (s B)]) =
/ total (full_arithmetic_safety) /
((mlam M => mlam N => add_total [|- M] [|- N]),
 (mlam M => mlam N => mul_total [|- M] [|- N]),
 (mlam A => mlam B => mlam P => mlam Q => fn d1 => fn d2 =>
  add_unique [|- A] [|- B] [|- P] [|- Q] d1 d2),
 (mlam M => mlam N => mlam P => mlam Q => fn d1 => fn d2 =>
  mul_unique [|- M] [|- N] [|- P] [|- Q] d1 d2),
 (mlam A => mlam B => fn d => leq_step [|- A] [|- B] d))
;

rec full_index_safety :
    ({B : [|- nat]} {D : [|- nat]} {R : [|- nat]} {C : [|- nat]} {T : [|- nat]} {PB : [|- nat]} {Idx : [|- nat]}
     [|- tensor-valid R C T] ->
     [|- lt B R] ->
     [|- lt D C] ->
     [|- mul B C PB] ->
     [|- add PB D Idx] ->
     [|- lt Idx T]) *
    ({B : [|- nat]} {D : [|- nat]} {R : [|- nat]} {C : [|- nat]}
     [|- lt B R] ->
     [|- lt D C] ->
     [|- mul R C Total] ->
     [|- mul B C PB] ->
     [|- add PB D Idx] ->
     [|- lt Idx Total]) =
/ total (full_index_safety) /
((mlam B => mlam D => mlam R => mlam C => mlam T => mlam PB => mlam Idx =>
  fn dtv => fn dltb => fn dltd => fn dmulb => fn dadd =>
  index_safe_2d [|- B] [|- D] [|- R] [|- C] [|- T] [|- PB] [|- Idx]
                dtv dltb dltd dmulb dadd),
 (mlam B => mlam D => mlam R => mlam C =>
  fn dltb => fn dltd => fn dmr => fn dmb => fn dadd =>
  index_bound [|- B] [|- D] [|- R] [|- C] dltb dltd dmr dmb dadd))
;

rec full_split_merge_safety :
    {Batch : [|- nat]} {Dim : [|- nat]} {TwoD : [|- nat]} {Full : [|- nat]} {Half : [|- nat]}
    [|- split-valid Batch Dim Full Half] ->
    [|- merge-valid Batch Dim Half Full] ->
    SplitIntoIndexSafetyW [|- Batch] [|- Dim] [|- TwoD] [|- Full] [|- Half] *
    MergeFromIndexSafetyW [|- Batch] [|- Dim] [|- TwoD] [|- Full] [|- Half] *
    SplitShapeW [|- Batch] [|- Dim] [|- TwoD] [|- Full] [|- Half] *
    MergeShapeW [|- Batch] [|- Dim] [|- TwoD] [|- Full] [|- Half] *
    SplitMergeRoundtripW [|- Batch] [|- Dim] [|- TwoD] [|- Full] [|- Half] =
/ total dsv (full_split_merge_safety _ _ _ _ _ dsv _) /
mlam Batch => mlam Dim => mlam TwoD => mlam Full => mlam Half =>
fn dsv => fn dmv =>
(split_into_index_safety [|- Batch] [|- Dim] [|- TwoD] [|- Full] [|- Half] dsv,
 merge_from_index_safety [|- Batch] [|- Dim] [|- TwoD] [|- Full] [|- Half] dmv,
 split_shape_correct [|- Batch] [|- Dim] [|- TwoD] [|- Full] [|- Half] dsv
   (case dsv of | [|- sv-intro _ Dbf _] => [|- tv-intro Dbf]),
 merge_shape_correct [|- Batch] [|- Dim] [|- TwoD] [|- Full] [|- Half] dmv
   (case dmv of | [|- mv-intro _ Dbh _] => [|- tv-intro Dbh]),
 split_merge_roundtrip [|- Batch] [|- Dim] [|- TwoD] [|- Full] [|- Half] dsv dmv
   (case dsv of | [|- sv-intro _ Dbf _] => [|- tv-intro Dbf]))
;

rec full_registry_completeness :
    ({N : [|- nat]} RegistryAcquireW [|- N]) *
    ({N : [|- nat]} RegistryReleaseW [|- N]) *
    ({N : [|- nat]} RegistryDestroyW [|- N]) *
    ({N : [|- nat]} EventualCleanupW [|- N]) *
    RegistryFreedTerminalW *
    RegistryNoUseAfterFreeW [|- reg-freed] =
/ total (full_registry_completeness) /
((mlam N => RegistryAcquireW [|- tr-acquire]),
 (mlam N => RegistryReleaseW [|- tr-release-live]),
 (mlam N => RegistryDestroyW [|- tr-destroy-live]),
 (mlam N => eventual_cleanup [|- N]),
 registry_freed_terminal,
 registry_no_use_after_free)
;

