inductive SplitIntoIndexSafetyW : {Batch : [|- nat]} {Dim : [|- nat]} {TwoD : [|- nat]} {Full : [|- nat]} {Half : [|- nat]} ctype =
| SplitIntoIndexSafetyW :
    ({B : [|- nat]} {D : [|- nat]}
     [|- lt B Batch] -> [|- lt D Dim] ->
     {PB2 : [|- nat]} {Idx : [|- nat]}
     [|- mul B TwoD PB2] -> [|- add PB2 D Idx] ->
     [|- lt Idx Full]) ->
    ({B : [|- nat]} {D : [|- nat]}
     [|- lt B Batch] -> [|- lt D Dim] ->
     {PB2 : [|- nat]} {PB2D : [|- nat]} {Idx : [|- nat]}
     [|- mul B TwoD PB2] -> [|- add PB2 Dim PB2D] -> [|- add PB2D D Idx] ->
     [|- lt Idx Full]) ->
    ({B : [|- nat]} {D : [|- nat]}
     [|- lt B Batch] -> [|- lt D Dim] ->
     {PBH : [|- nat]} {Idx : [|- nat]}
     [|- mul B Dim PBH] -> [|- add PBH D Idx] ->
     [|- lt Idx Half]) ->
    SplitIntoIndexSafetyW [|- Batch] [|- Dim] [|- TwoD] [|- Full] [|- Half]
;

