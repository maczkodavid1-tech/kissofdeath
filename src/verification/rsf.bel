rec all_arithmetic_lemmas_hold :
    ({M : [|- nat]} {N : [|- nat]} AddW [|- M] [|- N]) *
    ({M : [|- nat]} {N : [|- nat]} MulW [|- M] [|- N]) *
    ({M : [|- nat]} {N : [|- nat]} {P : [|- nat]} [|- add M N P] -> AddCommW [|- M] [|- N] [|- P]) *
    ({A : [|- nat]} {B : [|- nat]} {C : [|- nat]} {AB : [|- nat]} {ABC : [|- nat]}
     [|- add A B AB] -> [|- add AB C ABC] -> AddAssocW [|- A] [|- B] [|- C] [|- ABC]) *
    ({A : [|- nat]} {B : [|- nat]} {C : [|- nat]} {P : [|- nat]} {Q : [|- nat]}
     [|- mul M N P] -> [|- mul M N Q] -> MulUniqueW [|- M] [|- N] [|- P] [|- Q]) =
/ total (all_arithmetic_lemmas_hold) /
((mlam M => mlam N => add_total [|- M] [|- N]),
 (mlam M => mlam N => mul_total [|- M] [|- N]),
 (mlam M => mlam N => mlam P => fn d => add_comm [|- M] [|- N] [|- P] d),
 (mlam A => mlam B => mlam C => mlam AB => mlam ABC => fn d1 => fn d2 =>
  add_assoc [|- A] [|- B] [|- C] [|- AB] [|- ABC] d1 d2),
 (mlam M => mlam N => mlam P => mlam Q => fn d1 => fn d2 =>
  mul_unique [|- M] [|- N] [|- P] [|- Q] d1 d2))
;

rec all_ordering_lemmas_hold :
    ({A : [|- nat]} {B : [|- nat]} {C : [|- nat]} [|- leq A B] -> [|- leq B C] -> [|- leq A C]) *
    ({A : [|- nat]} {B : [|- nat]} {C : [|- nat]} [|- lt A B] -> [|- leq B C] -> [|- lt A C]) *
    ({A : [|- nat]} {B : [|- nat]} [|- leq A B] -> [|- lt A (s B)]) *
    ({A : [|- nat]} {B : [|- nat]} {C : [|- nat]} [|- lt A B] -> [|- lt B C] -> [|- lt A C]) *
    ({A : [|- nat]} {B : [|- nat]} [|- lt A B] -> [|- leq A B]) =
/ total (all_ordering_lemmas_hold) /
((mlam A => mlam B => mlam C => fn d1 => fn d2 => leq_trans [|- A] [|- B] [|- C] d1 d2),
 (mlam A => mlam B => mlam C => fn d1 => fn d2 => lt_leq_trans [|- A] [|- B] [|- C] d1 d2),
 (mlam A => mlam B => fn d => leq_to_lt_succ [|- A] [|- B] d),
 (mlam A => mlam B => mlam C => fn d1 => fn d2 => lt_trans [|- A] [|- B] [|- C] d1 d2),
 (mlam A => mlam B => fn d => lt_to_leq [|- A] [|- B] d))
;

rec all_index_safety_lemmas_hold :
    ({B : [|- nat]} {D : [|- nat]} {Rows : [|- nat]} {Cols : [|- nat]}
     [|- lt B Rows] ->
     [|- lt D Cols] ->
     [|- mul Rows Cols Total] ->
     [|- mul B Cols PB] ->
     [|- add PB D Idx] ->
     [|- lt Idx Total]) =
/ total (all_index_safety_lemmas_hold) /
(mlam B => mlam D => mlam Rows => mlam Cols =>
 fn dltb => fn dltd => fn dmr => fn dmb => fn dadd =>
 index_bound [|- B] [|- D] [|- Rows] [|- Cols]
             dltb dltd dmr dmb dadd)
;

rec all_registry_lemmas_hold :
    ({N : [|- nat]} {S : [|- reg-state]}
     [|- transition (reg-alive N btrue) S] ->
     [|- is-acquirable S] ->
     [|- eq-nat z (s z)]) *
    ({S : [|- reg-state]}
     [|- reachable reg-freed S] ->
     [|- is-acquirable S] ->
     [|- eq-nat z (s z)]) *
    ({N : [|- nat]}
     [|- reachable (reg-alive N btrue) reg-freed]) *
    ({S : [|- reg-state]}
     [|- reachable reg-freed S] ->
     [|- eq-nat z z]) =
/ total (all_registry_lemmas_hold) /
((mlam N => mlam S => fn dtr => fn dacq =>
  no_acquire_after_destroy [|- N] [|- S] dtr dacq),
 (mlam S => fn dr => fn dacq =>
  no_use_after_free [|- S] dr dacq),
 (mlam N =>
  layer_eventual_free_proof [|- N]),
 (mlam S => fn dr =>
  freed_is_terminal [|- S] dr))
;

