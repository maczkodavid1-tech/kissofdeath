rec full_rsf_operation_safety :
    {Dim : [|- nat]} {NumLayers : [|- nat]} {DimSq : [|- nat]}
    {Batch : [|- nat]} {TwoD : [|- nat]} {Full : [|- nat]}
    [|- mul Dim Dim DimSq] ->
    [|- add Dim Dim TwoD] ->
    [|- mul Batch TwoD Full] ->
    [|- lt z (s NumLayers)] ->
    [|- is-acquirable (reg-alive z bfalse)] ->
    ForwardCPUCompleteW [|- Batch] [|- Dim] [|- TwoD] [|- Full] [|- NumLayers] *
    InverseCPUCompleteW [|- Batch] [|- Dim] [|- TwoD] [|- Full] [|- NumLayers] *
    BackwardCPUCompleteW [|- Batch] [|- Dim] [|- TwoD] [|- Full] [|- NumLayers] *
    RSFCoreInitW [|- Dim] [|- NumLayers] [|- DimSq] *
    RSFCoreDeinitW [|- NumLayers] *
    RegistryEventualFreeW [|- z] =
/ total d1 (full_rsf_operation_safety _ _ _ _ _ _ d1 _ _ _ _) /
mlam Dim => mlam NumLayers => mlam DimSq => mlam Batch => mlam TwoD => mlam Full =>
fn dmul => fn dadd => fn dmbtf => fn dlt => fn dacq =>
(ForwardCPUCompleteW [|- tv-intro dmbtf] dlt,
 InverseCPUCompleteW [|- tv-intro dmbtf] dlt,
 BackwardCPUCompleteW [|- tv-intro dmbtf] [|- tv-intro dmbtf] [|- tv-intro dmbtf] dlt,
 rsf_core_init [|- Dim] [|- NumLayers] [|- DimSq] dmul,
 rsf_core_deinit [|- NumLayers],
 let EventualCleanupW [|- DR] = eventual_cleanup [|- z] in
 RegistryEventualFreeW [|- reach-step tr-destroy-zero reach-refl])
;

rec comprehensive_safety_certificate :
    ({M : [|- nat]} {N : [|- nat]} AddW [|- M] [|- N]) *
    ({M : [|- nat]} {N : [|- nat]} MulW [|- M] [|- N]) *
    ({B : [|- nat]} {D : [|- nat]} {R : [|- nat]} {C : [|- nat]} {T : [|- nat]} {PB : [|- nat]} {Idx : [|- nat]}
     [|- tensor-valid R C T] ->
     [|- lt B R] -> [|- lt D C] ->
     [|- mul B C PB] -> [|- add PB D Idx] ->
     [|- lt Idx T]) *
    ({N : [|- nat]} {S : [|- reg-state]}
     [|- transition (reg-alive N btrue) S] ->
     [|- is-acquirable S] ->
     [|- eq-nat z (s z)]) *
    ({S : [|- reg-state]}
     [|- reachable reg-freed S] ->
     [|- is-acquirable S] ->
     [|- eq-nat z (s z)]) *
    ({N : [|- nat]} [|- reachable (reg-alive N btrue) reg-freed]) *
    ({S : [|- reg-state]} [|- reachable reg-freed S] -> [|- eq-nat z z]) =
/ total (comprehensive_safety_certificate) /
((mlam M => mlam N => add_total [|- M] [|- N]),
 (mlam M => mlam N => mul_total [|- M] [|- N]),
 (mlam B => mlam D => mlam R => mlam C => mlam T => mlam PB => mlam Idx =>
  fn dtv => fn dltb => fn dltd => fn dmulb => fn dadd =>
  index_safe_2d [|- B] [|- D] [|- R] [|- C] [|- T] [|- PB] [|- Idx]
                dtv dltb dltd dmulb dadd),
 (mlam N => mlam S => fn dtr => fn dacq =>
  no_acquire_after_destroy [|- N] [|- S] dtr dacq),
 (mlam S => fn dr => fn dacq =>
  no_use_after_free [|- S] dr dacq),
 (mlam N => layer_eventual_free_proof [|- N]),
 (mlam S => fn dr => freed_is_terminal [|- S] dr))
;


