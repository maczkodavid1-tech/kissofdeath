inductive LoadCompleteW : {NumLayers : [|- nat]} {Dim : [|- nat]} {DimSq : [|- nat]} ctype =
| LoadCompleteW :
    [|- leq z NumLayers] ->
    [|- leq z Dim] ->
    [|- leq z DimSq] ->
    LoadCompleteW [|- NumLayers] [|- Dim] [|- DimSq]
;

rec add_total : {M : [|- nat]} {N : [|- nat]} AddW [|- M] [|- N] =
/ total m (add_total m _) /
mlam M => mlam N =>
case [|- M] of
| [|- z] =>
  AddW [|- N] [|- add-z]
| [|- s M'] =>
  let AddW [|- P'] [|- D'] = add_total [|- M'] [|- N] in
  AddW [|- s P'] [|- add-s D']
;

rec add_unique : {M : [|- nat]} {N : [|- nat]} {P : [|- nat]} {Q : [|- nat]}
                 [|- add M N P] -> [|- add M N Q] -> AddUniqueW [|- M] [|- N] [|- P] [|- Q] =
/ total d1 (add_unique _ _ _ _ d1 _) /
mlam M => mlam N => mlam P => mlam Q =>
fn d1 => fn d2 =>
case d1 of
| [|- add-z] =>
  (case d2 of
   | [|- add-z] => AddUniqueW [|- eq-nat-refl])
| [|- add-s D1'] =>
  (case d2 of
   | [|- add-s D2'] =>
     let AddUniqueW [|- eq-nat-refl] =
       add_unique [|- _] [|- N] [|- _] [|- _] [|- D1'] [|- D2']
     in
     AddUniqueW [|- eq-nat-refl])
;

rec add_zero_right : {N : [|- nat]} AddZeroRightW [|- N] =
/ total n (add_zero_right n) /
mlam N =>
case [|- N] of
| [|- z] =>
  AddZeroRightW [|- add-z]
| [|- s N'] =>
  let AddZeroRightW [|- D'] = add_zero_right [|- N'] in
  AddZeroRightW [|- add-s D']
;

rec add_succ_right : {M : [|- nat]} {N : [|- nat]} {P : [|- nat]}
                     [|- add M N P] -> AddSuccRightW [|- M] [|- N] [|- P] =
/ total d (add_succ_right _ _ _ d) /
mlam M => mlam N => mlam P =>
fn d =>
case d of
| [|- add-z] =>
  AddSuccRightW [|- add-z]
| [|- add-s D'] =>
  let AddSuccRightW [|- D''] = add_succ_right [|- _] [|- N] [|- _] [|- D'] in
  AddSuccRightW [|- add-s D'']
;

rec add_comm : {M : [|- nat]} {N : [|- nat]} {P : [|- nat]}
               [|- add M N P] -> AddCommW [|- M] [|- N] [|- P] =
/ total d (add_comm _ _ _ d) /
mlam M => mlam N => mlam P =>
fn d =>
case d of
| [|- add-z] =>
  let AddZeroRightW [|- Dz] = add_zero_right [|- N] in
  AddCommW [|- Dz]
| [|- add-s D'] =>
  let AddCommW [|- Dc'] = add_comm [|- _] [|- N] [|- _] [|- D'] in
  let AddSuccRightW [|- Dsr] = add_succ_right [|- N] [|- _] [|- _] [|- Dc'] in
  AddCommW [|- Dsr]
;

rec add_assoc : {A : [|- nat]} {B : [|- nat]} {C : [|- nat]} {AB : [|- nat]} {ABC : [|- nat]}
                [|- add A B AB] -> [|- add AB C ABC]
             -> AddAssocW [|- A] [|- B] [|- C] [|- ABC] =
/ total d1 (add_assoc _ _ _ _ _ d1 _) /
mlam A => mlam B => mlam C => mlam AB => mlam ABC =>
fn d1 => fn d2 =>
case d1 of
| [|- add-z] =>
  AddAssocW [|- ABC] [|- d2] [|- add-z]
| [|- add-s D1'] =>
  (case d2 of
   | [|- add-s D2'] =>
     let AddAssocW [|- BC] [|- Dbc] [|- Da'] =
       add_assoc [|- _] [|- B] [|- C] [|- _] [|- _] [|- D1'] [|- D2']
     in
     AddAssocW [|- BC] [|- Dbc] [|- add-s Da'])
;

rec add_rev_assoc : {A : [|- nat]} {C : [|- nat]} {B : [|- nat]} {CB : [|- nat]} {R : [|- nat]}
                    [|- add C B CB] -> [|- add A CB R]
                 -> RevAssocW [|- A] [|- C] [|- B] [|- CB] [|- R] =
/ total d2 (add_rev_assoc _ _ _ _ _ _ d2) /
mlam A => mlam C => mlam B => mlam CB => mlam R =>
fn d1 => fn d2 =>
case [|- A] of
| [|- z] =>
  (case d2 of
   | [|- add-z] =>
     let AddZeroRightW [|- Daz] = add_zero_right [|- C] in
     RevAssocW [|- C] [|- Daz] [|- d1])
| [|- s A'] =>
  (case d2 of
   | [|- add-s D2'] =>
     let RevAssocW [|- AC'] [|- Dac'] [|- Dacb'] =
       add_rev_assoc [|- A'] [|- C] [|- B] [|- CB] [|- _] [|- d1] [|- D2']
     in
     RevAssocW [|- s AC'] [|- add-s Dac'] [|- add-s Dacb'])
;

rec leq_refl : {N : [|- nat]} [|- leq N N] =
/ total n (leq_refl n) /
mlam N =>
case [|- N] of
| [|- z] =>
  [|- leq-z]
| [|- s N'] =>
  let [|- D'] = leq_refl [|- N'] in
  [|- leq-s D']
;

rec leq_step : {A : [|- nat]} {B : [|- nat]} [|- leq A B] -> [|- leq A (s B)] =
/ total d (leq_step _ _ d) /
mlam A => mlam B =>
fn d =>
case d of
| [|- leq-z] =>
  [|- leq-z]
| [|- leq-s D'] =>
  let [|- D''] = leq_step [|- _] [|- _] [|- D'] in
  [|- leq-s D'']
;

rec leq_add : {A : [|- nat]} {B : [|- nat]} {C : [|- nat]}
              [|- add A B C] -> LeqAddW [|- A] [|- B] [|- C] =
/ total d (leq_add _ _ _ d) /
mlam A => mlam B => mlam C =>
fn d =>
case d of
| [|- add-z] =>
  LeqAddW [|- leq_refl [|- B]]
| [|- add-s D'] =>
  let LeqAddW [|- Dl] = leq_add [|- _] [|- B] [|- _] [|- D'] in
  LeqAddW [|- leq_step [|- B] [|- _] [|- Dl]]
;

rec leq_trans : {A : [|- nat]} {B : [|- nat]} {C : [|- nat]}
                [|- leq A B] -> [|- leq B C] -> [|- leq A C] =
/ total d1 (leq_trans _ _ _ d1 _) /
mlam A => mlam B => mlam C =>
fn d1 => fn d2 =>
case d1 of
| [|- leq-z] =>
  [|- leq-z]
| [|- leq-s D1'] =>
  (case d2 of
   | [|- leq-s D2'] =>
     let [|- D'] = leq_trans [|- _] [|- _] [|- _] [|- D1'] [|- D2'] in
     [|- leq-s D'])
;

rec lt_leq_trans : {A : [|- nat]} {B : [|- nat]} {C : [|- nat]}
                   [|- lt A B] -> [|- leq B C] -> [|- lt A C] =
/ total d1 (lt_leq_trans _ _ _ d1 _) /
mlam A => mlam B => mlam C =>
fn d1 => fn d2 =>
case d1 of
| [|- lt-z] =>
  (case d2 of
   | [|- leq-s D'] =>
     [|- lt-z])
| [|- lt-s D1'] =>
  (case d2 of
   | [|- leq-s D2'] =>
     let [|- D'] = lt_leq_trans [|- _] [|- _] [|- _] [|- D1'] [|- D2'] in
     [|- lt-s D'])
;

rec leq_to_lt_succ : {A : [|- nat]} {B : [|- nat]} [|- leq A B] -> [|- lt A (s B)] =
/ total d (leq_to_lt_succ _ _ d) /
mlam A => mlam B =>
fn d =>
case d of
| [|- leq-z] =>
  [|- lt-z]
| [|- leq-s D'] =>
  let [|- D''] = leq_to_lt_succ [|- _] [|- _] [|- D'] in
  [|- lt-s D'']
;

rec lt_trans : {A : [|- nat]} {B : [|- nat]} {C : [|- nat]}
               [|- lt A B] -> [|- lt B C] -> [|- lt A C] =
/ total d1 (lt_trans _ _ _ d1 _) /
mlam A => mlam B => mlam C =>
fn d1 => fn d2 =>
case d1 of
| [|- lt-z] =>
  (case d2 of
   | [|- lt-s D2'] =>
     [|- lt-z])
| [|- lt-s D1'] =>
  (case d2 of
   | [|- lt-s D2'] =>
     let [|- D'] = lt_trans [|- _] [|- _] [|- _] [|- D1'] [|- D2'] in
     [|- lt-s D'])
;

rec lt_to_leq : {A : [|- nat]} {B : [|- nat]} [|- lt A B] -> [|- leq A B] =
/ total d (lt_to_leq _ _ d) /
mlam A => mlam B =>
fn d =>
case d of
| [|- lt-z] =>
  [|- leq-z]
| [|- lt-s D'] =>
  let [|- D''] = lt_to_leq [|- _] [|- _] [|- D'] in
  [|- leq-s D'']
;

rec leq_antisym : {A : [|- nat]} {B : [|- nat]}
                  [|- leq A B] -> [|- leq B A] -> [|- eq-nat A B] =
/ total d1 (leq_antisym _ _ d1 _) /
mlam A => mlam B =>
fn d1 => fn d2 =>
case d1 of
| [|- leq-z] =>
  (case d2 of
   | [|- leq-z] => [|- eq-nat-refl])
| [|- leq-s D1'] =>
  (case d2 of
   | [|- leq-s D2'] =>
     let [|- eq-nat-refl] = leq_antisym [|- _] [|- _] [|- D1'] [|- D2'] in
     [|- eq-nat-refl])
;

rec mul_total : {M : [|- nat]} {N : [|- nat]} MulW [|- M] [|- N] =
/ total m (mul_total m _) /
mlam M => mlam N =>
case [|- M] of
| [|- z] =>
  MulW [|- z] [|- mul-z]
| [|- s M'] =>
  let MulW [|- P'] [|- Dm'] = mul_total [|- M'] [|- N] in
  let AddW [|- Q'] [|- Da'] = add_total [|- P'] [|- N] in
  MulW [|- Q'] [|- mul-s Dm' Da']
;

rec mul_unique : {M : [|- nat]} {N : [|- nat]} {P : [|- nat]} {Q : [|- nat]}
                 [|- mul M N P] -> [|- mul M N Q] -> MulUniqueW [|- M] [|- N] [|- P] [|- Q] =
/ total d1 (mul_unique _ _ _ _ d1 _) /
mlam M => mlam N => mlam P => mlam Q =>
fn d1 => fn d2 =>
case d1 of
| [|- mul-z] =>
  (case d2 of
   | [|- mul-z] => MulUniqueW [|- eq-nat-refl])
| [|- mul-s Dm1 Da1] =>
  (case d2 of
   | [|- mul-s Dm2 Da2] =>
     let MulUniqueW [|- eq-nat-refl] = mul_unique [|- _] [|- N] [|- _] [|- _] [|- Dm1] [|- Dm2] in
     let AddUniqueW [|- eq-nat-refl] = add_unique [|- _] [|- N] [|- P] [|- Q] [|- Da1] [|- Da2] in
     MulUniqueW [|- eq-nat-refl])
;

rec add_right_preserves_lt : {A : [|- nat]} {B : [|- nat]} {C : [|- nat]} {AC : [|- nat]} {BC : [|- nat]}
                              [|- lt A B] -> [|- add A C AC] -> [|- add B C BC] -> [|- lt AC BC] =
/ total d (add_right_preserves_lt _ _ _ _ _ d _ _) /
mlam A => mlam B => mlam C => mlam AC => mlam BC =>
fn dlt => fn dac => fn dbc =>
case dlt of
| [|- lt-z] =>
  (case dac of
   | [|- add-z] =>
     let LeqAddW [|- Dlq] = leq_add [|- _] [|- C] [|- _] [|- dbc] in
     leq_to_lt_succ [|- C] [|- _] [|- Dlq])
| [|- lt-s Dlt'] =>
  (case dac of
   | [|- add-s Dac'] =>
     (case dbc of
      | [|- add-s Dbc'] =>
        let [|- D'] =
          add_right_preserves_lt [|- _] [|- _] [|- C] [|- _] [|- _] [|- Dlt'] [|- Dac'] [|- Dbc']
        in
        [|- lt-s D']))
;

rec add_left_preserves_lt : {A : [|- nat]} {B : [|- nat]} {C : [|- nat]} {CA : [|- nat]} {CB : [|- nat]}
                             [|- lt A B] -> [|- add C A CA] -> [|- add C B CB] -> [|- lt CA CB] =
/ total d (add_left_preserves_lt _ _ _ _ _ d _ _) /
mlam A => mlam B => mlam C => mlam CA => mlam CB =>
fn dlt => fn dca => fn dcb =>
let AddCommW [|- Dac] = add_comm [|- C] [|- A] [|- CA] [|- dca] in
let AddCommW [|- Dbc] = add_comm [|- C] [|- B] [|- CB] [|- dcb] in
add_right_preserves_lt [|- A] [|- B] [|- C] [|- CA] [|- CB] [|- dlt] [|- Dac] [|- Dbc]
;

rec add_mono_right : {A : [|- nat]} {B : [|- nat]} {C : [|- nat]} {AC : [|- nat]} {BC : [|- nat]}
                     [|- leq A B] -> [|- add A C AC] -> [|- add B C BC] -> [|- leq AC BC] =
/ total d (add_mono_right _ _ _ _ _ d _ _) /
mlam A => mlam B => mlam C => mlam AC => mlam BC =>
fn dleq => fn dac => fn dbc =>
case dleq of
| [|- leq-z] =>
  (case dac of
   | [|- add-z] =>
     let LeqAddW [|- Dlq] = leq_add [|- _] [|- C] [|- BC] [|- dbc] in
     Dlq)
| [|- leq-s Dleq'] =>
  (case dac of
   | [|- add-s Dac'] =>
     (case dbc of
      | [|- add-s Dbc'] =>
        let [|- D'] = add_mono_right [|- _] [|- _] [|- C] [|- _] [|- _] [|- Dleq'] [|- Dac'] [|- Dbc'] in
        [|- leq-s D']))
;

rec index_bound : {B : [|- nat]} {D : [|- nat]} {Rows : [|- nat]} {Cols : [|- nat]}
                  [|- lt B Rows] ->
                  [|- lt D Cols] ->
                  [|- mul Rows Cols Total] ->
                  [|- mul B Cols PB] ->
                  [|- add PB D Idx] ->
                  [|- lt Idx Total] =
/ total dlt_b (index_bound _ _ _ _ dlt_b _ _ _ _) /
mlam B => mlam D => mlam Rows => mlam Cols =>
fn dlt_b => fn dlt_d => fn dmul_r => fn dmul_b => fn dadd =>
case dlt_b of
| [|- lt-z] =>
  (case dmul_b of
   | [|- mul-z] =>
     (case dadd of
      | [|- add-z] =>
        (case dmul_r of
         | [|- mul-s Dmr' Dar] =>
           let LeqAddW [|- Dlq] = leq_add [|- _] [|- Cols] [|- _] [|- Dar] in
           lt_leq_trans [|- D] [|- Cols] [|- _] [|- dlt_d] [|- Dlq])))
| [|- lt-s Dlt'] =>
  (case dmul_b of
   | [|- mul-s Dmb' Dab] =>
     (case dmul_r of
      | [|- mul-s Dmr' Dar] =>
        let AddAssocW [|- CD] [|- Dcd] [|- Dpbcd] =
          add_assoc [|- _] [|- Cols] [|- D] [|- _] [|- _] [|- Dab] [|- dadd]
        in
        let AddCommW [|- Ddc] = add_comm [|- Cols] [|- D] [|- CD] [|- Dcd] in
        let RevAssocW [|- Idx'] [|- Dpbd] [|- Didxc] =
          add_rev_assoc [|- _] [|- D] [|- Cols] [|- CD] [|- _] [|- Ddc] [|- Dpbcd]
        in
        let [|- LtIdx'PR'] =
          index_bound [|- _] [|- D] [|- _] [|- Cols]
                      [|- Dlt'] [|- dlt_d] [|- Dmr'] [|- Dmb'] [|- Dpbd]
        in
        add_right_preserves_lt [|- Idx'] [|- _] [|- Cols] [|- _] [|- _]
                                [|- LtIdx'PR'] [|- Didxc] [|- Dar]))
;

rec no_transition_from_freed : {S : [|- reg-state]}
                                [|- transition reg-freed S] -> [|- eq-nat z (s z)] =
/ total d (no_transition_from_freed _ d) /
mlam S => fn d =>
case d of
;

rec freed_not_acquirable : [|- is-acquirable reg-freed] -> [|- eq-nat z (s z)] =
/ total d (freed_not_acquirable d) /
fn d =>
case d of
;

rec destroyed_not_acquirable : {N : [|- nat]}
                                [|- is-acquirable (reg-alive N btrue)] -> [|- eq-nat z (s z)] =
/ total d (destroyed_not_acquirable _ d) /
mlam N => fn d =>
case d of
;

rec acquire_requires_live : {N : [|- nat]} {B : [|- bool]} {S : [|- reg-state]}
                             [|- is-acquirable (reg-alive N B)] ->
                             [|- transition (reg-alive N B) S] ->
                             [|- is-core-valid S] =
/ total d (acquire_requires_live _ _ _ _ d) /
mlam N => mlam B => mlam S =>
fn dacq => fn dtr =>
case dacq of
| [|- acquirable-alive] =>
  (case dtr of
   | [|- tr-acquire]      => [|- cv-alive-false]
   | [|- tr-release-live] => [|- cv-alive-false]
   | [|- tr-destroy-live] => [|- cv-alive-true])
;

rec no_acquire_after_destroy : {N : [|- nat]} {S : [|- reg-state]}
                                [|- transition (reg-alive N btrue) S] ->
                                [|- is-acquirable S] ->
                                [|- eq-nat z (s z)] =
/ total d (no_acquire_after_destroy _ _ d _) /
mlam N => mlam S =>
fn dtr => fn dacq =>
case dtr of
| [|- tr-release-dying] =>
  (case dacq of)
| [|- tr-release-final] =>
  (case dacq of)
| [|- tr-destroy-live] =>
  (case dacq of)
;

rec eventual_cleanup : {N : [|- nat]} EventualCleanupW [|- N] =
/ total n (eventual_cleanup n) /
mlam N =>
case [|- N] of
| [|- z] =>
  EventualCleanupW [|- reach-step tr-destroy-zero reach-refl]
| [|- s z] =>
  EventualCleanupW [|- reach-step tr-release-final reach-refl]
| [|- s (s N')] =>
  let EventualCleanupW [|- DR] = eventual_cleanup [|- s N'] in
  EventualCleanupW [|- reach-step tr-release-dying DR]
;

rec freed_is_terminal : {S : [|- reg-state]}
                        [|- reachable reg-freed S] -> [|- eq-nat z z] =
/ total d (freed_is_terminal _ d) /
mlam S =>
fn d =>
case d of
| [|- reach-refl] =>
  [|- eq-nat-refl]
| [|- reach-step Dtr Dr] =>
  let [|- Contra] = no_transition_from_freed [|- _] [|- Dtr] in
  impossible [|- Contra]
;

rec no_use_after_free : {S : [|- reg-state]}
                        [|- reachable reg-freed S] ->
                        [|- is-acquirable S] ->
                        [|- eq-nat z (s z)] =
/ total d (no_use_after_free _ d _) /
mlam S =>
fn dreachable => fn dacq =>
case dreachable of
| [|- reach-refl] =>
  freed_not_acquirable dacq
| [|- reach-step Dtr Dr] =>
  let [|- Contra] = no_transition_from_freed [|- _] [|- Dtr] in
  impossible [|- Contra]
;

rec destroyed_stays_not_acquirable : {N : [|- nat]} {S : [|- reg-state]}
                                     [|- transition (reg-alive N btrue) S] ->
                                     [|- is-acquirable S] ->
                                     [|- eq-nat z (s z)] =
/ total d (destroyed_stays_not_acquirable _ _ d _) /
mlam N => mlam S =>
fn dtr => fn dacq =>
case dtr of
| [|- tr-release-dying] => (case dacq of)
| [|- tr-release-final] => (case dacq of)
| [|- tr-destroy-live]  => (case dacq of)
;

rec acquire_increments : {N : [|- nat]}
                         [|- is-acquirable (reg-alive N bfalse)] ->
                         [|- transition (reg-alive N bfalse) (reg-alive (s N) bfalse)] =
/ total d (acquire_increments _ d) /
mlam N =>
fn d =>
case d of
| [|- acquirable-alive] => [|- tr-acquire]
;

rec release_decrements_live : {N : [|- nat]}
                              [|- is-core-valid (reg-alive (s N) bfalse)] ->
                              [|- transition (reg-alive (s N) bfalse) (reg-alive N bfalse)] =
/ total d (release_decrements_live _ d) /
mlam N =>
fn d =>
case d of
| [|- cv-alive-false] => [|- tr-release-live]
;

rec destroy_marks : {N : [|- nat]}
                    [|- is-core-valid (reg-alive (s N) bfalse)] ->
                    [|- transition (reg-alive (s N) bfalse) (reg-alive (s N) btrue)] =
/ total d (destroy_marks _ d) /
mlam N =>
fn d =>
case d of
| [|- cv-alive-false] => [|- tr-destroy-live]
;

rec destroy_zero_frees : [|- is-acquirable (reg-alive z bfalse)] ->
                         [|- transition (reg-alive z bfalse) reg-freed] =
/ total d (destroy_zero_frees d) /
fn d =>
case d of
| [|- acquirable-alive] => [|- tr-destroy-zero]
;

rec acquire_release_balance : {N : [|- nat]} AcquireReleaseBalanceW [|- N] =
/ total n (acquire_release_balance n) /
mlam N =>
AcquireReleaseBalanceW
  [|- tr-acquire]
  [|- tr-release-live]
;

rec registry_coherent : {N : [|- nat]}
                         [|- is-acquirable (reg-alive N bfalse)] ->
                         [|- is-core-valid (reg-alive N bfalse)] =
/ total d (registry_coherent _ d) /
mlam N =>
fn d =>
case d of
| [|- acquirable-alive] => [|- cv-alive-false]
;

rec registry_no_use_after_free : RegistryNoUseAfterFreeW [|- reg-freed] =
/ total (registry_no_use_after_free) /
RegistryNoUseAfterFreeW
  (mlam T => fn dr => fn dacq =>
   no_use_after_free [|- T] dr dacq)
;

rec registry_no_double_acquire_after_destroy : {N : [|- nat]}
    RegistryNoDoubleAcquireAfterDestroyW [|- N] =
/ total n (registry_no_double_acquire_after_destroy n) /
mlam N =>
RegistryNoDoubleAcquireAfterDestroyW
  (mlam S => fn dtr => fn dacq =>
   no_acquire_after_destroy [|- N] [|- S] dtr dacq)
;

rec registry_eventual_free : {N : [|- nat]} RegistryEventualFreeW [|- N] =
/ total n (registry_eventual_free n) /
mlam N =>
let EventualCleanupW [|- DR] = eventual_cleanup [|- N] in
RegistryEventualFreeW [|- DR]
;

rec registry_freed_terminal : RegistryFreedTerminalW =
/ total (registry_freed_terminal) /
RegistryFreedTerminalW
  (mlam S => fn dr => freed_is_terminal [|- S] dr)
;

rec tensor_valid_from_mul : {R : [|- nat]} {C : [|- nat]} {Total : [|- nat]}
                             [|- mul R C Total] -> [|- tensor-valid R C Total] =
/ total d (tensor_valid_from_mul _ _ _ d) /
mlam R => mlam C => mlam Total =>
fn d => [|- tv-intro d]
;

rec index_safe_2d : {B : [|- nat]} {D : [|- nat]} {Rows : [|- nat]} {Cols : [|- nat]} {Total : [|- nat]} {PB : [|- nat]} {Idx : [|- nat]}
                    [|- tensor-valid Rows Cols Total] ->
                    [|- lt B Rows] ->
                    [|- lt D Cols] ->
                    [|- mul B Cols PB] ->
                    [|- add PB D Idx] ->
                    [|- lt Idx Total] =
/ total d (index_safe_2d _ _ _ _ _ _ _ d _ _ _ _) /
mlam B => mlam D => mlam Rows => mlam Cols => mlam Total => mlam PB => mlam Idx =>
fn dtv => fn dltb => fn dltd => fn dmulb => fn dadd =>
case dtv of
| [|- tv-intro Dmr] =>
  index_bound [|- B] [|- D] [|- Rows] [|- Cols]
              [|- dltb] [|- dltd] [|- Dmr] [|- dmulb] [|- dadd]
;

rec construct_iib : {B : [|- nat]} {D : [|- nat]} {Rows : [|- nat]} {Cols : [|- nat]} {Total : [|- nat]} {PB : [|- nat]} {Idx : [|- nat]}
                    [|- lt B Rows] ->
                    [|- lt D Cols] ->
                    [|- mul Rows Cols Total] ->
                    [|- mul B Cols PB] ->
                    [|- add PB D Idx] ->
                    [|- index-in-bounds B D Rows Cols Total Idx] =
/ total dltb (construct_iib _ _ _ _ _ _ _ dltb _ _ _ _) /
mlam B => mlam D => mlam Rows => mlam Cols => mlam Total => mlam PB => mlam Idx =>
fn dltb => fn dltd => fn dmr => fn dmb => fn dadd =>
let [|- DltIdx] =
  index_bound [|- B] [|- D] [|- Rows] [|- Cols]
              [|- dltb] [|- dltd] [|- dmr] [|- dmb] [|- dadd]
in
[|- iib-intro dltb dltd dmr dmb dadd DltIdx]
;

rec valid_index_lt_total : {B : [|- nat]} {D : [|- nat]} {Rows : [|- nat]} {Cols : [|- nat]} {Total : [|- nat]} {PB : [|- nat]} {Idx : [|- nat]}
                            [|- index-in-bounds B D Rows Cols Total Idx] -> [|- lt Idx Total] =
/ total d (valid_index_lt_total _ _ _ _ _ _ _ d) /
mlam B => mlam D => mlam Rows => mlam Cols => mlam Total => mlam PB => mlam Idx =>
fn d =>
case d of
| [|- iib-intro _ _ _ _ _ Dlt] => [|- Dlt]
;

