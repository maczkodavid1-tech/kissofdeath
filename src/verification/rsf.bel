rec complete_shape_preservation_theorem :
    {Batch : [|- nat]} {Dim : [|- nat]} {TwoD : [|- nat]} {Full : [|- nat]} {NumLayers : [|- nat]}
    [|- add Dim Dim TwoD] ->
    [|- mul Batch TwoD Full] ->
    [|- lt z (s NumLayers)] ->
    [|- tensor-valid Batch TwoD Full] ->
    [|- tensor-valid Batch TwoD Full] *
    [|- tensor-valid Batch TwoD Full] *
    [|- tensor-valid Batch TwoD Full] =
/ total d1 (complete_shape_preservation_theorem _ _ _ _ _ d1 _ _ _) /
mlam Batch => mlam Dim => mlam TwoD => mlam Full => mlam NumLayers =>
fn dadd => fn dmul => fn dlt => fn dtv =>
(dtv, dtv, dtv)
;

rec complete_index_safety_theorem :
    {Batch : [|- nat]} {Dim : [|- nat]} {TwoD : [|- nat]} {Full : [|- nat]} {Half : [|- nat]}
    [|- split-valid Batch Dim Full Half] ->
    [|- merge-valid Batch Dim Half Full] ->
    SplitIntoIndexSafetyW [|- Batch] [|- Dim] [|- TwoD] [|- Full] [|- Half] *
    MergeFromIndexSafetyW [|- Batch] [|- Dim] [|- TwoD] [|- Full] [|- Half] =
/ total dsv (complete_index_safety_theorem _ _ _ _ _ dsv _) /
mlam Batch => mlam Dim => mlam TwoD => mlam Full => mlam Half =>
fn dsv => fn dmv =>
(split_into_index_safety [|- Batch] [|- Dim] [|- TwoD] [|- Full] [|- Half] dsv,
 merge_from_index_safety [|- Batch] [|- Dim] [|- TwoD] [|- Full] [|- Half] dmv)
;

rec complete_registry_safety_theorem :
    RegistryNoUseAfterFreeW [|- reg-freed] *
    RegistryFreedTerminalW *
    ({N : [|- nat]} RegistryEventualFreeW [|- N]) =
/ total (complete_registry_safety_theorem) /
(registry_no_use_after_free,
 registry_freed_terminal,
 mlam N => registry_eventual_free [|- N])
;

