rec full_registry_safety_layer :
    ({N : [|- nat]}
     {S : [|- reg-state]}
     [|- transition (reg-alive N btrue) S] ->
     [|- is-acquirable S] ->
     [|- eq-nat z (s z)]) *
    ({S : [|- reg-state]}
     [|- reachable reg-freed S] ->
     [|- is-acquirable S] ->
     [|- eq-nat z (s z)]) *
    ({N : [|- nat]}
     [|- reachable (reg-alive N btrue) reg-freed]) =
/ total (full_registry_safety_layer) /
((mlam N => mlam S => fn dtr => fn dacq =>
  no_acquire_after_destroy [|- N] [|- S] dtr dacq),
 (mlam S => fn dr => fn dacq =>
  no_use_after_free [|- S] dr dacq),
 (mlam N =>
  layer_eventual_free_proof [|- N]))
;

rec full_registry_safety_model :
    ({N : [|- nat]}
     {S : [|- reg-state]}
     [|- transition (reg-alive N btrue) S] ->
     [|- is-acquirable S] ->
     [|- eq-nat z (s z)]) *
    ({S : [|- reg-state]}
     [|- reachable reg-freed S] ->
     [|- is-acquirable S] ->
     [|- eq-nat z (s z)]) *
    ({N : [|- nat]}
     [|- reachable (reg-alive N btrue) reg-freed]) =
/ total (full_registry_safety_model) /
((mlam N => mlam S => fn dtr => fn dacq =>
  no_acquire_after_destroy [|- N] [|- S] dtr dacq),
 (mlam S => fn dr => fn dacq =>
  no_use_after_free [|- S] dr dacq),
 (mlam N =>
  model_eventual_free_proof [|- N]))
;

