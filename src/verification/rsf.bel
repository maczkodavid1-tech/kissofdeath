mlam Dim => mlam DimSq =>
fn dmul =>
(layer_init_shape [|- Dim] [|- DimSq] dmul,
 grad_shape_consistent [|- Dim] [|- DimSq] dmul,
 ensure_gradients_shape [|- Dim] [|- DimSq] dmul,
 zero_gradients_ok [|- Dim] [|- DimSq] dmul,
 rsf_layer_init [|- Dim] [|- DimSq] dmul,
 rsf_layer_deinit [|- Dim])
;

