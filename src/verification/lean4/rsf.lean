  rsfCore : RSFCoreSpec fi
  handleId : Nat

def dotProductAt (fi : FloatInterface) (weightData biasData input : List fi.carrier) (idx dim : Nat) : fi.carrier :=
  let sum := listFoldl (fun acc j =>
    fi.addF acc (fi.mulF (listGetD weightData (idx * dim + j) fi.zeroF)
                         (listGetD input j fi.zeroF)))
    fi.zeroF (List.range dim)
  fi.addF sum (listGetD biasData idx fi.zeroF)

def computeScaleRowSpec (fi : FloatInterface) (lcs : LayerCoreSpec fi) (x2Row : List fi.carrier) : List fi.carrier :=
  listMap (fun i => fi.expF (fi.clipF (dotProductAt fi lcs.sWeight.data lcs.sBias.data x2Row i lcs.dim) lcs.clipMin lcs.clipMax)) (List.range lcs.dim)

def computeTranslationRowSpec (fi : FloatInterface) (lcs : LayerCoreSpec fi) (y1Row : List fi.carrier) : List fi.carrier :=
  listMap (fun i => dotProductAt fi lcs.tWeight.data lcs.tBias.data y1Row i lcs.dim) (List.range lcs.dim)

def forwardRowSpec (fi : FloatInterface) (lcs : LayerCoreSpec fi)
    (x1Row x2Row : List fi.carrier) : List fi.carrier × List fi.carrier :=
  let scale := computeScaleRowSpec fi lcs x2Row
  let y1 := listZipWith fi.mulF x1Row scale
  let trans := computeTranslationRowSpec fi lcs y1
  let y2 := listZipWith fi.addF x2Row trans
  (y1, y2)

def inverseRowSpec (fi : FloatInterface) (lcs : LayerCoreSpec fi)
    (y1Row y2Row : List fi.carrier) : List fi.carrier × List fi.carrier :=
  let trans := computeTranslationRowSpec fi lcs y1Row
  let x2 := listZipWith fi.subF y2Row trans
  let scale := computeScaleRowSpec fi lcs x2
  let x1 := listZipWith fi.divF y1Row scale
  (x1, x2)

theorem forwardRowSpec_det (fi : FloatInterface) (lcs : LayerCoreSpec fi) (x1 x2 : List fi.carrier) :
    forwardRowSpec fi lcs x1 x2 = forwardRowSpec fi lcs x1 x2 := rfl

theorem inverseRowSpec_det (fi : FloatInterface) (lcs : LayerCoreSpec fi) (y1 y2 : List fi.carrier) :
    inverseRowSpec fi lcs y1 y2 = inverseRowSpec fi lcs y1 y2 := rfl

theorem computeScaleRowSpec_det (fi : FloatInterface) (lcs : LayerCoreSpec fi) (x : List fi.carrier) :
    computeScaleRowSpec fi lcs x = computeScaleRowSpec fi lcs x := rfl

theorem computeTranslationRowSpec_det (fi : FloatInterface) (lcs : LayerCoreSpec fi) (x : List fi.carrier) :
    computeTranslationRowSpec fi lcs x = computeTranslationRowSpec fi lcs x := rfl

def x2RecoveryRowSpec (fi : FloatInterface) (tWeightData tBiasData y1Row y2Row : List fi.carrier) (dim : Nat) : List fi.carrier :=
  let trans := listMap (fun i => dotProductAt fi tWeightData tBiasData y1Row i dim) (List.range dim)
  listZipWith fi.subF y2Row trans

def scaleRecompRowSpec (fi : FloatInterface) (sWeightData sBiasData x2Row : List fi.carrier)
    (clipMin clipMax : fi.carrier) (dim : Nat) : List fi.carrier :=
  listMap (fun i => fi.expF (fi.clipF (dotProductAt fi sWeightData sBiasData x2Row i dim) clipMin clipMax)) (List.range dim)

def dy1TotalRowSpec (fi : FloatInterface) (tWeightData dy1Row dy2Row : List fi.carrier) (dim : Nat) : List fi.carrier :=
  listMap (fun i =>
    fi.addF (listGetD dy1Row i fi.zeroF)
      (listFoldl (fun acc j =>
        fi.addF acc (fi.mulF (listGetD tWeightData (j * dim + i) fi.zeroF)
                             (listGetD dy2Row j fi.zeroF)))
        fi.zeroF (List.range dim))
  ) (List.range dim)

def dsRowSpec (fi : FloatInterface) (sWeightData sBiasData x2Row dy1TotalRow y1Row : List fi.carrier)
    (clipMin clipMax : fi.carrier) (dim : Nat) : List fi.carrier :=
  listMap (fun i =>
    let raw := dotProductAt fi sWeightData sBiasData x2Row i dim
    bIte (bOr (fi.ltF raw clipMin) (fi.ltF clipMax raw))
      fi.zeroF
      (fi.mulF (listGetD dy1TotalRow i fi.zeroF) (listGetD y1Row i fi.zeroF))
  ) (List.range dim)

def dx1RowSpec (fi : FloatInterface) (dy1TotalRow scaleRow : List fi.carrier) : List fi.carrier :=
  listZipWith fi.mulF dy1TotalRow scaleRow

def dx2RowSpec (fi : FloatInterface) (sWeightData dy2Row dsRow : List fi.carrier) (dim : Nat) : List fi.carrier :=
  listMap (fun i =>
    fi.addF (listGetD dy2Row i fi.zeroF)
      (listFoldl (fun acc j =>
        fi.addF acc (fi.mulF (listGetD sWeightData (j * dim + i) fi.zeroF)
                             (listGetD dsRow j fi.zeroF)))
        fi.zeroF (List.range dim))
  ) (List.range dim)

theorem x2RecoveryRowSpec_det (fi : FloatInterface) (args : List fi.carrier) :
    x2RecoveryRowSpec = x2RecoveryRowSpec := rfl

theorem dy1TotalRowSpec_det (fi : FloatInterface) (args : List fi.carrier) :
    dy1TotalRowSpec = dy1TotalRowSpec := rfl

theorem dx1RowSpec_det (fi : FloatInterface) (args : List fi.carrier) :
    dx1RowSpec = dx1RowSpec := rfl

def gradScaleSpec (fi : FloatInterface) (gradMean : Bool) (batchSize : Nat) : fi.carrier :=
  bIte gradMean (fi.divF fi.oneF (fi.fromNat batchSize)) fi.oneF

def sWeightGradUpdateRowSpec (fi : FloatInterface) (grad dsRow x2Row : List fi.carrier) (gscale : fi.carrier) (dim : Nat) : List fi.carrier :=
  listMap (fun idx =>
    fi.addF (listGetD grad idx fi.zeroF)
      (fi.mulF gscale (fi.mulF (listGetD dsRow (idx / dim) fi.zeroF) (listGetD x2Row (idx % dim) fi.zeroF)))
  ) (List.range (dim * dim))

def tWeightGradUpdateRowSpec (fi : FloatInterface) (grad dy2Row y1Row : List fi.carrier) (gscale : fi.carrier) (dim : Nat) : List fi.carrier :=
  listMap (fun idx =>
    fi.addF (listGetD grad idx fi.zeroF)
      (fi.mulF gscale (fi.mulF (listGetD dy2Row (idx / dim) fi.zeroF) (listGetD y1Row (idx % dim) fi.zeroF)))
  ) (List.range (dim * dim))

def sBiasGradUpdateRowSpec (fi : FloatInterface) (grad dsRow : List fi.carrier) (gscale : fi.carrier) (dim : Nat) : List fi.carrier :=
  listMap (fun idx => fi.addF (listGetD grad idx fi.zeroF) (fi.mulF gscale (listGetD dsRow idx fi.zeroF))) (List.range dim)

def tBiasGradUpdateRowSpec (fi : FloatInterface) (grad dy2Row : List fi.carrier) (gscale : fi.carrier) (dim : Nat) : List fi.carrier :=
  listMap (fun idx => fi.addF (listGetD grad idx fi.zeroF) (fi.mulF gscale (listGetD dy2Row idx fi.zeroF))) (List.range dim)

