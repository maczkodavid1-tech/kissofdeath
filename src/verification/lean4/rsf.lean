theorem tolCloseF_self (fi : FloatInterface) (a absTol relTol : fi.carrier)
    (hAtol : fi.leF fi.zeroF absTol = Bool.true)
    (hRtol : fi.leF fi.zeroF relTol = Bool.true) :
    tolCloseF fi a a absTol relTol = Bool.true :=
  let diff := fi.absF (fi.subF a a)
