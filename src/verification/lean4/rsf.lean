    (x1 x2 : List fi.carrier) (h : natLtB 64 lcs.dim = Bool.true) :
    listGetD (Prod.fst (forwardRowSpec fi lcs x1 x2)) 64 fi.zeroF =
    fi.mulF (listGetD x1 64 fi.zeroF)
