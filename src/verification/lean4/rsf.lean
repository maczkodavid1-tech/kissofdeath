theorem listLength_map {α β : Type} (f : α → β) (xs : List α) :
    listLength (listMap f xs) = listLength xs :=
  match xs with
  | [] => rfl
  | _ :: t => congrArg (· + 1) (listLength_map f t)

theorem listLength_replicate {α : Type} (n : Nat) (v : α) :
    listLength (listReplicate n v) = n :=
  match n with
  | 0 => rfl
  | n + 1 => congrArg (· + 1) (listLength_replicate n v)

theorem listAppend_nil_r {α : Type} (xs : List α) : listAppend xs [] = xs :=
  match xs with
  | [] => rfl
  | x :: xs => congrArg (x :: ·) (listAppend_nil_r xs)

theorem listMap_compose {α β γ : Type} (f : β → γ) (g : α → β) (xs : List α) :
    listMap f (listMap g xs) = listMap (fun x => f (g x)) xs :=
  match xs with
  | [] => rfl
  | _ :: t => congrArg (f (g _) :: ·) (listMap_compose f g t)

theorem listMap_id {α : Type} (xs : List α) :
    listMap id xs = xs :=
  match xs with
  | [] => rfl
  | h :: t => congrArg (h :: ·) (listMap_id t)

