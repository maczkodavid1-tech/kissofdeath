def rsfCoreForward (fi : FloatInterface) (core : RSFCoreSpec fi)
    (x1 x2 : List fi.carrier) : List fi.carrier × List fi.carrier :=
  listFoldl (fun acc lc => forwardRowSpec fi lc acc.1 acc.2) (x1, x2) core.layers

def rsfCoreInverse (fi : FloatInterface) (core : RSFCoreSpec fi)
    (y1 y2 : List fi.carrier) : List fi.carrier × List fi.carrier :=
  listFoldl (fun acc lc => inverseRowSpec fi lc acc.1 acc.2) (y1, y2) (listReverse core.layers)

theorem rsfCoreForward_det (fi : FloatInterface) (core : RSFCoreSpec fi) (x1 x2 : List fi.carrier) :
    rsfCoreForward fi core x1 x2 = rsfCoreForward fi core x1 x2 := rfl

theorem rsfCoreInverse_det (fi : FloatInterface) (core : RSFCoreSpec fi) (y1 y2 : List fi.carrier) :
    rsfCoreInverse fi core y1 y2 = rsfCoreInverse fi core y1 y2 := rfl

theorem disableGPU_forward (fi : FloatInterface) (core : RSFCoreSpec fi) (x1 x2 : List fi.carrier) :
    rsfCoreForward fi (disableGPUSpec fi core) x1 x2 = rsfCoreForward fi core x1 x2 := rfl

theorem disableGPU_inverse (fi : FloatInterface) (core : RSFCoreSpec fi) (y1 y2 : List fi.carrier) :
    rsfCoreInverse fi (disableGPUSpec fi core) y1 y2 = rsfCoreInverse fi core y1 y2 := rfl

theorem notify_forward (fi : FloatInterface) (core : RSFCoreSpec fi) (x1 x2 : List fi.carrier) :
    rsfCoreForward fi (notifyWeightsChangedSpec fi core) x1 x2 = rsfCoreForward fi core x1 x2 := rfl

theorem notify_inverse (fi : FloatInterface) (core : RSFCoreSpec fi) (y1 y2 : List fi.carrier) :
    rsfCoreInverse fi (notifyWeightsChangedSpec fi core) y1 y2 = rsfCoreInverse fi core y1 y2 := rfl

