theorem rowForward_element_x1 (fi : FloatInterface) (lcs : LayerCoreSpec fi)
    (x1Row x2Row : List fi.carrier) (d : Nat) :
    listGetD (Prod.fst (forwardRowSpec fi lcs x1Row x2Row)) d fi.zeroF =
    listGetD (listZipWith fi.mulF x1Row (computeScaleRowSpec fi lcs x2Row)) d fi.zeroF := Eq.refl _

theorem rowForward_element_x2 (fi : FloatInterface) (lcs : LayerCoreSpec fi)
    (x1Row x2Row : List fi.carrier) (d : Nat) :
    listGetD (Prod.snd (forwardRowSpec fi lcs x1Row x2Row)) d fi.zeroF =
    listGetD (listZipWith fi.addF x2Row
