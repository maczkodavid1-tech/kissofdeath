set_option linter.unusedVariables false

namespace RSFLean

inductive ZigError : Type where
  | overflow : ZigError
  | tooLarge : ZigError
  | nonFinite : ZigError
  | invalidConfig : ZigError
  | invalidTolerance : ZigError
  | shapeMismatch : ZigError
  | dataLengthMismatch : ZigError
  | invalidDimension : ZigError
  | invalidLayerCount : ZigError
  | invalidBatchSize : ZigError
  | aliasedBuffers : ZigError
  | notInitialized : ZigError
  | handleCopied : ZigError
  | invalidModelState : ZigError
  | numericFailure : ZigError
  | gpuUnsupportedConfiguration : ZigError
  | noGPUAvailable : ZigError
  | badFileFormat : ZigError
  | unsupportedVersion : ZigError
  | checksumMismatch : ZigError
  | trailingData : ZigError
  | tempFileCollision : ZigError
  | pathAlreadyExists : ZigError
  | allocationFailure : ZigError
  | ioError : ZigError

inductive ResultT (α : Type) : Type where
  | ok : α → ResultT α
  | err : ZigError → ResultT α

def ResultT.bind {α β : Type} (r : ResultT α) (f : α → ResultT β) : ResultT β :=
  match r with
  | .ok a => f a
  | .err e => .err e

def ResultT.map {α β : Type} (f : α → β) (r : ResultT α) : ResultT β :=
  match r with
  | .ok a => .ok (f a)
  | .err e => .err e

def ResultT.pure {α : Type} (a : α) : ResultT α := ResultT.ok a

def ResultT.isOk {α : Type} : ResultT α → Bool
  | .ok _ => true
  | .err _ => false

def ResultT.isErr {α : Type} : ResultT α → Bool
  | .ok _ => false
  | .err _ => true

theorem ResultT.bind_ok {α β : Type} (a : α) (f : α → ResultT β) :
    ResultT.bind (ResultT.ok a) f = f a := rfl

theorem ResultT.bind_err {α β : Type} (e : ZigError) (f : α → ResultT β) :
    ResultT.bind (ResultT.err e) f = ResultT.err e := rfl

theorem ResultT.map_ok {α β : Type} (a : α) (f : α → β) :
    ResultT.map f (ResultT.ok a) = ResultT.ok (f a) := rfl

theorem ResultT.map_err {α β : Type} (e : ZigError) (f : α → β) :
    ResultT.map f (@ResultT.err α e) = ResultT.err e := rfl

theorem ResultT.bind_assoc {α β γ : Type} (r : ResultT α) (f : α → ResultT β) (g : β → ResultT γ) :
    ResultT.bind (ResultT.bind r f) g = ResultT.bind r (fun a => ResultT.bind (f a) g) :=
  match r with
  | .ok a => rfl
  | .err e => rfl

theorem ResultT.ok_ne_err {α : Type} (a : α) (e : ZigError) :
    ResultT.ok a ≠ ResultT.err e :=
  fun (h : ResultT.ok a = ResultT.err e) => ResultT.noConfusion h

theorem ResultT.err_ne_ok {α : Type} (e : ZigError) (a : α) :
    ResultT.err e ≠ ResultT.ok a :=
  fun (h : ResultT.err e = ResultT.ok a) => ResultT.noConfusion h

theorem ResultT.err_injective {α : Type} (e1 e2 : ZigError) (h : @ResultT.err α e1 = @ResultT.err α e2) : e1 = e2 :=
  ResultT.noConfusion h fun h => h

theorem ResultT.ok_injective {α : Type} (a1 a2 : α) (h : ResultT.ok a1 = ResultT.ok a2) : a1 = a2 :=
  ResultT.noConfusion h fun h => h

theorem ResultT.isOk_ok {α : Type} (a : α) : ResultT.isOk (ResultT.ok a) = true := rfl
theorem ResultT.isOk_err {α : Type} (e : ZigError) : ResultT.isOk (@ResultT.err α e) = false := rfl
theorem ResultT.isErr_ok {α : Type} (a : α) : ResultT.isErr (ResultT.ok a) = false := rfl
theorem ResultT.isErr_err {α : Type} (e : ZigError) : ResultT.isErr (@ResultT.err α e) = true := rfl

theorem ResultT.map_id {α : Type} (r : ResultT α) :
    ResultT.map id r = r :=
  match r with | .ok _ => rfl | .err _ => rfl

theorem ResultT.map_compose {α β γ : Type} (f : β → γ) (g : α → β) (r : ResultT α) :
    ResultT.map f (ResultT.map g r) = ResultT.map (fun x => f (g x)) r :=
  match r with | .ok _ => rfl | .err _ => rfl

theorem ResultT.bind_map_equiv {α β : Type} (r : ResultT α) (f : α → β) :
    ResultT.map f r = ResultT.bind r (fun a => ResultT.ok (f a)) :=
  match r with | .ok _ => rfl | .err _ => rfl

