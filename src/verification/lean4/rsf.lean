structure FloatInterface where
  carrier : Type
  zeroF : carrier
  oneF : carrier
  addF : carrier → carrier → carrier
  subF : carrier → carrier → carrier
  mulF : carrier → carrier → carrier
  divF : carrier → carrier → carrier
  negF : carrier → carrier
  expF : carrier → carrier
  logF : carrier → carrier
  sqrtF : carrier → carrier
  absF : carrier → carrier
  fromNat : Nat → carrier
  clipF : carrier → carrier → carrier → carrier
  isFiniteF : carrier → Bool
  eqF : carrier → carrier → Bool
  ltF : carrier → carrier → Bool
  leF : carrier → carrier → Bool
  fromBitsU32 : Nat → carrier
  addF_comm : ∀ a b, addF a b = addF b a
  mulF_comm : ∀ a b, mulF a b = mulF b a
  addF_assoc : ∀ a b c, addF (addF a b) c = addF a (addF b c)
  mulF_assoc : ∀ a b c, mulF (mulF a b) c = mulF a (mulF b c)
  addF_zero : ∀ a, addF a zeroF = a
  mulF_one : ∀ a, mulF a oneF = a
  mulF_zero : ∀ a, mulF a zeroF = zeroF
  subF_self : ∀ a, subF a a = zeroF
  expF_logF : ∀ a, expF (logF a) = a
  mulF_divF : ∀ a b, mulF (divF a b) b = a
  clipF_inside : ∀ v lo hi, leF lo v = true → leF v hi = true → clipF v lo hi = v
  clipF_low : ∀ v lo hi, ltF v lo = true → clipF v lo hi = lo
  clipF_high : ∀ v lo hi, ltF hi v = true → clipF v lo hi = hi
  expF_pos : ∀ v, ltF zeroF (expF v) = true
  addF_subF : ∀ a b, subF (addF a b) b = a
  divF_mulF : ∀ a b, divF (mulF a b) b = a
  negF_negF : ∀ a, negF (negF a) = a
  addF_negF : ∀ a, addF a (negF a) = zeroF

theorem fi_addF_comm (fi : FloatInterface) (a b : fi.carrier) : fi.addF a b = fi.addF b a := fi.addF_comm a b
theorem fi_mulF_comm (fi : FloatInterface) (a b : fi.carrier) : fi.mulF a b = fi.mulF b a := fi.mulF_comm a b
theorem fi_addF_assoc (fi : FloatInterface) (a b c : fi.carrier) : fi.addF (fi.addF a b) c = fi.addF a (fi.addF b c) := fi.addF_assoc a b c
theorem fi_mulF_assoc (fi : FloatInterface) (a b c : fi.carrier) : fi.mulF (fi.mulF a b) c = fi.mulF a (fi.mulF b c) := fi.mulF_assoc a b c
theorem fi_addF_zero (fi : FloatInterface) (a : fi.carrier) : fi.addF a fi.zeroF = a := fi.addF_zero a
theorem fi_mulF_one (fi : FloatInterface) (a : fi.carrier) : fi.mulF a fi.oneF = a := fi.mulF_one a
theorem fi_mulF_zero (fi : FloatInterface) (a : fi.carrier) : fi.mulF a fi.zeroF = fi.zeroF := fi.mulF_zero a
theorem fi_subF_self (fi : FloatInterface) (a : fi.carrier) : fi.subF a a = fi.zeroF := fi.subF_self a
theorem fi_expF_logF (fi : FloatInterface) (a : fi.carrier) : fi.expF (fi.logF a) = a := fi.expF_logF a
theorem fi_mulF_divF (fi : FloatInterface) (a b : fi.carrier) : fi.mulF (fi.divF a b) b = a := fi.mulF_divF a b
theorem fi_addF_subF (fi : FloatInterface) (a b : fi.carrier) : fi.subF (fi.addF a b) b = a := fi.addF_subF a b
theorem fi_divF_mulF (fi : FloatInterface) (a b : fi.carrier) : fi.divF (fi.mulF a b) b = a := fi.divF_mulF a b
theorem fi_negF_negF (fi : FloatInterface) (a : fi.carrier) : fi.negF (fi.negF a) = a := fi.negF_negF a
theorem fi_addF_negF (fi : FloatInterface) (a : fi.carrier) : fi.addF a (fi.negF a) = fi.zeroF := fi.addF_negF a

theorem fi_mulF_comm_assoc (fi : FloatInterface) (a b c : fi.carrier) :
    fi.mulF (fi.mulF a b) c = fi.mulF (fi.mulF b a) c :=
  congrArg (fi.mulF · c) (fi.mulF_comm a b)

theorem fi_addF_comm_assoc (fi : FloatInterface) (a b c : fi.carrier) :
    fi.addF (fi.addF a b) c = fi.addF (fi.addF b a) c :=
  congrArg (fi.addF · c) (fi.addF_comm a b)

theorem fi_zero_addF (fi : FloatInterface) (a : fi.carrier) :
    fi.addF fi.zeroF a = a :=
  Eq.trans (fi.addF_comm fi.zeroF a) (fi.addF_zero a)

theorem fi_one_mulF (fi : FloatInterface) (a : fi.carrier) :
    fi.mulF fi.oneF a = a :=
  Eq.trans (fi.mulF_comm fi.oneF a) (fi.mulF_one a)

theorem fi_zero_mulF (fi : FloatInterface) (a : fi.carrier) :
    fi.mulF fi.zeroF a = fi.zeroF :=
  Eq.trans (fi.mulF_comm fi.zeroF a) (fi.mulF_zero a)

