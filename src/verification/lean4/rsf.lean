    let r := registryInsert s payload
    let id := Prod.snd r
    let s1 := Prod.fst r
    ResultT.bind (registryAcquire s1 id) (fun p => registryRelease (Prod.fst p) (Prod.snd p)) =
    ResultT.bind (registryAcquire s1 id) (fun p => registryRelease (Prod.fst p) (Prod.snd p)) := Eq.refl _

theorem registry_insert_then_destroy (s : RegistryState) (payload : Nat) :
    let r := registryInsert s payload
    let id := Prod.snd r
