  fun b => Bool.recOn (motive := fun _ => Bool) b Bool.true Bool.false

noncomputable def bAnd : Bool → Bool → Bool :=
  fun b1 b2 => Bool.recOn (motive := fun _ => Bool) b1 Bool.false b2

noncomputable def bOr : Bool → Bool → Bool :=
  fun b1 b2 => Bool.recOn (motive := fun _ => Bool) b1 b2 Bool.true

noncomputable def bIte {α : Type} (b : Bool) (t f : α) : α :=
  Bool.recOn (motive := fun _ => α) b f t

theorem bNot_true : bNot Bool.true = Bool.false := Eq.refl Bool.false
theorem bNot_false : bNot Bool.false = Bool.true := Eq.refl Bool.true
theorem bAnd_true_l (b : Bool) : bAnd Bool.true b = b := Eq.refl b
theorem bAnd_false_l (b : Bool) : bAnd Bool.false b = Bool.false := Eq.refl Bool.false
theorem bOr_false_l (b : Bool) : bOr Bool.false b = b := Eq.refl b
theorem bOr_true_l (b : Bool) : bOr Bool.true b = Bool.true := Eq.refl Bool.true
theorem bIte_true {α : Type} (t f : α) : bIte Bool.true t f = t := Eq.refl t
theorem bIte_false {α : Type} (t f : α) : bIte Bool.false t f = f := Eq.refl f

theorem bNot_bNot (b : Bool) : bNot (bNot b) = b :=
  Bool.recOn (motive := fun c => bNot (bNot c) = c) b (Eq.refl Bool.false) (Eq.refl Bool.true)

theorem bAnd_true_r (b : Bool) : bAnd b Bool.true = b :=
  Bool.recOn (motive := fun c => bAnd c Bool.true = c) b (Eq.refl Bool.false) (Eq.refl Bool.true)

theorem bAnd_false_r (b : Bool) : bAnd b Bool.false = Bool.false :=
  Bool.recOn (motive := fun c => bAnd c Bool.false = Bool.false) b (Eq.refl Bool.false) (Eq.refl Bool.false)

theorem bOr_false_r (b : Bool) : bOr b Bool.false = b :=
  Bool.recOn (motive := fun c => bOr c Bool.false = c) b (Eq.refl Bool.false) (Eq.refl Bool.true)

theorem bOr_true_r (b : Bool) : bOr b Bool.true = Bool.true :=
  Bool.recOn (motive := fun c => bOr c Bool.true = Bool.true) b (Eq.refl Bool.true) (Eq.refl Bool.true)

theorem bAnd_comm (b1 b2 : Bool) : bAnd b1 b2 = bAnd b2 b1 :=
  Bool.recOn (motive := fun c => bAnd c b2 = bAnd b2 c) b1
    (Bool.recOn (motive := fun c => bAnd Bool.false c = bAnd c Bool.false) b2
      (Eq.refl Bool.false) (Eq.refl Bool.false))
    (Bool.recOn (motive := fun c => bAnd Bool.true c = bAnd c Bool.true) b2
      (Eq.refl Bool.false) (Eq.refl Bool.true))

theorem bOr_comm (b1 b2 : Bool) : bOr b1 b2 = bOr b2 b1 :=
  Bool.recOn (motive := fun c => bOr c b2 = bOr b2 c) b1
    (Bool.recOn (motive := fun c => bOr Bool.false c = bOr c Bool.false) b2
      (Eq.refl Bool.false) (Eq.refl Bool.true))
    (Bool.recOn (motive := fun c => bOr Bool.true c = bOr c Bool.true) b2
      (Eq.refl Bool.true) (Eq.refl Bool.true))

theorem bAnd_assoc (b1 b2 b3 : Bool) : bAnd (bAnd b1 b2) b3 = bAnd b1 (bAnd b2 b3) :=
  Bool.recOn (motive := fun c => bAnd (bAnd c b2) b3 = bAnd c (bAnd b2 b3)) b1
    (Eq.refl Bool.false)
    (Eq.refl (bAnd b2 b3))

theorem bOr_assoc (b1 b2 b3 : Bool) : bOr (bOr b1 b2) b3 = bOr b1 (bOr b2 b3) :=
  Bool.recOn (motive := fun c => bOr (bOr c b2) b3 = bOr c (bOr b2 b3)) b1
    (Eq.refl (bOr b2 b3))
    (Eq.refl Bool.true)

theorem bAnd_self (b : Bool) : bAnd b b = b :=
  Bool.recOn (motive := fun c => bAnd c c = c) b (Eq.refl Bool.false) (Eq.refl Bool.true)

theorem bOr_self (b : Bool) : bOr b b = b :=
  Bool.recOn (motive := fun c => bOr c c = c) b (Eq.refl Bool.false) (Eq.refl Bool.true)

theorem bIte_same {α : Type} (b : Bool) (x : α) : bIte b x x = x :=
  Bool.recOn (motive := fun c => bIte c x x = x) b (Eq.refl x) (Eq.refl x)

theorem bFalseNeTrueHelper : Bool.false = Bool.true → False :=
  fun h => Bool.noConfusion h

theorem bTrueNeFalseHelper : Bool.true = Bool.false → False :=
  fun h => Bool.noConfusion h

theorem bAnd_eq_true_intro (b1 b2 : Bool) (h1 : b1 = Bool.true) (h2 : b2 = Bool.true) :
    bAnd b1 b2 = Bool.true :=
  Eq.trans (congrArg (fun x => bAnd x b2) h1) h2

theorem bOr_eq_true_left (b1 b2 : Bool) (h1 : b1 = Bool.true) :
    bOr b1 b2 = Bool.true :=
  congrArg (fun x => bOr x b2) h1

theorem bOr_eq_true_right (b1 b2 : Bool) (h2 : b2 = Bool.true) :
    bOr b1 b2 = Bool.true :=
  Eq.trans (bOr_comm b1 b2) (congrArg (fun x => bOr x b1) h2)

noncomputable def natEqB : Nat → Nat → Bool :=
  fun m n => Nat.recOn (motive := fun _ => Nat → Bool) m
    (fun n => Nat.recOn (motive := fun _ => Bool) n Bool.true (fun _ _ => Bool.false))
    (fun m' ihm n => Nat.recOn (motive := fun _ => Bool) n Bool.false (fun n' _ => ihm n'))

theorem natEqB_refl (n : Nat) : natEqB n n = Bool.true :=
  Nat.recOn (motive := fun k => natEqB k k = Bool.true) n
    (Eq.refl Bool.true)
    (fun k ih => ih)

theorem natEqB_zero_zero : natEqB 0 0 = Bool.true := Eq.refl Bool.true
theorem natEqB_zero_succ (n : Nat) : natEqB 0 (Nat.succ n) = Bool.false := Eq.refl Bool.false
theorem natEqB_succ_zero (n : Nat) : natEqB (Nat.succ n) 0 = Bool.false := Eq.refl Bool.false
theorem natEqB_succ_succ (m n : Nat) : natEqB (Nat.succ m) (Nat.succ n) = natEqB m n := Eq.refl (natEqB m n)

theorem natEqB_symm (m n : Nat) : natEqB m n = natEqB n m :=
  Nat.recOn (motive := fun k => ∀ j, natEqB k j = natEqB j k) m
    (fun j => Nat.recOn (motive := fun k => natEqB 0 k = natEqB k 0) j
      (Eq.refl Bool.true)
      (fun j' _ => Eq.refl Bool.false))
    (fun m' ihm j => Nat.recOn (motive := fun k => natEqB (Nat.succ m') k = natEqB k (Nat.succ m')) j
      (Eq.refl Bool.false)
      (fun j' _ => ihm j'))
    n

noncomputable def natLeB : Nat → Nat → Bool :=
  fun m n => Nat.recOn (motive := fun _ => Nat → Bool) m
    (fun _ => Bool.true)
    (fun m' ihm n => Nat.recOn (motive := fun _ => Bool) n Bool.false (fun n' _ => ihm n'))

theorem natLeB_zero (n : Nat) : natLeB 0 n = Bool.true := Eq.refl Bool.true
theorem natLeB_succ_zero (m : Nat) : natLeB (Nat.succ m) 0 = Bool.false := Eq.refl Bool.false
theorem natLeB_succ_succ (m n : Nat) : natLeB (Nat.succ m) (Nat.succ n) = natLeB m n := Eq.refl (natLeB m n)
theorem natLeB_refl (n : Nat) : natLeB n n = Bool.true :=
  Nat.recOn (motive := fun k => natLeB k k = Bool.true) n (Eq.refl Bool.true) (fun k ih => ih)

noncomputable def natLtB : Nat → Nat → Bool :=
  fun m n => natLeB (Nat.succ m) n

theorem natLtB_zero_succ (n : Nat) : natLtB 0 (Nat.succ n) = Bool.true := Eq.refl Bool.true
theorem natLtB_zero_zero : natLtB 0 0 = Bool.false := Eq.refl Bool.false
theorem natLtB_succ_succ (m n : Nat) : natLtB (Nat.succ m) (Nat.succ n) = natLtB m n := Eq.refl (natLtB m n)
theorem natLtB_irrefl (n : Nat) : natLtB n n = Bool.false :=
  Nat.recOn (motive := fun k => natLtB k k = Bool.false) n
    (Eq.refl Bool.false)
    (fun k ih => ih)

noncomputable def natSub : Nat → Nat → Nat :=
  fun m n => Nat.recOn (motive := fun _ => Nat → Nat) n m (fun n' ihn k =>
    Nat.recOn (motive := fun _ => Nat) k 0 (fun k' _ => ihn k'))

theorem natSub_zero (n : Nat) : natSub n 0 = n := Eq.refl n
theorem natSub_self (n : Nat) : natSub n n = 0 :=
  Nat.recOn (motive := fun k => natSub k k = 0) n
    (Eq.refl 0)
    (fun k ih => ih)
theorem natSub_succ_succ (m n : Nat) : natSub (Nat.succ m) (Nat.succ n) = natSub m n :=
  Eq.refl (natSub m n)
theorem natSub_zero_left (n : Nat) : natSub 0 n = 0 :=
  Nat.recOn (motive := fun k => natSub 0 k = 0) n
    (Eq.refl 0)
    (fun k _ => Eq.refl 0)

noncomputable def natMin : Nat → Nat → Nat :=
  fun m n => bIte (natLeB m n) m n

noncomputable def natMax : Nat → Nat → Nat :=
  fun m n => bIte (natLeB m n) n m

theorem natMin_self (n : Nat) : natMin n n = n :=
  congrArg (fun b => bIte b n n) (natLeB_refl n)

theorem natMax_self (n : Nat) : natMax n n = n :=
  congrArg (fun b => bIte b n n) (natLeB_refl n)

noncomputable def natMod : Nat → Nat → Nat :=
  fun m n => Nat.recOn (motive := fun _ => Nat) n m (fun _ _ => Nat.mod m (Nat.succ n))

noncomputable def natDiv : Nat → Nat → Nat :=
  fun m n => Nat.recOn (motive := fun _ => Nat) n 0 (fun _ _ => Nat.div m (Nat.succ n))

noncomputable def natXor : Nat → Nat → Nat :=
  fun m n => Nat.xor m n

noncomputable def natAnd : Nat → Nat → Nat :=
  fun m n => Nat.land m n

noncomputable def natOr : Nat → Nat → Nat :=
  fun m n => Nat.lor m n

noncomputable def natShiftR : Nat → Nat → Nat :=
  fun m n => Nat.shiftRight m n

noncomputable def listLength {α : Type} : List α → Nat :=
  fun xs => List.recOn (motive := fun _ => Nat) xs 0 (fun _ _ n => Nat.succ n)

theorem listLength_nil {α : Type} : listLength ([] : List α) = 0 := Eq.refl 0
theorem listLength_cons {α : Type} (h : α) (t : List α) :
    listLength (List.cons h t) = Nat.succ (listLength t) := Eq.refl (Nat.succ (listLength t))

noncomputable def listAppend {α : Type} : List α → List α → List α :=
  fun xs ys => List.recOn (motive := fun _ => List α) xs ys (fun h _ acc => List.cons h acc)

theorem listAppend_nil_left {α : Type} (ys : List α) : listAppend List.nil ys = ys := Eq.refl ys
theorem listAppend_cons {α : Type} (h : α) (t ys : List α) :
    listAppend (List.cons h t) ys = List.cons h (listAppend t ys) := Eq.refl _
theorem listAppend_nil_right {α : Type} (xs : List α) : listAppend xs List.nil = xs :=
  List.recOn (motive := fun l => listAppend l List.nil = l) xs
    (Eq.refl List.nil)
    (fun h t ih => congrArg (List.cons h) ih)
theorem listAppend_assoc {α : Type} (xs ys zs : List α) :
    listAppend (listAppend xs ys) zs = listAppend xs (listAppend ys zs) :=
  List.recOn (motive := fun l => listAppend (listAppend l ys) zs = listAppend l (listAppend ys zs)) xs
    (Eq.refl (listAppend ys zs))
    (fun h t ih => congrArg (List.cons h) ih)

theorem listLength_append {α : Type} (xs ys : List α) :
    listLength (listAppend xs ys) = Nat.add (listLength xs) (listLength ys) :=
  List.recOn (motive := fun l => listLength (listAppend l ys) = Nat.add (listLength l) (listLength ys)) xs
    (Eq.refl (listLength ys))
    (fun h t ih => congrArg Nat.succ ih)

noncomputable def listMap {α β : Type} (f : α → β) : List α → List β :=
  fun xs => List.recOn (motive := fun _ => List β) xs List.nil
    (fun h _ acc => List.cons (f h) acc)

theorem listMap_nil {α β : Type} (f : α → β) : listMap f List.nil = List.nil := Eq.refl _
theorem listMap_cons {α β : Type} (f : α → β) (h : α) (t : List α) :
    listMap f (List.cons h t) = List.cons (f h) (listMap f t) := Eq.refl _
theorem listLength_map {α β : Type} (f : α → β) (xs : List α) :
    listLength (listMap f xs) = listLength xs :=
  List.recOn (motive := fun l => listLength (listMap f l) = listLength l) xs
    (Eq.refl 0)
    (fun h t ih => congrArg Nat.succ ih)

noncomputable def listGetD {α : Type} (xs : List α) (i : Nat) (d : α) : α :=
  Nat.recOn (motive := fun _ => List α → α) i
    (fun l => List.recOn (motive := fun _ => α) l d (fun h _ _ => h))
    (fun _ ihI l => List.recOn (motive := fun _ => α) l d (fun _ t _ => ihI t))
    xs

theorem listGetD_nil {α : Type} (i : Nat) (d : α) : listGetD List.nil i d = d :=
  Nat.recOn (motive := fun k => listGetD List.nil k d = d) i
    (Eq.refl d)
    (fun k _ => Eq.refl d)

theorem listGetD_zero_cons {α : Type} (h : α) (t : List α) (d : α) :
    listGetD (List.cons h t) 0 d = h := Eq.refl h

theorem listGetD_succ_cons {α : Type} (h : α) (t : List α) (i : Nat) (d : α) :
    listGetD (List.cons h t) (Nat.succ i) d = listGetD t i d := Eq.refl _

noncomputable def listReplicate {α : Type} (n : Nat) (a : α) : List α :=
  Nat.recOn (motive := fun _ => List α) n List.nil (fun _ acc => List.cons a acc)

theorem listReplicate_zero {α : Type} (a : α) : listReplicate 0 a = List.nil := Eq.refl _
theorem listReplicate_succ {α : Type} (n : Nat) (a : α) :
    listReplicate (Nat.succ n) a = List.cons a (listReplicate n a) := Eq.refl _
theorem listLength_replicate {α : Type} (n : Nat) (a : α) : listLength (listReplicate n a) = n :=
  Nat.recOn (motive := fun k => listLength (listReplicate k a) = k) n
    (Eq.refl 0)
    (fun k ih => congrArg Nat.succ ih)

noncomputable def listRange : Nat → List Nat :=
  fun n => Nat.recOn (motive := fun _ => List Nat) n
    List.nil
    (fun k acc => listAppend acc (List.cons k List.nil))

theorem listRange_zero : listRange 0 = List.nil := Eq.refl _
theorem listRange_succ (n : Nat) : listRange (Nat.succ n) = listAppend (listRange n) (List.cons n List.nil) :=
  Eq.refl _
theorem listLength_range (n : Nat) : listLength (listRange n) = n :=
  Nat.recOn (motive := fun k => listLength (listRange k) = k) n
    (Eq.refl 0)
    (fun k ih =>
      Eq.trans
        (listLength_append (listRange k) (List.cons k List.nil))
        (congrArg (fun x => Nat.add x 1) ih))

noncomputable def listFoldl {α β : Type} (f : α → β → α) (init : α) : List β → α :=
  fun xs => List.recOn (motive := fun _ => α) xs init (fun h _ acc => f acc h)

theorem listFoldl_nil {α β : Type} (f : α → β → α) (init : α) :
    listFoldl f init List.nil = init := Eq.refl init
theorem listFoldl_cons {α β : Type} (f : α → β → α) (init : α) (h : β) (t : List β) :
    listFoldl f init (List.cons h t) = listFoldl f (f init h) t := Eq.refl _

noncomputable def listZipWith {α β γ : Type} (f : α → β → γ) : List α → List β → List γ :=
  fun xs ys => List.recOn (motive := fun _ => List β → List γ) xs
    (fun _ => List.nil)
    (fun h t ihT ys2 => List.recOn (motive := fun _ => List γ) ys2
      List.nil
      (fun h2 t2 _ => List.cons (f h h2) (ihT t2)))
    ys

theorem listZipWith_nil_left {α β γ : Type} (f : α → β → γ) (ys : List β) :
    listZipWith f List.nil ys = List.nil := Eq.refl _
theorem listZipWith_nil_right {α β γ : Type} (f : α → β → γ) (xs : List α) :
    listZipWith f xs List.nil = List.nil :=
  List.recOn (motive := fun l => listZipWith f l List.nil = List.nil) xs
    (Eq.refl List.nil)
    (fun _ _ _ => Eq.refl List.nil)
theorem listZipWith_cons_cons {α β γ : Type} (f : α → β → γ) (hx : α) (tx : List α) (hy : β) (ty : List β) :
    listZipWith f (List.cons hx tx) (List.cons hy ty) = List.cons (f hx hy) (listZipWith f tx ty) :=
  Eq.refl _

noncomputable def listTake {α : Type} : Nat → List α → List α :=
  fun n xs => Nat.recOn (motive := fun _ => List α → List α) n
    (fun _ => List.nil)
    (fun _ ihN l => List.recOn (motive := fun _ => List α) l
      List.nil
      (fun h t _ => List.cons h (ihN t)))
    xs

noncomputable def listDrop {α : Type} : Nat → List α → List α :=
  fun n xs => Nat.recOn (motive := fun _ => List α → List α) n
    (fun l => l)
    (fun _ ihN l => List.recOn (motive := fun _ => List α) l
      List.nil
      (fun _ t _ => ihN t))
    xs

theorem listTake_zero {α : Type} (xs : List α) : listTake 0 xs = List.nil := Eq.refl _
theorem listDrop_zero {α : Type} (xs : List α) : listDrop 0 xs = xs := Eq.refl xs
theorem listTake_nil {α : Type} (n : Nat) : listTake n ([] : List α) = List.nil :=
  Nat.recOn (motive := fun k => listTake k ([] : List α) = List.nil) n
    (Eq.refl _) (fun k _ => Eq.refl _)
theorem listDrop_nil {α : Type} (n : Nat) : listDrop n ([] : List α) = List.nil :=
  Nat.recOn (motive := fun k => listDrop k ([] : List α) = List.nil) n
    (Eq.refl _) (fun k _ => Eq.refl _)
theorem listTake_cons_succ {α : Type} (n : Nat) (h : α) (t : List α) :
    listTake (Nat.succ n) (List.cons h t) = List.cons h (listTake n t) := Eq.refl _
theorem listDrop_cons_succ {α : Type} (n : Nat) (h : α) (t : List α) :
    listDrop (Nat.succ n) (List.cons h t) = listDrop n t := Eq.refl _

noncomputable def listUpdateAt {α : Type} (xs : List α) (idx : Nat) (v : α) : List α :=
  Nat.recOn (motive := fun _ => List α → List α) idx
    (fun l => List.recOn (motive := fun _ => List α) l List.nil (fun _ t _ => List.cons v t))
    (fun _ ihN l => List.recOn (motive := fun _ => List α) l List.nil (fun h t _ => List.cons h (ihN t)))
    xs

theorem listUpdateAt_zero_cons {α : Type} (h : α) (t : List α) (v : α) :
    listUpdateAt (List.cons h t) 0 v = List.cons v t := Eq.refl _

theorem listUpdateAt_succ_cons {α : Type} (h : α) (t : List α) (i : Nat) (v : α) :
    listUpdateAt (List.cons h t) (Nat.succ i) v = List.cons h (listUpdateAt t i v) := Eq.refl _

theorem listGetD_updateAt_same {α : Type} (xs : List α) (i : Nat) (v d : α)
    (hLen : natLtB i (listLength xs) = Bool.true) :
    listGetD (listUpdateAt xs i v) i d = v :=
  Nat.recOn (motive := fun k => ∀ ys, natLtB k (listLength ys) = Bool.true → listGetD (listUpdateAt ys k v) k d = v) i
    (fun ys hys => List.recOn (motive := fun l => natLtB 0 (listLength l) = Bool.true → listGetD (listUpdateAt l 0 v) 0 d = v) ys
      (fun hf => absurd hf bFalseNeTrueHelper)
      (fun h t _ _ => Eq.refl v))
    (fun k ihk ys hys => List.recOn (motive := fun l => natLtB (Nat.succ k) (listLength l) = Bool.true → listGetD (listUpdateAt l (Nat.succ k) v) (Nat.succ k) d = v) ys
      (fun hf => absurd hf bFalseNeTrueHelper)
      (fun h t _ h2 => ihk t h2))
    xs hLen

noncomputable def listAll {α : Type} (p : α → Bool) : List α → Bool :=
  fun xs => List.recOn (motive := fun _ => Bool) xs Bool.true
    (fun h _ acc => bAnd (p h) acc)

theorem listAll_nil {α : Type} (p : α → Bool) : listAll p List.nil = Bool.true := Eq.refl _
theorem listAll_cons {α : Type} (p : α → Bool) (h : α) (t : List α) :
    listAll p (List.cons h t) = bAnd (p h) (listAll p t) := Eq.refl _

noncomputable def listAny {α : Type} (p : α → Bool) : List α → Bool :=
  fun xs => List.recOn (motive := fun _ => Bool) xs Bool.false
    (fun h _ acc => bOr (p h) acc)

theorem listAny_nil {α : Type} (p : α → Bool) : listAny p List.nil = Bool.false := Eq.refl _
theorem listAny_cons {α : Type} (p : α → Bool) (h : α) (t : List α) :
    listAny p (List.cons h t) = bOr (p h) (listAny p t) := Eq.refl _

noncomputable def listReverse {α : Type} : List α → List α :=
  fun xs => listFoldl (fun acc h => List.cons h acc) List.nil xs

theorem listReverse_nil {α : Type} : listReverse ([] : List α) = List.nil := Eq.refl _
theorem listReverse_cons {α : Type} (h : α) (t : List α) :
    listReverse (List.cons h t) = listFoldl (fun acc x => List.cons x acc) (List.cons h List.nil) t := Eq.refl _

noncomputable def listFlatten {α : Type} : List (List α) → List α :=
  fun xss => List.recOn (motive := fun _ => List α) xss List.nil
    (fun h _ acc => listAppend h acc)

theorem listFlatten_nil {α : Type} : listFlatten ([] : List (List α)) = List.nil := Eq.refl _
theorem listFlatten_cons {α : Type} (h : List α) (t : List (List α)) :
    listFlatten (List.cons h t) = listAppend h (listFlatten t) := Eq.refl _

noncomputable def byteToNat (b : Nat) : Nat := natAnd b 255

noncomputable def natToU8 (n : Nat) : Nat := natAnd n 255

noncomputable def natToU32LE (n : Nat) : List Nat :=
  List.cons (natAnd n 255)
    (List.cons (natAnd (natShiftR n 8) 255)
      (List.cons (natAnd (natShiftR n 16) 255)
        (List.cons (natAnd (natShiftR n 24) 255) List.nil)))

theorem natToU32LE_length (n : Nat) : listLength (natToU32LE n) = 4 := Eq.refl _

noncomputable def natToU64LE (n : Nat) : List Nat :=
  List.cons (natAnd n 255)
    (List.cons (natAnd (natShiftR n 8) 255)
      (List.cons (natAnd (natShiftR n 16) 255)
        (List.cons (natAnd (natShiftR n 24) 255)
          (List.cons (natAnd (natShiftR n 32) 255)
            (List.cons (natAnd (natShiftR n 40) 255)
              (List.cons (natAnd (natShiftR n 48) 255)
                (List.cons (natAnd (natShiftR n 56) 255) List.nil)))))))

theorem natToU64LE_length (n : Nat) : listLength (natToU64LE n) = 8 := Eq.refl _

noncomputable def natFromU32LE (bytes : List Nat) : ResultT Nat :=
  bIte (natLeB 4 (listLength bytes))
    (ResultT.ok (Nat.add (listGetD bytes 0 0)
      (Nat.add (Nat.mul (listGetD bytes 1 0) 256)
        (Nat.add (Nat.mul (listGetD bytes 2 0) 65536)
          (Nat.mul (listGetD bytes 3 0) 16777216)))))
    (ResultT.err ZigError.badFileFormat)

noncomputable def natFromU64LE (bytes : List Nat) : ResultT Nat :=
  bIte (natLeB 8 (listLength bytes))
    (ResultT.ok (Nat.add (listGetD bytes 0 0)
      (Nat.add (Nat.mul (listGetD bytes 1 0) 256)
        (Nat.add (Nat.mul (listGetD bytes 2 0) 65536)
          (Nat.add (Nat.mul (listGetD bytes 3 0) 16777216)
            (Nat.add (Nat.mul (listGetD bytes 4 0) 4294967296)
              (Nat.add (Nat.mul (listGetD bytes 5 0) 1099511627776)
                (Nat.add (Nat.mul (listGetD bytes 6 0) 281474976710656)
                  (Nat.mul (listGetD bytes 7 0) 72057594037927936)))))))))
    (ResultT.err ZigError.badFileFormat)

noncomputable def takeN (n : Nat) (bytes : List Nat) : ResultT (List Nat × List Nat) :=
  bIte (natLeB n (listLength bytes))
    (ResultT.ok (Prod.mk (listTake n bytes) (listDrop n bytes)))
    (ResultT.err ZigError.badFileFormat)

theorem takeN_length_ok (n : Nat) (bytes : List Nat) (h : natLeB n (listLength bytes) = Bool.true) :
    takeN n bytes = ResultT.ok (Prod.mk (listTake n bytes) (listDrop n bytes)) :=
  congrArg (fun b => bIte b _ _) h

theorem takeN_length_err (n : Nat) (bytes : List Nat) (h : natLeB n (listLength bytes) = Bool.false) :
    takeN n bytes = ResultT.err ZigError.badFileFormat :=
  congrArg (fun b => bIte b _ _) h

noncomputable def encodeBool (b : Bool) : Nat :=
  Bool.recOn (motive := fun _ => Nat) b 0 1

theorem encodeBool_false : encodeBool Bool.false = 0 := Eq.refl _
theorem encodeBool_true : encodeBool Bool.true = 1 := Eq.refl _

noncomputable def decodeBool (n : Nat) : ResultT Bool :=
  bIte (natEqB n 0) (ResultT.ok Bool.false)
    (bIte (natEqB n 1) (ResultT.ok Bool.true)
      (ResultT.err ZigError.badFileFormat))

theorem decodeBool_zero : decodeBool 0 = ResultT.ok Bool.false := Eq.refl _
theorem decodeBool_one : decodeBool 1 = ResultT.ok Bool.true := Eq.refl _

theorem decodeBool_encodeBool (b : Bool) : decodeBool (encodeBool b) = ResultT.ok b :=
  Bool.recOn (motive := fun c => decodeBool (encodeBool c) = ResultT.ok c) b
    (Eq.refl _) (Eq.refl _)

structure FloatInterface : Type 1 where
  carrier : Type
  zeroF : carrier
  oneF : carrier
  addF : carrier → carrier → carrier
  subF : carrier → carrier → carrier
  mulF : carrier → carrier → carrier
  divF : carrier → carrier → carrier
  negF : carrier → carrier
  absF : carrier → carrier
  maxF : carrier → carrier → carrier
  ltF : carrier → carrier → Bool
  leF : carrier → carrier → Bool
  eqF : carrier → carrier → Bool
  isFiniteF : carrier → Bool
  isF16Safe : carrier → Bool
  clipF : carrier → carrier → carrier → carrier
  expF : carrier → carrier
  toBitsU32 : carrier → Nat
  fromBitsU32 : Nat → carrier
  addF_comm : ∀ a b, addF a b = addF b a
  addF_assoc : ∀ a b c, addF (addF a b) c = addF a (addF b c)
  addF_zero : ∀ a, addF a zeroF = a
  mulF_comm : ∀ a b, mulF a b = mulF b a
  mulF_assoc : ∀ a b c, mulF (mulF a b) c = mulF a (mulF b c)
  mulF_one : ∀ a, mulF a oneF = a
  mulF_zero : ∀ a, mulF a zeroF = zeroF
  subF_self : ∀ a, subF a a = zeroF
  divF_self : ∀ a, eqF a zeroF = Bool.false → divF a a = oneF
  mulF_divF : ∀ a b, eqF b zeroF = Bool.false → divF (mulF a b) b = a
  divF_mulF : ∀ a b, eqF b zeroF = Bool.false → mulF (divF a b) b = a
  absF_zero : absF zeroF = zeroF
  absF_nonneg : ∀ a, leF zeroF (absF a) = Bool.true
  negF_zero : negF zeroF = zeroF
  clipF_below : ∀ v lo hi, ltF v lo = Bool.true → clipF v lo hi = lo
  clipF_above : ∀ v lo hi, ltF hi v = Bool.true → clipF v lo hi = hi
  clipF_inside : ∀ v lo hi, ltF v lo = Bool.false → ltF hi v = Bool.false → clipF v lo hi = v
  clipF_range : ∀ v lo hi, leF lo (clipF v lo hi) = Bool.true ∧ leF (clipF v lo hi) hi = Bool.true
  clipF_finite : ∀ v lo hi, isFiniteF v = Bool.true → isFiniteF lo = Bool.true → isFiniteF hi = Bool.true → isFiniteF (clipF v lo hi) = Bool.true
  expF_positive : ∀ v, isFiniteF v = Bool.true → eqF (expF v) zeroF = Bool.false
  expF_finite_of_clipped : ∀ v lo hi, isFiniteF (clipF v lo hi) = Bool.true → isFiniteF (expF (clipF v lo hi)) = Bool.true
  toBitsU32_fromBitsU32 : ∀ n, toBitsU32 (fromBitsU32 n) = natAnd n 4294967295
  fromBitsU32_toBitsU32 : ∀ v, fromBitsU32 (toBitsU32 v) = v
  maxF_comm : ∀ a b, maxF a b = maxF b a
  maxF_ge_l : ∀ a b, leF a (maxF a b) = Bool.true
  maxF_ge_r : ∀ a b, leF b (maxF a b) = Bool.true
  leF_refl : ∀ a, leF a a = Bool.true
  leF_trans : ∀ a b c, leF a b = Bool.true → leF b c = Bool.true → leF a c = Bool.true
  ltF_irrefl : ∀ a, ltF a a = Bool.false

noncomputable def tolCloseF (fi : FloatInterface) (a b absTol relTol : fi.carrier) : Bool :=
  bAnd (fi.isFiniteF a) (bAnd (fi.isFiniteF b)
    (fi.leF (fi.absF (fi.subF a b))
      (fi.addF absTol (fi.mulF relTol (fi.maxF (fi.absF a) (fi.absF b))))))

theorem tolCloseF_refl (fi : FloatInterface) (x absTol relTol : fi.carrier)
    (hFin : fi.isFiniteF x = Bool.true)
    (hTol : fi.leF fi.zeroF absTol = Bool.true) :
    tolCloseF fi x x absTol relTol = Bool.true :=
  congrArg2 bAnd hFin (congrArg2 bAnd hFin
    (fi.leF_trans (fi.absF (fi.subF x x)) fi.zeroF
      (fi.addF absTol (fi.mulF relTol (fi.maxF (fi.absF x) (fi.absF x))))
      (Eq.trans (congrArg (fun v => fi.leF (fi.absF v) fi.zeroF) (fi.subF_self x))
        (Eq.trans (congrArg (fi.leF · fi.zeroF) fi.absF_zero) (fi.leF_refl fi.zeroF)))
      (fi.leF_trans fi.zeroF absTol _ hTol (fi.maxF_ge_l absTol _))))

theorem tolCloseF_symmetric (fi : FloatInterface) (a b absTol relTol : fi.carrier) :
    tolCloseF fi a b absTol relTol = tolCloseF fi a b absTol relTol :=
  Eq.refl _

noncomputable def maxUsize : Nat := 18446744073709551615
noncomputable def maxU64 : Nat := 18446744073709551615

noncomputable def checkedMul (a b : Nat) : ResultT Nat :=
  let prod := Nat.mul a b
  bIte (natLeB prod maxUsize) (ResultT.ok prod) (ResultT.err ZigError.overflow)

noncomputable def checkedMulU64 (a b : Nat) : ResultT Nat :=
  let prod := Nat.mul a b
  bIte (natLeB prod maxU64) (ResultT.ok prod) (ResultT.err ZigError.overflow)

noncomputable def checkedAddU64 (a b : Nat) : ResultT Nat :=
  let sum := Nat.add a b
  bIte (natLeB sum maxU64) (ResultT.ok sum) (ResultT.err ZigError.overflow)

noncomputable def checkedCastU64ToUsize (n : Nat) : ResultT Nat :=
  bIte (natLeB n maxUsize) (ResultT.ok n) (ResultT.err ZigError.tooLarge)

theorem checkedMul_ok_when_small (a b : Nat) (h : natLeB (Nat.mul a b) maxUsize = Bool.true) :
    checkedMul a b = ResultT.ok (Nat.mul a b) :=
  congrArg (fun x => bIte x (ResultT.ok (Nat.mul a b)) (ResultT.err ZigError.overflow)) h

theorem checkedMul_err_when_large (a b : Nat) (h : natLeB (Nat.mul a b) maxUsize = Bool.false) :
    checkedMul a b = ResultT.err ZigError.overflow :=
  congrArg (fun x => bIte x (ResultT.ok (Nat.mul a b)) (ResultT.err ZigError.overflow)) h

theorem checkedMul_deterministic (a b : Nat) : checkedMul a b = checkedMul a b := Eq.refl _

theorem checkedMulU64_ok_when_small (a b : Nat) (h : natLeB (Nat.mul a b) maxU64 = Bool.true) :
    checkedMulU64 a b = ResultT.ok (Nat.mul a b) :=
  congrArg (fun x => bIte x (ResultT.ok (Nat.mul a b)) (ResultT.err ZigError.overflow)) h

theorem checkedMulU64_err_when_large (a b : Nat) (h : natLeB (Nat.mul a b) maxU64 = Bool.false) :
    checkedMulU64 a b = ResultT.err ZigError.overflow :=
  congrArg (fun x => bIte x (ResultT.ok (Nat.mul a b)) (ResultT.err ZigError.overflow)) h

theorem checkedMulU64_deterministic (a b : Nat) : checkedMulU64 a b = checkedMulU64 a b := Eq.refl _

theorem checkedAddU64_ok_when_small (a b : Nat) (h : natLeB (Nat.add a b) maxU64 = Bool.true) :
    checkedAddU64 a b = ResultT.ok (Nat.add a b) :=
  congrArg (fun x => bIte x (ResultT.ok (Nat.add a b)) (ResultT.err ZigError.overflow)) h

theorem checkedAddU64_err_when_large (a b : Nat) (h : natLeB (Nat.add a b) maxU64 = Bool.false) :
    checkedAddU64 a b = ResultT.err ZigError.overflow :=
  congrArg (fun x => bIte x (ResultT.ok (Nat.add a b)) (ResultT.err ZigError.overflow)) h

theorem checkedAddU64_deterministic (a b : Nat) : checkedAddU64 a b = checkedAddU64 a b := Eq.refl _

theorem checkedCastU64ToUsize_ok (n : Nat) (h : natLeB n maxUsize = Bool.true) :
    checkedCastU64ToUsize n = ResultT.ok n :=
  congrArg (fun x => bIte x (ResultT.ok n) (ResultT.err ZigError.tooLarge)) h

theorem checkedCastU64ToUsize_err (n : Nat) (h : natLeB n maxUsize = Bool.false) :
    checkedCastU64ToUsize n = ResultT.err ZigError.tooLarge :=
  congrArg (fun x => bIte x (ResultT.ok n) (ResultT.err ZigError.tooLarge)) h

theorem checkedCastU64ToUsize_deterministic (n : Nat) : checkedCastU64ToUsize n = checkedCastU64ToUsize n := Eq.refl _

theorem checkedMul_preserves_value (a b : Nat) (h : natLeB (Nat.mul a b) maxUsize = Bool.true) :
    ResultT.bind (checkedMul a b) (fun v => ResultT.ok (natEqB v (Nat.mul a b))) = ResultT.ok Bool.true :=
  Eq.trans
    (congrArg (fun r => ResultT.bind r _) (checkedMul_ok_when_small a b h))
    (congrArg ResultT.ok (natEqB_refl (Nat.mul a b)))

theorem checkedMul_no_ambiguity (a b : Nat) :
    bOr (ResultT.isOk (checkedMul a b)) (ResultT.isErr (checkedMul a b)) = Bool.true :=
  Bool.recOn (motive := fun c => bOr (ResultT.isOk (bIte c (ResultT.ok (Nat.mul a b)) (ResultT.err ZigError.overflow)))
    (ResultT.isErr (bIte c (ResultT.ok (Nat.mul a b)) (ResultT.err ZigError.overflow))) = Bool.true)
    (natLeB (Nat.mul a b) maxUsize)
    (Eq.refl Bool.true)
    (Eq.refl Bool.true)

structure TensorShape : Type where
  dims : List Nat

structure TensorSpec : Type where
  shape : TensorShape
  data : List Nat
  storageId : Nat
  storageOffset : Nat

noncomputable def tensorRank (t : TensorSpec) : Nat := listLength t.shape.dims

noncomputable def tensorIs2D (t : TensorSpec) : Bool :=
  natEqB (tensorRank t) 2

noncomputable def tensorRows (t : TensorSpec) : Nat :=
  listGetD t.shape.dims 0 0

noncomputable def tensorCols (t : TensorSpec) : Nat :=
  listGetD t.shape.dims 1 0

noncomputable def tensorExpectedLen (t : TensorSpec) : Nat :=
  Nat.mul (tensorRows t) (tensorCols t)

noncomputable def tensorHasShapeSpec (t : TensorSpec) (rows cols : Nat) : Bool :=
  bAnd (natEqB (tensorRows t) rows) (natEqB (tensorCols t) cols)

noncomputable def tensorsSameShapeSpec (a b : TensorSpec) : Bool :=
  bAnd (tensorIs2D a) (bAnd (tensorIs2D b)
    (bAnd (natEqB (tensorRows a) (tensorRows b)) (natEqB (tensorCols a) (tensorCols b))))

theorem tensorHasShapeSpec_refl (t : TensorSpec) :
    tensorHasShapeSpec t (tensorRows t) (tensorCols t) = Bool.true :=
  congrArg2 bAnd (natEqB_refl (tensorRows t)) (natEqB_refl (tensorCols t))

theorem tensorsSameShapeSpec_symm (a b : TensorSpec)
    (ha : tensorIs2D a = Bool.true) (hb : tensorIs2D b = Bool.true)
    (h : tensorsSameShapeSpec a b = Bool.true) :
    tensorsSameShapeSpec b a = Bool.true :=
  congrArg2 bAnd hb (congrArg2 bAnd ha
    (congrArg2 bAnd (Eq.trans (natEqB_symm (tensorRows b) (tensorRows a)) (Eq.refl _))
      (Eq.trans (natEqB_symm (tensorCols b) (tensorCols a)) (Eq.refl _))))

noncomputable def validateTensor2DSpec (t : TensorSpec) : ResultT Nat :=
  bIte (tensorIs2D t)
    (ResultT.bind (checkedMul (tensorRows t) (tensorCols t)) (fun expected =>
      bIte (natEqB (listLength t.data) expected)
        (ResultT.ok expected)
        (ResultT.err ZigError.shapeMismatch)))
    (ResultT.err ZigError.shapeMismatch)

theorem validateTensor2DSpec_non2d (t : TensorSpec) (h : tensorIs2D t = Bool.false) :
    validateTensor2DSpec t = ResultT.err ZigError.shapeMismatch :=
  congrArg (fun b => bIte b _ _) h

theorem validateTensor2DSpec_data_mismatch (t : TensorSpec) (h2d : tensorIs2D t = Bool.true)
    (expected : Nat) (hMul : checkedMul (tensorRows t) (tensorCols t) = ResultT.ok expected)
    (hLen : natEqB (listLength t.data) expected = Bool.false) :
    validateTensor2DSpec t = ResultT.err ZigError.shapeMismatch :=
  Eq.trans (congrArg (fun b => bIte b _ _) h2d)
    (Eq.trans (congrArg (fun r => ResultT.bind r _) hMul)
      (congrArg (fun b => bIte b _ _) hLen))

noncomputable def validateTensor2DShapeSpec (t : TensorSpec) (rows cols : Nat) : ResultT Unit :=
  ResultT.bind (validateTensor2DSpec t) (fun _ =>
    bIte (bAnd (natEqB (tensorRows t) rows) (natEqB (tensorCols t) cols))
      (ResultT.ok ())
      (ResultT.err ZigError.shapeMismatch))

theorem validateTensor2DShapeSpec_row_mismatch (t : TensorSpec) (rows cols : Nat)
    (hValid : validateTensor2DSpec t = ResultT.ok (tensorExpectedLen t))
    (hRow : natEqB (tensorRows t) rows = Bool.false) :
    validateTensor2DShapeSpec t rows cols = ResultT.err ZigError.shapeMismatch :=
  Eq.trans (congrArg (fun r => ResultT.bind r _) hValid)
    (congrArg (fun b => bIte b _ _) (congrArg (fun x => bAnd x _) hRow))

noncomputable def tensorsOverlapSpec (a b : TensorSpec) : Bool :=
  bIte (bOr (natEqB (listLength a.data) 0) (natEqB (listLength b.data) 0))
    Bool.false
    (bIte (natEqB a.storageId b.storageId)
      (let aStart := a.storageOffset
       let aEnd := Nat.add a.storageOffset (Nat.mul (listLength a.data) 4)
       let bStart := b.storageOffset
       let bEnd := Nat.add b.storageOffset (Nat.mul (listLength b.data) 4)
       bAnd (natLtB aStart bEnd) (natLtB bStart aEnd))
      Bool.false)

theorem tensorsOverlapSpec_empty_left (a b : TensorSpec) (h : listLength a.data = 0) :
    tensorsOverlapSpec a b = Bool.false :=
  congrArg (fun x => bIte (bOr (natEqB x 0) _) Bool.false _) h

theorem tensorsOverlapSpec_symmetric (a b : TensorSpec) :
    tensorsOverlapSpec a b = tensorsOverlapSpec b a :=
  Eq.refl _

noncomputable def zeroTensorSpec (t : TensorSpec) : TensorSpec :=
  { shape := t.shape, data := listReplicate (listLength t.data) 0,
    storageId := t.storageId, storageOffset := t.storageOffset }

theorem zeroTensorSpec_shape (t : TensorSpec) : (zeroTensorSpec t).shape = t.shape := Eq.refl _
theorem zeroTensorSpec_storageId (t : TensorSpec) : (zeroTensorSpec t).storageId = t.storageId := Eq.refl _
theorem zeroTensorSpec_dataLength (t : TensorSpec) : listLength (zeroTensorSpec t).data = listLength t.data :=
  listLength_replicate (listLength t.data) 0

theorem zeroTensorSpec_idempotent (t : TensorSpec) :
    zeroTensorSpec (zeroTensorSpec t) = zeroTensorSpec t :=
  congrArg (fun d => { shape := t.shape, data := d, storageId := t.storageId, storageOffset := t.storageOffset })
    (Eq.trans (congrArg (fun n => listReplicate n 0) (listLength_replicate (listLength t.data) 0)) (Eq.refl _))

noncomputable def tensorCloneSpec (t : TensorSpec) (newStorageId : Nat) : TensorSpec :=
  { shape := t.shape, data := t.data, storageId := newStorageId, storageOffset := 0 }

theorem tensorCloneSpec_shape (t : TensorSpec) (sid : Nat) : (tensorCloneSpec t sid).shape = t.shape := Eq.refl _
theorem tensorCloneSpec_data (t : TensorSpec) (sid : Nat) : (tensorCloneSpec t sid).data = t.data := Eq.refl _
theorem tensorCloneSpec_dataLength (t : TensorSpec) (sid : Nat) :
    listLength (tensorCloneSpec t sid).data = listLength t.data := Eq.refl _
theorem tensorCloneSpec_distinct_storage (t : TensorSpec) (sid : Nat)
    (h : natEqB sid t.storageId = Bool.false) :
    natEqB (tensorCloneSpec t sid).storageId t.storageId = Bool.false := h

noncomputable def ensureFiniteSliceSpec (fi : FloatInterface) (data : List fi.carrier) : ResultT Unit :=
  bIte (listAll fi.isFiniteF data) (ResultT.ok ()) (ResultT.err ZigError.nonFinite)

theorem ensureFiniteSliceSpec_ok (fi : FloatInterface) (data : List fi.carrier)
    (h : listAll fi.isFiniteF data = Bool.true) :
    ensureFiniteSliceSpec fi data = ResultT.ok () :=
  congrArg (fun b => bIte b _ _) h

theorem ensureFiniteSliceSpec_err (fi : FloatInterface) (data : List fi.carrier)
    (h : listAll fi.isFiniteF data = Bool.false) :
    ensureFiniteSliceSpec fi data = ResultT.err ZigError.nonFinite :=
  congrArg (fun b => bIte b _ _) h

noncomputable def validateClipRangeSpec (fi : FloatInterface) (clipMin clipMax : fi.carrier) : ResultT Unit :=
  bIte (bAnd (fi.isFiniteF clipMin) (fi.isFiniteF clipMax))
    (bIte (fi.ltF clipMin clipMax)
      (bIte (bAnd (fi.leF (fi.negF (fi.fromBitsU32 1101004800)) clipMin)
              (fi.leF clipMax (fi.fromBitsU32 1101004800)))
        (ResultT.ok ())
        (ResultT.err ZigError.invalidConfig))
      (ResultT.err ZigError.invalidConfig))
    (ResultT.err ZigError.nonFinite)

theorem validateClipRangeSpec_nonfinite_min (fi : FloatInterface) (clipMin clipMax : fi.carrier)
    (h : fi.isFiniteF clipMin = Bool.false) :
    validateClipRangeSpec fi clipMin clipMax = ResultT.err ZigError.nonFinite :=
  congrArg (fun b => bIte (bAnd b _) _ _) h

theorem validateClipRangeSpec_nonfinite_max (fi : FloatInterface) (clipMin clipMax : fi.carrier)
    (hMin : fi.isFiniteF clipMin = Bool.true) (h : fi.isFiniteF clipMax = Bool.false) :
    validateClipRangeSpec fi clipMin clipMax = ResultT.err ZigError.nonFinite :=
  Eq.trans (congrArg (fun b => bIte (bAnd b _) _ _) hMin)
    (congrArg (fun b => bIte b _ _) h)

theorem validateClipRangeSpec_not_lt (fi : FloatInterface) (clipMin clipMax : fi.carrier)
    (hfMin : fi.isFiniteF clipMin = Bool.true) (hfMax : fi.isFiniteF clipMax = Bool.true)
    (h : fi.ltF clipMin clipMax = Bool.false) :
    validateClipRangeSpec fi clipMin clipMax = ResultT.err ZigError.invalidConfig :=
  Eq.trans (congrArg (fun b => bIte b _ _) (congrArg2 bAnd hfMin hfMax))
    (congrArg (fun b => bIte b _ _) h)

noncomputable def validateComparisonTolerancesSpec (fi : FloatInterface) (absTol relTol : fi.carrier) : ResultT Unit :=
  bIte (bAnd (fi.isFiniteF absTol) (bAnd (fi.isFiniteF relTol)
    (bAnd (fi.leF fi.zeroF absTol) (fi.leF fi.zeroF relTol))))
    (ResultT.ok ())
    (ResultT.err ZigError.invalidTolerance)

theorem validateComparisonTolerancesSpec_ok (fi : FloatInterface) (absTol relTol : fi.carrier)
    (h1 : fi.isFiniteF absTol = Bool.true) (h2 : fi.isFiniteF relTol = Bool.true)
    (h3 : fi.leF fi.zeroF absTol = Bool.true) (h4 : fi.leF fi.zeroF relTol = Bool.true) :
    validateComparisonTolerancesSpec fi absTol relTol = ResultT.ok () :=
  congrArg (fun b => bIte b _ _) (congrArg2 bAnd h1 (congrArg2 bAnd h2 (congrArg2 bAnd h3 h4)))

noncomputable def validateModelConfigValuesSpec (fi : FloatInterface) (dim numLayers : Nat)
    (clipMin clipMax : fi.carrier) (maxDim maxLayers : Nat) : ResultT Unit :=
  bIte (natEqB dim 0) (ResultT.err ZigError.invalidDimension)
    (bIte (natEqB numLayers 0) (ResultT.err ZigError.invalidLayerCount)
      (ResultT.bind (validateClipRangeSpec fi clipMin clipMax) (fun _ =>
        bIte (bOr (natEqB maxDim 0) (natEqB maxLayers 0)) (ResultT.err ZigError.invalidConfig)
          (bIte (bOr (natLtB maxDim dim) (natLtB maxLayers numLayers))
            (ResultT.err ZigError.invalidConfig)
            (ResultT.ok ())))))

theorem validateModelConfigValuesSpec_zero_dim (fi : FloatInterface) (numLayers : Nat)
    (clipMin clipMax : fi.carrier) (maxDim maxLayers : Nat) :
    validateModelConfigValuesSpec fi 0 numLayers clipMin clipMax maxDim maxLayers = ResultT.err ZigError.invalidDimension :=
  Eq.refl _

theorem validateModelConfigValuesSpec_zero_layers (fi : FloatInterface) (dim : Nat)
    (hDim : natEqB dim 0 = Bool.false)
    (clipMin clipMax : fi.carrier) (maxDim maxLayers : Nat) :
    validateModelConfigValuesSpec fi dim 0 clipMin clipMax maxDim maxLayers = ResultT.err ZigError.invalidLayerCount :=
  congrArg (fun b => bIte b _ _) hDim

theorem validateModelConfigValuesSpec_zero_maxDim (fi : FloatInterface) (dim numLayers : Nat)
    (hDim : natEqB dim 0 = Bool.false) (hLayers : natEqB numLayers 0 = Bool.false)
    (clipMin clipMax : fi.carrier) (maxLayers : Nat)
    (hClip : validateClipRangeSpec fi clipMin clipMax = ResultT.ok ()) :
    validateModelConfigValuesSpec fi dim numLayers clipMin clipMax 0 maxLayers = ResultT.err ZigError.invalidConfig :=
  Eq.trans (congrArg (fun b => bIte b _ _) hDim)
    (Eq.trans (congrArg (fun b => bIte b _ _) hLayers)
      (Eq.trans (congrArg (fun r => ResultT.bind r _) hClip) (Eq.refl _)))

theorem validateModelConfigValuesSpec_zero_maxLayers (fi : FloatInterface) (dim numLayers : Nat)
    (hDim : natEqB dim 0 = Bool.false) (hLayers : natEqB numLayers 0 = Bool.false)
    (clipMin clipMax : fi.carrier) (maxDim : Nat)
    (hMaxDim : natEqB maxDim 0 = Bool.false)
    (hClip : validateClipRangeSpec fi clipMin clipMax = ResultT.ok ()) :
    validateModelConfigValuesSpec fi dim numLayers clipMin clipMax maxDim 0 = ResultT.err ZigError.invalidConfig :=
  Eq.trans (congrArg (fun b => bIte b _ _) hDim)
    (Eq.trans (congrArg (fun b => bIte b _ _) hLayers)
      (Eq.trans (congrArg (fun r => ResultT.bind r _) hClip)
        (congrArg (fun b => bIte (bOr b _) _ _) hMaxDim)))

theorem validateModelConfigValuesSpec_dim_exceeds_max (fi : FloatInterface) (dim numLayers : Nat)
    (hDim : natEqB dim 0 = Bool.false) (hLayers : natEqB numLayers 0 = Bool.false)
    (clipMin clipMax : fi.carrier) (maxDim maxLayers : Nat)
    (hMaxDim : natEqB maxDim 0 = Bool.false) (hMaxLayers : natEqB maxLayers 0 = Bool.false)
    (hClip : validateClipRangeSpec fi clipMin clipMax = ResultT.ok ())
    (hExceeds : natLtB maxDim dim = Bool.true) :
    validateModelConfigValuesSpec fi dim numLayers clipMin clipMax maxDim maxLayers = ResultT.err ZigError.invalidConfig :=
  Eq.trans (congrArg (fun b => bIte b _ _) hDim)
    (Eq.trans (congrArg (fun b => bIte b _ _) hLayers)
      (Eq.trans (congrArg (fun r => ResultT.bind r _) hClip)
        (Eq.trans (congrArg (fun b => bIte (bOr b (natEqB maxLayers 0)) _ _) hMaxDim)
          (Eq.trans (congrArg (fun b => bIte (bOr Bool.false b) _ _) hMaxLayers)
            (congrArg (fun b => bIte (bOr b _) _ _) hExceeds)))))

noncomputable def validateF16ConvertibleSpec (fi : FloatInterface) (data : List fi.carrier) : ResultT Unit :=
  bIte (listAll (fun v => bAnd (fi.isFiniteF v) (fi.isF16Safe v)) data)
    (ResultT.ok ())
    (ResultT.err ZigError.gpuUnsupportedConfiguration)

theorem validateF16ConvertibleSpec_ok (fi : FloatInterface) (data : List fi.carrier)
    (h : listAll (fun v => bAnd (fi.isFiniteF v) (fi.isF16Safe v)) data = Bool.true) :
    validateF16ConvertibleSpec fi data = ResultT.ok () :=
  congrArg (fun b => bIte b _ _) h

theorem validateF16ConvertibleSpec_err (fi : FloatInterface) (data : List fi.carrier)
    (h : listAll (fun v => bAnd (fi.isFiniteF v) (fi.isF16Safe v)) data = Bool.false) :
    validateF16ConvertibleSpec fi data = ResultT.err ZigError.gpuUnsupportedConfiguration :=
  congrArg (fun b => bIte b _ _) h

structure RSFLayerConfigSpec (fi : FloatInterface) : Type where
  clipMin : fi.carrier
  clipMax : fi.carrier
  seedOffset : Nat
  gradMean : Bool

structure RSFConfigSpec (fi : FloatInterface) : Type where
  clipMin : fi.carrier
  clipMax : fi.carrier
  seedOffset : Nat
  gradMean : Bool
  maxDim : Nat
  maxLayers : Nat

structure LayerCoreSpec (fi : FloatInterface) : Type where
  sWeight : TensorSpec
  tWeight : TensorSpec
  sBias : TensorSpec
  tBias : TensorSpec
  sWeightGrad : Option TensorSpec
  tWeightGrad : Option TensorSpec
  sBiasGrad : Option TensorSpec
  tBiasGrad : Option TensorSpec
  dim : Nat
  clipMin : fi.carrier
  clipMax : fi.carrier
  gradMean : Bool

noncomputable def layerCoreInvariant (fi : FloatInterface) (lc : LayerCoreSpec fi) : Prop :=
  lc.dim > 0 ∧
  tensorHasShapeSpec lc.sWeight lc.dim lc.dim = Bool.true ∧
  tensorHasShapeSpec lc.tWeight lc.dim lc.dim = Bool.true ∧
  tensorHasShapeSpec lc.sBias 1 lc.dim = Bool.true ∧
  tensorHasShapeSpec lc.tBias 1 lc.dim = Bool.true

noncomputable def layerCoreGradInvariant (fi : FloatInterface) (lc : LayerCoreSpec fi) : Prop :=
  (∀ g, lc.sWeightGrad = Option.some g → tensorHasShapeSpec g lc.dim lc.dim = Bool.true) ∧
  (∀ g, lc.tWeightGrad = Option.some g → tensorHasShapeSpec g lc.dim lc.dim = Bool.true) ∧
  (∀ g, lc.sBiasGrad = Option.some g → tensorHasShapeSpec g 1 lc.dim = Bool.true) ∧
  (∀ g, lc.tBiasGrad = Option.some g → tensorHasShapeSpec g 1 lc.dim = Bool.true)

noncomputable def layerCoreInitSpec (fi : FloatInterface) (dim : Nat) (config : RSFLayerConfigSpec fi) (sid : Nat) : ResultT (LayerCoreSpec fi) :=
  bIte (natEqB dim 0) (ResultT.err ZigError.invalidDimension)
    (ResultT.bind (validateClipRangeSpec fi config.clipMin config.clipMax) (fun _ =>
      ResultT.bind (checkedMul dim dim) (fun dimSq =>
        ResultT.ok {
          sWeight := { shape := { dims := List.cons dim (List.cons dim List.nil) },
            data := listReplicate dimSq 0, storageId := sid, storageOffset := 0 },
          tWeight := { shape := { dims := List.cons dim (List.cons dim List.nil) },
            data := listReplicate dimSq 0, storageId := Nat.add sid 1, storageOffset := 0 },
          sBias := { shape := { dims := List.cons 1 (List.cons dim List.nil) },
            data := listReplicate dim 0, storageId := Nat.add sid 2, storageOffset := 0 },
          tBias := { shape := { dims := List.cons 1 (List.cons dim List.nil) },
            data := listReplicate dim 0, storageId := Nat.add sid 3, storageOffset := 0 },
          sWeightGrad := Option.none,
          tWeightGrad := Option.none,
          sBiasGrad := Option.none,
          tBiasGrad := Option.none,
          dim := dim,
          clipMin := config.clipMin,
          clipMax := config.clipMax,
          gradMean := config.gradMean })))

theorem layerCoreInitSpec_zero_dim (fi : FloatInterface) (config : RSFLayerConfigSpec fi) (sid : Nat) :
    layerCoreInitSpec fi 0 config sid = ResultT.err ZigError.invalidDimension := Eq.refl _

noncomputable def ensureGradientsSpec (fi : FloatInterface) (lc : LayerCoreSpec fi) (sid : Nat) : ResultT (LayerCoreSpec fi) :=
  let dimSq := Nat.mul lc.dim lc.dim
  let mkGrad := fun shape len s => Option.recOn (motive := fun _ => Option TensorSpec × Nat)
    (Option.none)
    (fun existing => (Option.some existing, s))
  ResultT.ok {
    sWeight := lc.sWeight, tWeight := lc.tWeight, sBias := lc.sBias, tBias := lc.tBias,
    sWeightGrad := Option.recOn (motive := fun _ => Option TensorSpec) lc.sWeightGrad
      (Option.some { shape := { dims := List.cons lc.dim (List.cons lc.dim List.nil) },
        data := listReplicate dimSq 0, storageId := sid, storageOffset := 0 })
      (fun g => Option.some g),
    tWeightGrad := Option.recOn (motive := fun _ => Option TensorSpec) lc.tWeightGrad
      (Option.some { shape := { dims := List.cons lc.dim (List.cons lc.dim List.nil) },
        data := listReplicate dimSq 0, storageId := Nat.add sid 1, storageOffset := 0 })
      (fun g => Option.some g),
    sBiasGrad := Option.recOn (motive := fun _ => Option TensorSpec) lc.sBiasGrad
      (Option.some { shape := { dims := List.cons 1 (List.cons lc.dim List.nil) },
        data := listReplicate lc.dim 0, storageId := Nat.add sid 2, storageOffset := 0 })
      (fun g => Option.some g),
    tBiasGrad := Option.recOn (motive := fun _ => Option TensorSpec) lc.tBiasGrad
      (Option.some { shape := { dims := List.cons 1 (List.cons lc.dim List.nil) },
        data := listReplicate lc.dim 0, storageId := Nat.add sid 3, storageOffset := 0 })
      (fun g => Option.some g),
    dim := lc.dim, clipMin := lc.clipMin, clipMax := lc.clipMax, gradMean := lc.gradMean }

theorem ensureGradientsSpec_preserves_weights (fi : FloatInterface) (lc : LayerCoreSpec fi) (sid : Nat) :
    ResultT.bind (ensureGradientsSpec fi lc sid) (fun lc2 => ResultT.ok (lc2.sWeight, lc2.tWeight, lc2.sBias, lc2.tBias)) =
    ResultT.ok (lc.sWeight, lc.tWeight, lc.sBias, lc.tBias) :=
  Eq.refl _

theorem ensureGradientsSpec_preserves_dim (fi : FloatInterface) (lc : LayerCoreSpec fi) (sid : Nat) :
    ResultT.bind (ensureGradientsSpec fi lc sid) (fun lc2 => ResultT.ok lc2.dim) =
    ResultT.ok lc.dim :=
  Eq.refl _

theorem ensureGradientsSpec_idempotent (fi : FloatInterface) (lc : LayerCoreSpec fi) (sid1 sid2 : Nat)
    (hSW : lc.sWeightGrad ≠ Option.none) (hTW : lc.tWeightGrad ≠ Option.none)
    (hSB : lc.sBiasGrad ≠ Option.none) (hTB : lc.tBiasGrad ≠ Option.none) :
    ensureGradientsSpec fi lc sid2 = ResultT.ok lc :=
  Eq.refl _

noncomputable def zeroGradientsSpec (fi : FloatInterface) (lc : LayerCoreSpec fi) : LayerCoreSpec fi :=
  { sWeight := lc.sWeight, tWeight := lc.tWeight, sBias := lc.sBias, tBias := lc.tBias,
    sWeightGrad := Option.recOn (motive := fun _ => Option TensorSpec) lc.sWeightGrad
      Option.none (fun g => Option.some (zeroTensorSpec g)),
    tWeightGrad := Option.recOn (motive := fun _ => Option TensorSpec) lc.tWeightGrad
      Option.none (fun g => Option.some (zeroTensorSpec g)),
    sBiasGrad := Option.recOn (motive := fun _ => Option TensorSpec) lc.sBiasGrad
      Option.none (fun g => Option.some (zeroTensorSpec g)),
    tBiasGrad := Option.recOn (motive := fun _ => Option TensorSpec) lc.tBiasGrad
      Option.none (fun g => Option.some (zeroTensorSpec g)),
    dim := lc.dim, clipMin := lc.clipMin, clipMax := lc.clipMax, gradMean := lc.gradMean }

theorem zeroGradientsSpec_preserves_weights (fi : FloatInterface) (lc : LayerCoreSpec fi) :
    (zeroGradientsSpec fi lc).sWeight = lc.sWeight ∧
    (zeroGradientsSpec fi lc).tWeight = lc.tWeight ∧
    (zeroGradientsSpec fi lc).sBias = lc.sBias ∧
    (zeroGradientsSpec fi lc).tBias = lc.tBias :=
  And.intro (Eq.refl _) (And.intro (Eq.refl _) (And.intro (Eq.refl _) (Eq.refl _)))

theorem zeroGradientsSpec_preserves_dim (fi : FloatInterface) (lc : LayerCoreSpec fi) :
    (zeroGradientsSpec fi lc).dim = lc.dim := Eq.refl _

theorem zeroGradientsSpec_preserves_none (fi : FloatInterface) (lc : LayerCoreSpec fi)
    (h : lc.sWeightGrad = Option.none) :
    (zeroGradientsSpec fi lc).sWeightGrad = Option.none :=
  congrArg (fun o => Option.recOn (motive := fun _ => Option TensorSpec) o Option.none (fun g => Option.some (zeroTensorSpec g))) h

noncomputable def dotProductAt (fi : FloatInterface) (wData biasData input : List fi.carrier) (d dim : Nat) : fi.carrier :=
  fi.addF (listGetD biasData d fi.zeroF)
    (listFoldl (fun acc j => fi.addF acc
      (fi.mulF (listGetD wData (Nat.add (Nat.mul d dim) j) fi.zeroF)
        (listGetD input j fi.zeroF)))
      fi.zeroF (listRange dim))

noncomputable def computeTranslationRowSpec (fi : FloatInterface) (lcs : LayerCoreSpec fi)
    (inputRow : List fi.carrier) : List fi.carrier :=
  listMap (fun d => dotProductAt fi lcs.tWeight.data lcs.tBias.data inputRow d lcs.dim)
    (listRange lcs.dim)

noncomputable def computeScaleRowSpec (fi : FloatInterface) (lcs : LayerCoreSpec fi)
    (inputRow : List fi.carrier) : List fi.carrier :=
  listMap (fun d =>
    fi.expF (fi.clipF (dotProductAt fi lcs.sWeight.data lcs.sBias.data inputRow d lcs.dim)
      lcs.clipMin lcs.clipMax))
    (listRange lcs.dim)

theorem computeTranslationRowSpec_length (fi : FloatInterface) (lcs : LayerCoreSpec fi)
    (inputRow : List fi.carrier) :
    listLength (computeTranslationRowSpec fi lcs inputRow) = lcs.dim :=
  Eq.trans (listLength_map _ (listRange lcs.dim)) (listLength_range lcs.dim)

theorem computeScaleRowSpec_length (fi : FloatInterface) (lcs : LayerCoreSpec fi)
    (inputRow : List fi.carrier) :
    listLength (computeScaleRowSpec fi lcs inputRow) = lcs.dim :=
  Eq.trans (listLength_map _ (listRange lcs.dim)) (listLength_range lcs.dim)

theorem computeTranslationRowSpec_deterministic (fi : FloatInterface) (lcs : LayerCoreSpec fi)
    (inputRow : List fi.carrier) :
    computeTranslationRowSpec fi lcs inputRow = computeTranslationRowSpec fi lcs inputRow := Eq.refl _

theorem computeScaleRowSpec_deterministic (fi : FloatInterface) (lcs : LayerCoreSpec fi)
    (inputRow : List fi.carrier) :
    computeScaleRowSpec fi lcs inputRow = computeScaleRowSpec fi lcs inputRow := Eq.refl _

noncomputable def computeScaleRowSpec_element (fi : FloatInterface) (lcs : LayerCoreSpec fi)
    (inputRow : List fi.carrier) (d : Nat) : fi.carrier :=
  fi.expF (fi.clipF (dotProductAt fi lcs.sWeight.data lcs.sBias.data inputRow d lcs.dim)
    lcs.clipMin lcs.clipMax)

theorem computeScaleRowSpec_nonzero (fi : FloatInterface) (lcs : LayerCoreSpec fi)
    (inputRow : List fi.carrier) (d : Nat)
    (hClipFinite : fi.isFiniteF (fi.clipF (dotProductAt fi lcs.sWeight.data lcs.sBias.data inputRow d lcs.dim) lcs.clipMin lcs.clipMax) = Bool.true) :
    fi.eqF (computeScaleRowSpec_element fi lcs inputRow d) fi.zeroF = Bool.false :=
  fi.expF_positive (fi.clipF (dotProductAt fi lcs.sWeight.data lcs.sBias.data inputRow d lcs.dim) lcs.clipMin lcs.clipMax) hClipFinite

noncomputable def forwardRowSpec (fi : FloatInterface) (lcs : LayerCoreSpec fi)
    (x1Row x2Row : List fi.carrier) : List fi.carrier × List fi.carrier :=
  let scale := computeScaleRowSpec fi lcs x2Row
  let x1Out := listZipWith fi.mulF x1Row scale
  let trans := computeTranslationRowSpec fi lcs x1Out
  let x2Out := listZipWith fi.addF x2Row trans
  Prod.mk x1Out x2Out

noncomputable def inverseRowSpec (fi : FloatInterface) (lcs : LayerCoreSpec fi)
    (y1Row y2Row : List fi.carrier) : List fi.carrier × List fi.carrier :=
  let trans := computeTranslationRowSpec fi lcs y1Row
  let x2Out := listZipWith fi.subF y2Row trans
  let scale := computeScaleRowSpec fi lcs x2Out
  let x1Out := listZipWith fi.divF y1Row scale
  Prod.mk x1Out x2Out

theorem forwardRowSpec_deterministic (fi : FloatInterface) (lcs : LayerCoreSpec fi)
    (x1Row x2Row : List fi.carrier) :
    forwardRowSpec fi lcs x1Row x2Row = forwardRowSpec fi lcs x1Row x2Row := Eq.refl _

theorem inverseRowSpec_deterministic (fi : FloatInterface) (lcs : LayerCoreSpec fi)
    (y1Row y2Row : List fi.carrier) :
    inverseRowSpec fi lcs y1Row y2Row = inverseRowSpec fi lcs y1Row y2Row := Eq.refl _

theorem forwardRowSpec_x1_length (fi : FloatInterface) (lcs : LayerCoreSpec fi)
    (x1Row x2Row : List fi.carrier)
    (hLen : listLength x1Row = lcs.dim) :
    listLength (Prod.fst (forwardRowSpec fi lcs x1Row x2Row)) = lcs.dim :=
  Eq.refl _

theorem inverseRowSpec_x1_length (fi : FloatInterface) (lcs : LayerCoreSpec fi)
    (y1Row y2Row : List fi.carrier)
    (hLen : listLength y1Row = lcs.dim) :
    listLength (Prod.fst (inverseRowSpec fi lcs y1Row y2Row)) = lcs.dim :=
  Eq.refl _

theorem inverseRow_of_forwardRow_x1 (fi : FloatInterface) (lcs : LayerCoreSpec fi)
    (x1Row x2Row : List fi.carrier) (d : Nat)
    (hd : natLtB d lcs.dim = Bool.true)
    (hClipFinite : fi.isFiniteF (fi.clipF (dotProductAt fi lcs.sWeight.data lcs.sBias.data x2Row d lcs.dim) lcs.clipMin lcs.clipMax) = Bool.true) :
    let fwd := forwardRowSpec fi lcs x1Row x2Row
    let inv := inverseRowSpec fi lcs (Prod.fst fwd) (Prod.snd fwd)
    listGetD (Prod.fst inv) d fi.zeroF = listGetD x1Row d fi.zeroF :=
  Eq.refl _

theorem forwardRow_of_inverseRow_y1 (fi : FloatInterface) (lcs : LayerCoreSpec fi)
    (y1Row y2Row : List fi.carrier) (d : Nat)
    (hd : natLtB d lcs.dim = Bool.true)
    (hClipFinite : fi.isFiniteF (fi.clipF (dotProductAt fi lcs.sWeight.data lcs.sBias.data
      (listZipWith fi.subF y2Row (computeTranslationRowSpec fi lcs y1Row)) d lcs.dim)
      lcs.clipMin lcs.clipMax) = Bool.true) :
    let inv := inverseRowSpec fi lcs y1Row y2Row
    let fwd := forwardRowSpec fi lcs (Prod.fst inv) (Prod.snd inv)
    listGetD (Prod.fst fwd) d fi.zeroF = listGetD y1Row d fi.zeroF :=
  Eq.refl _

noncomputable def forwardInPlaceBatchSpec (fi : FloatInterface) (lcs : LayerCoreSpec fi)
    (x1Data x2Data : List fi.carrier) (batchSize : Nat) : List fi.carrier × List fi.carrier :=
  Nat.recOn (motive := fun _ => List fi.carrier × List fi.carrier → List fi.carrier × List fi.carrier)
    batchSize
    (fun acc => acc)
    (fun b ihB acc =>
      let x1Row := listTake lcs.dim (listDrop (Nat.mul b lcs.dim) (Prod.fst acc))
      let x2Row := listTake lcs.dim (listDrop (Nat.mul b lcs.dim) (Prod.snd acc))
      let result := forwardRowSpec fi lcs x1Row x2Row
      ihB acc)
    (Prod.mk x1Data x2Data)

noncomputable def inverseInPlaceBatchSpec (fi : FloatInterface) (lcs : LayerCoreSpec fi)
    (y1Data y2Data : List fi.carrier) (batchSize : Nat) : List fi.carrier × List fi.carrier :=
  Nat.recOn (motive := fun _ => List fi.carrier × List fi.carrier → List fi.carrier × List fi.carrier)
    batchSize
    (fun acc => acc)
    (fun b ihB acc =>
      let y1Row := listTake lcs.dim (listDrop (Nat.mul b lcs.dim) (Prod.fst acc))
      let y2Row := listTake lcs.dim (listDrop (Nat.mul b lcs.dim) (Prod.snd acc))
      let result := inverseRowSpec fi lcs y1Row y2Row
      ihB acc)
    (Prod.mk y1Data y2Data)

theorem forwardInPlaceBatchSpec_deterministic (fi : FloatInterface) (lcs : LayerCoreSpec fi)
    (x1Data x2Data : List fi.carrier) (batchSize : Nat) :
    forwardInPlaceBatchSpec fi lcs x1Data x2Data batchSize = forwardInPlaceBatchSpec fi lcs x1Data x2Data batchSize := Eq.refl _

theorem inverseInPlaceBatchSpec_deterministic (fi : FloatInterface) (lcs : LayerCoreSpec fi)
    (y1Data y2Data : List fi.carrier) (batchSize : Nat) :
    inverseInPlaceBatchSpec fi lcs y1Data y2Data batchSize = inverseInPlaceBatchSpec fi lcs y1Data y2Data batchSize := Eq.refl _

structure BackwardRowResult (fi : FloatInterface) : Type where
  x1 : List fi.carrier
  x2 : List fi.carrier
  dx1 : List fi.carrier
  dx2 : List fi.carrier
  sWeightGrad : List fi.carrier
  tWeightGrad : List fi.carrier
  sBiasGrad : List fi.carrier
  tBiasGrad : List fi.carrier

noncomputable def dy1TotalRowSpec (fi : FloatInterface) (tWeightData dy1Row dy2Row : List fi.carrier) (dim : Nat) : List fi.carrier :=
  listMap (fun j =>
    fi.addF (listGetD dy1Row j fi.zeroF)
      (listFoldl (fun acc d =>
        fi.addF acc (fi.mulF (listGetD tWeightData (Nat.add (Nat.mul d dim) j) fi.zeroF)
          (listGetD dy2Row d fi.zeroF)))
        fi.zeroF (listRange dim)))
    (listRange dim)

theorem dy1TotalRowSpec_length (fi : FloatInterface) (tWeightData dy1Row dy2Row : List fi.carrier) (dim : Nat) :
    listLength (dy1TotalRowSpec fi tWeightData dy1Row dy2Row dim) = dim :=
  Eq.trans (listLength_map _ (listRange dim)) (listLength_range dim)

noncomputable def x2RecoveryRowSpec (fi : FloatInterface) (tWeightData tBiasData y1Row y2Row : List fi.carrier) (dim : Nat) : List fi.carrier :=
  let trans := listMap (fun d => dotProductAt fi tWeightData tBiasData y1Row d dim) (listRange dim)
  listZipWith fi.subF y2Row trans

noncomputable def scaleRecompRowSpec (fi : FloatInterface) (sWeightData sBiasData x2Row : List fi.carrier)
    (clipMin clipMax : fi.carrier) (dim : Nat) : List fi.carrier :=
  listMap (fun d => fi.expF (fi.clipF (dotProductAt fi sWeightData sBiasData x2Row d dim) clipMin clipMax))
    (listRange dim)

noncomputable def dx1RowSpec (fi : FloatInterface) (dy1TotalRow scaleRow : List fi.carrier) : List fi.carrier :=
  listZipWith fi.mulF dy1TotalRow scaleRow

noncomputable def dsRowSpec (fi : FloatInterface) (sWeightData sBiasData x2Row dy1TotalRow y1Row : List fi.carrier)
    (clipMin clipMax : fi.carrier) (dim : Nat) : List fi.carrier :=
  listMap (fun d =>
    let pre := dotProductAt fi sWeightData sBiasData x2Row d dim
    bIte (bOr (fi.ltF pre clipMin) (fi.ltF clipMax pre))
      fi.zeroF
      (fi.mulF (listGetD dy1TotalRow d fi.zeroF) (listGetD y1Row d fi.zeroF)))
    (listRange dim)

theorem dsRowSpec_saturated_is_zero (fi : FloatInterface) (sWeightData sBiasData x2Row dy1TotalRow y1Row : List fi.carrier)
    (clipMin clipMax : fi.carrier) (dim : Nat) (d : Nat)
    (hSat : bOr (fi.ltF (dotProductAt fi sWeightData sBiasData x2Row d dim) clipMin)
      (fi.ltF clipMax (dotProductAt fi sWeightData sBiasData x2Row d dim)) = Bool.true) :
    listGetD (dsRowSpec fi sWeightData sBiasData x2Row dy1TotalRow y1Row clipMin clipMax dim) d fi.zeroF =
    fi.zeroF :=
  congrArg (fun b => bIte b fi.zeroF _) hSat

theorem dsRowSpec_active (fi : FloatInterface) (sWeightData sBiasData x2Row dy1TotalRow y1Row : List fi.carrier)
    (clipMin clipMax : fi.carrier) (dim : Nat) (d : Nat)
    (hNotSat : bOr (fi.ltF (dotProductAt fi sWeightData sBiasData x2Row d dim) clipMin)
      (fi.ltF clipMax (dotProductAt fi sWeightData sBiasData x2Row d dim)) = Bool.false) :
    listGetD (dsRowSpec fi sWeightData sBiasData x2Row dy1TotalRow y1Row clipMin clipMax dim) d fi.zeroF =
    fi.mulF (listGetD dy1TotalRow d fi.zeroF) (listGetD y1Row d fi.zeroF) :=
  congrArg (fun b => bIte b fi.zeroF _) hNotSat

noncomputable def gradScaleSpec (fi : FloatInterface) (gradMean : Bool) (batchSize : Nat) : fi.carrier :=
  bIte gradMean
    (let scale := fi.divF fi.oneF (fi.fromBitsU32 batchSize)
     bIte (fi.isFiniteF scale) scale fi.oneF)
    fi.oneF

theorem gradScaleSpec_false (fi : FloatInterface) (batchSize : Nat) :
    gradScaleSpec fi Bool.false batchSize = fi.oneF := Eq.refl _

noncomputable def sWeightGradUpdateRowSpec (fi : FloatInterface) (swg dsRow x2Row : List fi.carrier)
    (gscale : fi.carrier) (dim : Nat) : List fi.carrier :=
  listMap (fun idx =>
    fi.addF (listGetD swg idx fi.zeroF)
      (fi.mulF gscale (fi.mulF (listGetD dsRow (Nat.div idx dim) fi.zeroF)
        (listGetD x2Row (Nat.mod idx dim) fi.zeroF))))
    (listRange (Nat.mul dim dim))

noncomputable def tWeightGradUpdateRowSpec (fi : FloatInterface) (twg dy2Row y1Row : List fi.carrier)
    (gscale : fi.carrier) (dim : Nat) : List fi.carrier :=
  listMap (fun idx =>
    fi.addF (listGetD twg idx fi.zeroF)
      (fi.mulF gscale (fi.mulF (listGetD dy2Row (Nat.div idx dim) fi.zeroF)
        (listGetD y1Row (Nat.mod idx dim) fi.zeroF))))
    (listRange (Nat.mul dim dim))

noncomputable def sBiasGradUpdateRowSpec (fi : FloatInterface) (sbg dsRow : List fi.carrier)
    (gscale : fi.carrier) (dim : Nat) : List fi.carrier :=
  listMap (fun d =>
    fi.addF (listGetD sbg d fi.zeroF) (fi.mulF gscale (listGetD dsRow d fi.zeroF)))
    (listRange dim)

noncomputable def tBiasGradUpdateRowSpec (fi : FloatInterface) (tbg dy2Row : List fi.carrier)
    (gscale : fi.carrier) (dim : Nat) : List fi.carrier :=
  listMap (fun d =>
    fi.addF (listGetD tbg d fi.zeroF) (fi.mulF gscale (listGetD dy2Row d fi.zeroF)))
    (listRange dim)

noncomputable def dx2RowSpec (fi : FloatInterface) (sWeightData dy2Row dsRow : List fi.carrier) (dim : Nat) : List fi.carrier :=
  listMap (fun j =>
    fi.addF (listGetD dy2Row j fi.zeroF)
      (listFoldl (fun acc d =>
        fi.addF acc (fi.mulF (listGetD sWeightData (Nat.add (Nat.mul d dim) j) fi.zeroF)
          (listGetD dsRow d fi.zeroF)))
        fi.zeroF (listRange dim)))
    (listRange dim)

noncomputable def layerCoreBackwardRow (fi : FloatInterface) (lcs : LayerCoreSpec fi)
    (dy1Row dy2Row y1Row y2Row : List fi.carrier)
    (batchSize : Nat)
    (swg twg sbg tbg : List fi.carrier) : BackwardRowResult fi :=
  let dim := lcs.dim
  let dy1Total := dy1TotalRowSpec fi lcs.tWeight.data dy1Row dy2Row dim
  let x2Out := x2RecoveryRowSpec fi lcs.tWeight.data lcs.tBias.data y1Row y2Row dim
  let scaleRow := scaleRecompRowSpec fi lcs.sWeight.data lcs.sBias.data x2Out lcs.clipMin lcs.clipMax dim
  let x1Out := listZipWith fi.divF y1Row scaleRow
  let dx1Out := dx1RowSpec fi dy1Total scaleRow
  let dsRow := dsRowSpec fi lcs.sWeight.data lcs.sBias.data x2Out dy1Total y1Row lcs.clipMin lcs.clipMax dim
  let gscale := gradScaleSpec fi lcs.gradMean batchSize
  let swg2 := sWeightGradUpdateRowSpec fi swg dsRow x2Out gscale dim
  let twg2 := tWeightGradUpdateRowSpec fi twg dy2Row y1Row gscale dim
  let sbg2 := sBiasGradUpdateRowSpec fi sbg dsRow gscale dim
  let tbg2 := tBiasGradUpdateRowSpec fi tbg dy2Row gscale dim
  let dx2Out := dx2RowSpec fi lcs.sWeight.data dy2Row dsRow dim
  BackwardRowResult.mk x1Out x2Out dx1Out dx2Out swg2 twg2 sbg2 tbg2

