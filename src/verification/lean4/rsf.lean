theorem clipF_idempotent (fi : FloatInterface) (v lo hi : fi.carrier)
    (hFinV : fi.isFiniteF v = Bool.true)
    (hFinLo : fi.isFiniteF lo = Bool.true)
    (hFinHi : fi.isFiniteF hi = Bool.true) :
    fi.clipF (fi.clipF v lo hi) lo hi = fi.clipF v lo hi :=
  let cv := fi.clipF v lo hi
  let r := fi.clipF_range v lo hi
  fi.clipF_inside cv lo hi
    (Bool.recOn (motive := fun b => fi.ltF cv lo = b → fi.ltF cv lo = Bool.false)
      (fi.ltF cv lo)
      (fun h => h) (fun h => absurd (fi.leF_trans lo cv lo r.1 (Eq.refl _).symm ▸ fi.leF_refl lo) bTrueNeFalseHelper))
    (Eq.refl _)
    (Bool.recOn (motive := fun b => fi.ltF hi cv = b → fi.ltF hi cv = Bool.false)
      (fi.ltF hi cv)
      (fun h => h) (fun h => absurd (fi.leF_trans cv hi cv r.2 (Eq.refl _).symm ▸ fi.leF_refl cv) bTrueNeFalseHelper))
    (Eq.refl _)

theorem expF_nonzero_of_clipped (fi : FloatInterface) (v lo hi : fi.carrier)
    (hFinLo : fi.isFiniteF lo = Bool.true) (hFinHi : fi.isFiniteF hi = Bool.true)
    (hFinV : fi.isFiniteF v = Bool.true) :
    fi.eqF (fi.expF (fi.clipF v lo hi)) fi.zeroF = Bool.false :=
  fi.expF_positive (fi.clipF v lo hi) (fi.clipF_finite v lo hi hFinV hFinLo hFinHi)

theorem divF_by_expF_recovers (fi : FloatInterface) (a v lo hi : fi.carrier)
    (hFinLo : fi.isFiniteF lo = Bool.true) (hFinHi : fi.isFiniteF hi = Bool.true)
    (hFinV : fi.isFiniteF v = Bool.true) :
    fi.divF (fi.mulF a (fi.expF (fi.clipF v lo hi))) (fi.expF (fi.clipF v lo hi)) = a :=
  fi.mulF_divF a (fi.expF (fi.clipF v lo hi))
    (fi.expF_positive (fi.clipF v lo hi) (fi.clipF_finite v lo hi hFinV hFinLo hFinHi))

