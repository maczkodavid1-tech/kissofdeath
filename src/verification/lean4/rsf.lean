noncomputable def xavierInitSpec (fi : FloatInterface) (dim : Nat) (seed : Nat) : List fi.carrier :=
  listMap (fun i => fi.mulF (fi.fromNat (deterministicRand seed i)) (xavierScale fi dim))
    (listRange (Nat.mul dim dim))

noncomputable def xavierScale (fi : FloatInterface) (dim : Nat) : fi.carrier :=
  fi.sqrtF (fi.divF (fi.fromNat 2) (fi.fromNat dim))

noncomputable def deterministicRand (seed i : Nat) : Nat :=
  natXor (Nat.add (Nat.mul seed 6364136223846793005) 1442695040888963407) i

theorem xavierInitSpec_length (fi : FloatInterface) (dim seed : Nat) :
    listLength (xavierInitSpec fi dim seed) = Nat.mul dim dim :=
  Eq.trans (listLength_map _ (listRange (Nat.mul dim dim))) (listLength_range (Nat.mul dim dim))

