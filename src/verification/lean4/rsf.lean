    registryRequestDestroy s1 id =
    registryRequestDestroy s1 id := Eq.refl _

theorem registry_double_acquire_different_ids (s : RegistryState) (p1 p2 : Nat) :
    let r1 := registryInsert s p1
    let s1 := Prod.fst r1
    let id1 := Prod.snd r1
    let r2 := registryInsert s1 p2
    let s2 := Prod.fst r2
    let id2 := Prod.snd r2
    id1 ≠ id2 :=
  Nat.succ_ne_self (Prod.snd (registryInsert s p1))

