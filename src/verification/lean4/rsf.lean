theorem multi_layer_forward_composition (fi : FloatInterface)
    (lc1 lc2 : LayerCoreSpec fi)
    (x1Row x2Row : List fi.carrier) :
    let core2 := { dim := lc1.dim, numLayers := 2,
      layers := List.cons lc1 (List.cons lc2 List.nil),
      cfg := RSFConfigSpec.mk lc1.clipMin lc1.clipMax 0 lc1.gradMean lc1.dim 2,
      gpuAvailable := Bool.false, gpuWeightVersion := 0, cpuWeightVersion := 1,
      hasAccel := Bool.false, hasF16Buf := Bool.false }
    let r1 := forwardRowSpec fi lc1 x1Row x2Row
    let r2 := forwardRowSpec fi lc2 (Prod.fst r1) (Prod.snd r1)
    rsfCoreForward fi core2 x1Row x2Row = r2 := Eq.refl _

theorem multi_layer_inverse_composition (fi : FloatInterface)
    (lc1 lc2 : LayerCoreSpec fi)
    (y1Row y2Row : List fi.carrier) :
    let core2 := { dim := lc1.dim, numLayers := 2,
      layers := List.cons lc1 (List.cons lc2 List.nil),
      cfg := RSFConfigSpec.mk lc1.clipMin lc1.clipMax 0 lc1.gradMean lc1.dim 2,
      gpuAvailable := Bool.false, gpuWeightVersion := 0, cpuWeightVersion := 1,
      hasAccel := Bool.false, hasF16Buf := Bool.false }
    let r1 := inverseRowSpec fi lc2 y1Row y2Row
    let r2 := inverseRowSpec fi lc1 (Prod.fst r1) (Prod.snd r1)
    rsfCoreInverse fi core2 y1Row y2Row = r2 := Eq.refl _

theorem multi_layer_forward_inverse_roundtrip (fi : FloatInterface)
    (lc1 lc2 : LayerCoreSpec fi)
    (x1Row x2Row : List fi.carrier) :
    let core2 := { dim := lc1.dim, numLayers := 2,
      layers := List.cons lc1 (List.cons lc2 List.nil),
      cfg := RSFConfigSpec.mk lc1.clipMin lc1.clipMax 0 lc1.gradMean lc1.dim 2,
      gpuAvailable := Bool.false, gpuWeightVersion := 0, cpuWeightVersion := 1,
