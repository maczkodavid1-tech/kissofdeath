def bNot : Bool → Bool
  | true => false
  | false => true

def bAnd : Bool → Bool → Bool
  | true, b => b
  | false, _ => false

def bOr : Bool → Bool → Bool
  | true, _ => true
  | false, b => b

def bIte {α : Type} : Bool → α → α → α
  | true, a, _ => a
  | false, _, b => b

theorem bNot_true : bNot true = false := rfl
theorem bNot_false : bNot false = true := rfl
theorem bAnd_true_l : ∀ b, bAnd true b = b := fun b => match b with | true => rfl | false => rfl
theorem bAnd_false_l : ∀ b, bAnd false b = false := fun _ => rfl
theorem bOr_true_l : ∀ b, bOr true b = true := fun _ => rfl
theorem bOr_false_l : ∀ b, bOr false b = b := fun b => match b with | true => rfl | false => rfl

theorem bNot_bNot (b : Bool) : bNot (bNot b) = b :=
  match b with | true => rfl | false => rfl

theorem bAnd_comm (a b : Bool) : bAnd a b = bAnd b a :=
  match a, b with
  | true, true => rfl | true, false => rfl
  | false, true => rfl | false, false => rfl

theorem bOr_comm (a b : Bool) : bOr a b = bOr b a :=
  match a, b with
  | true, true => rfl | true, false => rfl
  | false, true => rfl | false, false => rfl

theorem bAnd_assoc (a b c : Bool) : bAnd (bAnd a b) c = bAnd a (bAnd b c) :=
  match a, b, c with
  | true, true, true => rfl | true, true, false => rfl
  | true, false, true => rfl | true, false, false => rfl
  | false, true, true => rfl | false, true, false => rfl
  | false, false, true => rfl | false, false, false => rfl

theorem bOr_assoc (a b c : Bool) : bOr (bOr a b) c = bOr a (bOr b c) :=
  match a, b, c with
  | true, true, true => rfl | true, true, false => rfl
  | true, false, true => rfl | true, false, false => rfl
  | false, true, true => rfl | false, true, false => rfl
  | false, false, true => rfl | false, false, false => rfl

theorem bAnd_idem (a : Bool) : bAnd a a = a :=
  match a with | true => rfl | false => rfl

theorem bOr_idem (a : Bool) : bOr a a = a :=
  match a with | true => rfl | false => rfl

theorem de_morgan_and (a b : Bool) : bNot (bAnd a b) = bOr (bNot a) (bNot b) :=
  match a, b with
  | true, true => rfl | true, false => rfl
  | false, true => rfl | false, false => rfl

theorem de_morgan_or (a b : Bool) : bNot (bOr a b) = bAnd (bNot a) (bNot b) :=
  match a, b with
  | true, true => rfl | true, false => rfl
  | false, true => rfl | false, false => rfl

theorem bIte_true {α : Type} (a b : α) : bIte true a b = a := rfl
theorem bIte_false {α : Type} (a b : α) : bIte false a b = b := rfl

def natEqB : Nat → Nat → Bool
  | 0, 0 => true
  | 0, _ + 1 => false
  | _ + 1, 0 => false
  | m + 1, n + 1 => natEqB m n

def natLtB : Nat → Nat → Bool
  | _, 0 => false
  | 0, _ + 1 => true
  | m + 1, n + 1 => natLtB m n

def natLeB : Nat → Nat → Bool
  | 0, _ => true
  | _ + 1, 0 => false
  | m + 1, n + 1 => natLeB m n

def natMin : Nat → Nat → Nat
  | 0, _ => 0
  | _, 0 => 0
  | m + 1, n + 1 => (natMin m n) + 1

def natMax : Nat → Nat → Nat
  | 0, n => n
  | m, 0 => m
  | m + 1, n + 1 => (natMax m n) + 1

def natSub : Nat → Nat → Nat
  | n, 0 => n
  | 0, _ => 0
  | m + 1, n + 1 => natSub m n

def natAnd : Nat → Nat → Nat := Nat.land
def natXor : Nat → Nat → Nat := Nat.xor
def natShiftR : Nat → Nat → Nat := Nat.shiftRight

theorem natEqB_self (n : Nat) : natEqB n n = true :=
  match n with
  | 0 => rfl
  | n + 1 => natEqB_self n

