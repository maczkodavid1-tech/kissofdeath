theorem listMap_append {α β : Type} (f : α → β) (xs ys : List α) :
    listMap f (listAppend xs ys) = listAppend (listMap f xs) (listMap f ys) :=
  List.recOn (motive := fun l => listMap f (listAppend l ys) = listAppend (listMap f l) (listMap f ys)) xs
    (Eq.refl _)
    (fun h t ih => congrArg (List.cons (f h)) ih)

theorem listAll_append {α : Type} (p : α → Bool) (xs ys : List α) :
    listAll p (listAppend xs ys) = bAnd (listAll p xs) (listAll p ys) :=
  List.recOn (motive := fun l => listAll p (listAppend l ys) = bAnd (listAll p l) (listAll p ys)) xs
    (Eq.refl _)
    (fun h t ih => Eq.trans (congrArg (bAnd (p h)) ih) (bAnd_assoc (p h) (listAll p t) (listAll p ys)))

theorem listAny_append {α : Type} (p : α → Bool) (xs ys : List α) :
    listAny p (listAppend xs ys) = bOr (listAny p xs) (listAny p ys) :=
  List.recOn (motive := fun l => listAny p (listAppend l ys) = bOr (listAny p l) (listAny p ys)) xs
    (Eq.refl _)
    (fun h t ih => Eq.trans (congrArg (bOr (p h)) ih) (bOr_assoc (p h) (listAny p t) (listAny p ys)))

theorem listFoldl_append {α β : Type} (f : β → α → β) (init : β) (xs ys : List α) :
    listFoldl f init (listAppend xs ys) = listFoldl f (listFoldl f init xs) ys :=
  List.recOn (motive := fun l => ∀ i, listFoldl f i (listAppend l ys) = listFoldl f (listFoldl f i l) ys) xs
    (fun i => Eq.refl _)
    (fun h t ih i => ih (f i h))
    init

