noncomputable def validateModelMetadataSpec (fi : FloatInterface) (core : RSFCoreSpec fi) : ResultT Unit :=
  ResultT.bind (checkedModelLayerCountSpec fi core) (fun numLayers =>
    ResultT.bind (validateModelConfigValuesSpec fi core.dim numLayers
      core.cfg.clipMin core.cfg.clipMax core.cfg.maxDim core.cfg.maxLayers) (fun _ =>
      listFoldl (fun acc layer =>
        ResultT.bind acc (fun _ =>
          bIte (bAnd (natEqB layer.dim core.dim)
            (bAnd (fi.eqF layer.clipMin core.cfg.clipMin)
              (bAnd (fi.eqF layer.clipMax core.cfg.clipMax)
                (Bool.recOn (motive := fun _ => Bool) layer.gradMean
                  (Bool.recOn (motive := fun _ => Bool) core.cfg.gradMean Bool.true Bool.false)
                  (Bool.recOn (motive := fun _ => Bool) core.cfg.gradMean Bool.false Bool.true)))))
            (ResultT.bind (validateTensor2DShapeSpec layer.sWeight core.dim core.dim) (fun _ =>
              ResultT.bind (validateTensor2DShapeSpec layer.tWeight core.dim core.dim) (fun _ =>
                ResultT.bind (validateTensor2DShapeSpec layer.sBias 1 core.dim) (fun _ =>
                  validateTensor2DShapeSpec layer.tBias 1 core.dim))))
            (ResultT.err ZigError.invalidModelState)))
        (ResultT.ok ()) core.layers))

