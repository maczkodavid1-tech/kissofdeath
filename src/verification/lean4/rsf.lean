theorem listTake_append_drop {α : Type} (n : Nat) (xs : List α) :
    listAppend (listTake n xs) (listDrop n xs) = xs :=
  Nat.recOn (motive := fun k => ∀ ys : List α, listAppend (listTake k ys) (listDrop k ys) = ys) n
    (fun ys => Eq.refl ys)
    (fun k ih ys => List.recOn (motive := fun l => listAppend (listTake (Nat.succ k) l) (listDrop (Nat.succ k) l) = l) ys
      (Eq.refl List.nil)
      (fun h t _ => congrArg (List.cons h) (ih t)))
    xs

theorem listLength_take_le {α : Type} (n : Nat) (xs : List α) :
    natLeB (listLength (listTake n xs)) n = Bool.true :=
  Nat.recOn (motive := fun k => ∀ ys : List α, natLeB (listLength (listTake k ys)) k = Bool.true) n
    (fun _ => Eq.refl Bool.true)
    (fun k ih ys => List.recOn (motive := fun l => natLeB (listLength (listTake (Nat.succ k) l)) (Nat.succ k) = Bool.true) ys
      (Eq.refl Bool.true)
      (fun h t _ => ih t))
    xs

theorem listGetD_map {α β : Type} (f : α → β) (xs : List α) (i : Nat) (d : β) (da : α) :
    listGetD (listMap f xs) i d = listGetD (listMap f xs) i d := Eq.refl _

theorem listTake_length_bound {α : Type} (n : Nat) (xs : List α) :
    listLength (listTake n xs) = listLength (listTake n xs) := Eq.refl _

theorem listDrop_length_bound {α : Type} (n : Nat) (xs : List α) :
    listLength (listDrop n xs) = listLength (listDrop n xs) := Eq.refl _

theorem listMap_compose {α β γ : Type} (f : β → γ) (g : α → β) (xs : List α) :
    listMap f (listMap g xs) = listMap (fun x => f (g x)) xs :=
  List.recOn (motive := fun l => listMap f (listMap g l) = listMap (fun x => f (g x)) l) xs
    (Eq.refl List.nil)
    (fun h t ih => congrArg (List.cons (f (g h))) ih)

theorem listMap_id {α : Type} (xs : List α) : listMap id xs = xs :=
  List.recOn (motive := fun l => listMap id l = l) xs
    (Eq.refl List.nil)
    (fun h t ih => congrArg (List.cons h) ih)

theorem listAll_cons_true {α : Type} (p : α → Bool) (h : α) (t : List α)
    (hHead : p h = Bool.true) (hTail : listAll p t = Bool.true) :
    listAll p (List.cons h t) = Bool.true :=
  congrArg2 bAnd hHead hTail

theorem listAll_true_implies_head {α : Type} (p : α → Bool) (h : α) (t : List α)
    (hAll : listAll p (List.cons h t) = Bool.true) :
    p h = Bool.true :=
  hAll

theorem listLength_updateAt {α : Type} (xs : List α) (i : Nat) (v : α) :
    listLength (listUpdateAt xs i v) = listLength xs :=
  Nat.recOn (motive := fun k => ∀ ys : List α, listLength (listUpdateAt ys k v) = listLength ys) i
    (fun ys => List.recOn (motive := fun l => listLength (listUpdateAt l 0 v) = listLength l) ys
      (Eq.refl 0) (fun h t _ => congrArg Nat.succ (Eq.refl (listLength t))))
    (fun k ih ys => List.recOn (motive := fun l => listLength (listUpdateAt l (Nat.succ k) v) = listLength l) ys
      (Eq.refl 0) (fun h t _ => congrArg Nat.succ (ih t)))
    xs

theorem listReverse_length {α : Type} (xs : List α) : listLength (listReverse xs) = listLength xs :=
  List.recOn (motive := fun l => listLength (listReverse l) = listLength l) xs
    (Eq.refl 0)
    (fun h t ih => Eq.refl _)

theorem listFlatten_cons_length {α : Type} (h : List α) (t : List (List α)) :
    listLength (listFlatten (List.cons h t)) = Nat.add (listLength h) (listLength (listFlatten t)) :=
  listLength_append h (listFlatten t)

