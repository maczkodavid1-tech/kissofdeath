    Nat.succ (Nat.succ core.cpuWeightVersion) := Eq.refl _

theorem triple_notify_increments_thrice (fi : FloatInterface) (core : RSFCoreSpec fi) :
    (notifyWeightsChangedSpec fi (notifyWeightsChangedSpec fi (notifyWeightsChangedSpec fi core))).cpuWeightVersion =
