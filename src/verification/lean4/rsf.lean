theorem notify_then_sync_needed (fi : FloatInterface) (core : RSFCoreSpec fi)
    (hSync : natEqB core.gpuWeightVersion core.cpuWeightVersion = Bool.true) :
    natEqB (notifyWeightsChangedSpec fi core).gpuWeightVersion
      (notifyWeightsChangedSpec fi core).cpuWeightVersion = Bool.false :=
  Nat.succ_ne_self_via_eqB core.cpuWeightVersion core.gpuWeightVersion hSync

