theorem xavierScale_positive (fi : FloatInterface) (dim : Nat)
    (hDim : natLtB 0 dim = Bool.true) :
    fi.ltF fi.zeroF (xavierScale fi dim) = Bool.true :=
  fi.sqrtF_positive (fi.divF (fi.fromNat 2) (fi.fromNat dim))
    (fi.divF_positive (fi.fromNat 2) (fi.fromNat dim)
      (fi.fromNat_positive 2)
      (fi.fromNat_positive_of_nat_pos dim hDim))

