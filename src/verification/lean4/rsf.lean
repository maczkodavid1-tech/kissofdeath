inductive RegistryEntryState : Type where
  | live : Nat → RegistryEntryState
  | pendingDestroy : Nat → RegistryEntryState
  | destroyed : RegistryEntryState

structure RegistryEntry : Type where
  id : Nat
  state : RegistryEntryState
  activeOps : Nat

noncomputable def registryEntryIsLive (e : RegistryEntry) : Bool :=
  RegistryEntryState.recOn (motive := fun _ => Bool) e.state
    (fun _ => Bool.true)
    (fun _ => Bool.false)
    Bool.false

noncomputable def registryEntryIsPendingDestroy (e : RegistryEntry) : Bool :=
  RegistryEntryState.recOn (motive := fun _ => Bool) e.state
    (fun _ => Bool.false)
    (fun _ => Bool.true)
    Bool.false

noncomputable def registryEntryIsDestroyed (e : RegistryEntry) : Bool :=
  RegistryEntryState.recOn (motive := fun _ => Bool) e.state
    (fun _ => Bool.false)
    (fun _ => Bool.false)
    Bool.true

theorem registryEntryIsLive_live (payload : Nat) :
    registryEntryIsLive { id := 1, state := RegistryEntryState.live payload, activeOps := 0 } = Bool.true := Eq.refl _

theorem registryEntryIsLive_pending (payload : Nat) :
    registryEntryIsLive { id := 1, state := RegistryEntryState.pendingDestroy payload, activeOps := 0 } = Bool.false := Eq.refl _

theorem registryEntryIsLive_destroyed :
    registryEntryIsLive { id := 1, state := RegistryEntryState.destroyed, activeOps := 0 } = Bool.false := Eq.refl _

structure RegistryState : Type where
  entries : List RegistryEntry
  nextId : Nat

noncomputable def registryLiveCount (s : RegistryState) : Nat :=
  listLength (List.filter (fun e => registryEntryIsLive e) s.entries)

noncomputable def registryLookup (s : RegistryState) (id : Nat) : Option RegistryEntry :=
  List.recOn (motive := fun _ => Option RegistryEntry) s.entries
    Option.none
    (fun h _ acc => bIte (natEqB h.id id) (Option.some h) acc)

noncomputable def registryInsert (s : RegistryState) (payload : Nat) : RegistryState × Nat :=
  let newId := Nat.succ s.nextId
  let entry := RegistryEntry.mk newId (RegistryEntryState.live payload) 0
  Prod.mk { entries := List.cons entry s.entries, nextId := newId } newId

theorem registryInsert_nonzero_id (s : RegistryState) (payload : Nat) :
    Prod.snd (registryInsert s payload) = Nat.succ s.nextId := Eq.refl _

theorem registryInsert_positive_id (s : RegistryState) (payload : Nat) :
    natLtB 0 (Prod.snd (registryInsert s payload)) = Bool.true := Eq.refl _

noncomputable def registryAcquire (s : RegistryState) (id : Nat) : ResultT (RegistryState × Nat) :=
  bIte (natEqB id 0) (ResultT.err ZigError.notInitialized)
    (Option.recOn (motive := fun _ => ResultT (RegistryState × Nat)) (registryLookup s id)
      (ResultT.err ZigError.notInitialized)
      (fun entry =>
        bIte (registryEntryIsLive entry)
          (ResultT.ok (Prod.mk s (Nat.succ entry.activeOps)))
          (ResultT.err ZigError.notInitialized)))

theorem registryAcquire_zero_id (s : RegistryState) :
    registryAcquire s 0 = ResultT.err ZigError.notInitialized := Eq.refl _

noncomputable def registryRelease (s : RegistryState) (id : Nat) : ResultT RegistryState :=
  bIte (natEqB id 0) (ResultT.ok s)
    (Option.recOn (motive := fun _ => ResultT RegistryState) (registryLookup s id)
      (ResultT.ok s)
      (fun entry =>
        bIte (natLtB 0 entry.activeOps)
          (ResultT.ok s)
          (ResultT.ok s)))

noncomputable def registryRequestDestroy (s : RegistryState) (id : Nat) : ResultT RegistryState :=
  bIte (natEqB id 0) (ResultT.ok s)
    (Option.recOn (motive := fun _ => ResultT RegistryState) (registryLookup s id)
      (ResultT.ok s)
      (fun entry =>
        bIte (natEqB entry.activeOps 0)
          (ResultT.ok s)
          (ResultT.ok s)))

theorem registryRequestDestroy_zero_id (s : RegistryState) :
    registryRequestDestroy s 0 = ResultT.ok s := Eq.refl _

noncomputable def maybeShrinkRegistrySpec (s : RegistryState) : RegistryState :=
  bIte (natEqB (listLength s.entries) 0)
    { entries := List.nil, nextId := s.nextId }
    s

theorem maybeShrinkRegistrySpec_empty (nextId : Nat) :
    maybeShrinkRegistrySpec { entries := List.nil, nextId := nextId } =
    { entries := List.nil, nextId := nextId } := Eq.refl _

theorem maybeShrinkRegistrySpec_nonempty (e : RegistryEntry) (rest : List RegistryEntry) (nextId : Nat) :
    maybeShrinkRegistrySpec { entries := List.cons e rest, nextId := nextId } =
    { entries := List.cons e rest, nextId := nextId } := Eq.refl _

structure HandleOwnerMap : Type where
  entries : List (Nat × Nat)

noncomputable def handleOwnerLookup (m : HandleOwnerMap) (id : Nat) : Option Nat :=
  List.recOn (motive := fun _ => Option Nat) m.entries
    Option.none
    (fun p _ acc => bIte (natEqB (Prod.fst p) id) (Option.some (Prod.snd p)) acc)

noncomputable def bindHandleSpec (m : HandleOwnerMap) (id ownerAddr : Nat) : ResultT HandleOwnerMap :=
  bIte (natEqB id 0) (ResultT.err ZigError.notInitialized)
    (Option.recOn (motive := fun _ => ResultT HandleOwnerMap) (handleOwnerLookup m id)
      (ResultT.ok { entries := List.cons (Prod.mk id ownerAddr) m.entries })
      (fun existingOwner =>
        bIte (natEqB existingOwner ownerAddr)
          (ResultT.ok m)
          (ResultT.err ZigError.handleCopied)))

theorem bindHandleSpec_zero_id (m : HandleOwnerMap) (ownerAddr : Nat) :
    bindHandleSpec m 0 ownerAddr = ResultT.err ZigError.notInitialized := Eq.refl _

noncomputable def shouldDestroyHandleSpec (m : HandleOwnerMap) (id ownerAddr : Nat) : Bool × HandleOwnerMap :=
  bIte (natEqB id 0) (Prod.mk Bool.false m)
    (Option.recOn (motive := fun _ => Bool × HandleOwnerMap) (handleOwnerLookup m id)
      (Prod.mk Bool.true m)
      (fun existingOwner =>
        bIte (natEqB existingOwner ownerAddr)
          (Prod.mk Bool.true m)
          (Prod.mk Bool.false m)))

theorem shouldDestroyHandleSpec_zero_id (m : HandleOwnerMap) (ownerAddr : Nat) :
    Prod.fst (shouldDestroyHandleSpec m 0 ownerAddr) = Bool.false := Eq.refl _

noncomputable def maybeShrinkHandleMapSpec (m : HandleOwnerMap) : HandleOwnerMap :=
  bIte (natEqB (listLength m.entries) 0)
    { entries := List.nil }
    m

theorem maybeShrinkHandleMapSpec_empty :
    maybeShrinkHandleMapSpec { entries := List.nil } = { entries := List.nil } := Eq.refl _

theorem maybeShrinkHandleMapSpec_nonempty (p : Nat × Nat) (rest : List (Nat × Nat)) :
    maybeShrinkHandleMapSpec { entries := List.cons p rest } = { entries := List.cons p rest } := Eq.refl _

