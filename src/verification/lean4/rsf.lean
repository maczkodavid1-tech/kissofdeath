def listLength {α : Type} : List α → Nat
  | [] => 0
  | _ :: t => (listLength t) + 1

def listMap {α β : Type} (f : α → β) : List α → List β
  | [] => []
  | h :: t => f h :: listMap f t

def listAppend {α : Type} : List α → List α → List α
  | [], ys => ys
  | x :: xs, ys => x :: listAppend xs ys

def listGetD {α : Type} : List α → Nat → α → α
  | [], _, d => d
  | h :: _, 0, _ => h
  | _ :: t, n + 1, d => listGetD t n d

def listReplicate {α : Type} : Nat → α → List α
  | 0, _ => []
  | n + 1, v => v :: listReplicate n v

def listRange : Nat → List Nat
  | 0 => []
  | n + 1 => listRange n ++ [n]

def listAll {α : Type} (p : α → Bool) : List α → Bool
  | [] => true
  | h :: t => bAnd (p h) (listAll p t)

def listAny {α : Type} (p : α → Bool) : List α → Bool
  | [] => false
  | h :: t => bOr (p h) (listAny p t)

def listFoldl {α β : Type} (f : β → α → β) : β → List α → β
  | acc, [] => acc
  | acc, h :: t => listFoldl f (f acc h) t

def listReverse {α : Type} : List α → List α :=
  listFoldl (fun acc x => x :: acc) []

def listTake {α : Type} : Nat → List α → List α
  | 0, _ => []
  | _, [] => []
  | n + 1, h :: t => h :: listTake n t

def listDrop {α : Type} : Nat → List α → List α
  | 0, xs => xs
  | _, [] => []
  | n + 1, _ :: t => listDrop n t

def listZipWith {α β γ : Type} (f : α → β → γ) : List α → List β → List γ
  | [], _ => []
  | _, [] => []
  | a :: as, b :: bs => f a b :: listZipWith f as bs

def listFilter {α : Type} (p : α → Bool) : List α → List α
  | [] => []
  | h :: t => if p h then h :: listFilter p t else listFilter p t

def listUpdateAt {α : Type} : List α → Nat → α → List α
  | [], _, _ => []
  | _ :: t, 0, v => v :: t
  | h :: t, n + 1, v => h :: listUpdateAt t n v

