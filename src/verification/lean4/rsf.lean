theorem listZipWith_length_min {α β γ : Type} (f : α → β → γ) (xs : List α) (ys : List β) :
    listLength (listZipWith f xs ys) = natMin (listLength xs) (listLength ys) :=
  Eq.refl _

theorem listZipWith_same_length {α β γ : Type} (f : α → β → γ) (xs : List α) (ys : List β)
    (h : listLength xs = listLength ys) :
    listLength (listZipWith f xs ys) = listLength xs :=
  Eq.trans (listZipWith_length_min f xs ys)
    (Eq.trans (congrArg (natMin (listLength xs)) h) (natMin_self (listLength xs)))

