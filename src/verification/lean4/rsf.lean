noncomputable def validatePairSpec (fi : FloatInterface) (lc : LayerCoreSpec fi) (a b : TensorSpec) : ResultT Nat :=
  ResultT.bind (validateTensor2DSpec a) (fun _ =>
    ResultT.bind (validateTensor2DSpec b) (fun _ =>
      bIte (tensorsSameShapeSpec a b)
        (bIte (natEqB (tensorCols a) (Nat.mul lc.dim 2))
          (bIte (tensorsOverlapSpec a b)
            (ResultT.err ZigError.aliasedBuffers)
            (ResultT.ok (tensorRows a)))
          (ResultT.err ZigError.shapeMismatch))
        (ResultT.err ZigError.shapeMismatch)))

theorem validatePairSpec_aliased (fi : FloatInterface) (lc : LayerCoreSpec fi) (a b : TensorSpec)
    (hVa : validateTensor2DSpec a = ResultT.ok (tensorExpectedLen a))
    (hVb : validateTensor2DSpec b = ResultT.ok (tensorExpectedLen b))
    (hSame : tensorsSameShapeSpec a b = Bool.true)
    (hCols : natEqB (tensorCols a) (Nat.mul lc.dim 2) = Bool.true)
    (hOverlap : tensorsOverlapSpec a b = Bool.true) :
    validatePairSpec fi lc a b = ResultT.err ZigError.aliasedBuffers :=
  Eq.trans (congrArg (fun r => ResultT.bind r _) hVa)
    (Eq.trans (congrArg (fun r => ResultT.bind r _) hVb)
      (Eq.trans (congrArg (fun x => bIte x _ _) hSame)
        (Eq.trans (congrArg (fun x => bIte x _ _) hCols)
          (congrArg (fun x => bIte x _ _) hOverlap))))

