theorem listGetD_zero {α : Type} (h : α) (t : List α) (d : α) : listGetD (h :: t) 0 d = h := rfl
theorem listReplicate_0 {α : Type} (v : α) : listReplicate 0 v = ([] : List α) := rfl
theorem listFoldl_nil {α β : Type} (f : β → α → β) (acc : β) : listFoldl f acc ([] : List α) = acc := rfl
theorem listMap_nil {α β : Type} (f : α → β) : listMap f ([] : List α) = [] := rfl
theorem listMap_cons {α β : Type} (f : α → β) (h : α) (t : List α) : listMap f (h :: t) = f h :: listMap f t := rfl
theorem listAppend_nil_l {α : Type} (xs : List α) : listAppend [] xs = xs := rfl
