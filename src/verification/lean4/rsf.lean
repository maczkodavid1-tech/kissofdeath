noncomputable def crc32Table (idx : Nat) : Nat :=
  let init := natXor idx 4294967295
  let step1 := bIte (natEqB (natAnd init 1) 1) (natXor (natShr init 1) 3988292384) (natShr init 1)
  let step2 := bIte (natEqB (natAnd step1 1) 1) (natXor (natShr step1 1) 3988292384) (natShr step1 1)
  let step3 := bIte (natEqB (natAnd step2 1) 1) (natXor (natShr step2 1) 3988292384) (natShr step2 1)
  let step4 := bIte (natEqB (natAnd step3 1) 1) (natXor (natShr step3 1) 3988292384) (natShr step3 1)
  let step5 := bIte (natEqB (natAnd step4 1) 1) (natXor (natShr step4 1) 3988292384) (natShr step4 1)
  let step6 := bIte (natEqB (natAnd step5 1) 1) (natXor (natShr step5 1) 3988292384) (natShr step5 1)
  let step7 := bIte (natEqB (natAnd step6 1) 1) (natXor (natShr step6 1) 3988292384) (natShr step6 1)
  let step8 := bIte (natEqB (natAnd step7 1) 1) (natXor (natShr step7 1) 3988292384) (natShr step7 1)
  natXor step8 4294967295

theorem crc32Table_deterministic (idx : Nat) : crc32Table idx = crc32Table idx := Eq.refl _

theorem crc32Update_uses_table (crc byte : Nat) :
    crc32Update crc byte = natXor (natShr crc 8) (crc32Table (natAnd (natXor crc byte) 255)) :=
  Eq.refl _

theorem crc32OfList_nil : crc32OfList List.nil = crc32Final crc32Init := Eq.refl _

theorem crc32OfList_singleton (b : Nat) :
    crc32OfList (List.cons b List.nil) = crc32Final (crc32Update crc32Init b) := Eq.refl _

noncomputable def checkCopiedSpec (m : HandleOwnerMap) (id ownerAddr : Nat) : ResultT Unit :=
  bIte (natEqB id 0) (ResultT.err ZigError.notInitialized)
    (Option.recOn (motive := fun _ => ResultT Unit) (handleOwnerLookup m id)
      (ResultT.err ZigError.notInitialized)
      (fun existing => bIte (natEqB existing ownerAddr)
        (ResultT.ok ())
        (ResultT.err ZigError.handleCopied)))

theorem checkCopiedSpec_zero (m : HandleOwnerMap) (ownerAddr : Nat) :
    checkCopiedSpec m 0 ownerAddr = ResultT.err ZigError.notInitialized := Eq.refl _

theorem checkCopiedSpec_missing (m : HandleOwnerMap) (id ownerAddr : Nat)
    (hNonzero : natEqB id 0 = Bool.false)
    (hMissing : handleOwnerLookup m id = Option.none) :
    checkCopiedSpec m id ownerAddr = ResultT.err ZigError.notInitialized :=
  Eq.trans (congrArg (fun b => bIte b _ _) hNonzero)
    (congrArg (fun o => Option.recOn (motive := fun _ => ResultT Unit) o _ _) hMissing)

theorem checkCopiedSpec_same_owner (m : HandleOwnerMap) (id ownerAddr : Nat)
    (hNonzero : natEqB id 0 = Bool.false)
    (hFound : handleOwnerLookup m id = Option.some ownerAddr) :
    checkCopiedSpec m id ownerAddr = ResultT.ok () :=
  Eq.trans (congrArg (fun b => bIte b _ _) hNonzero)
    (Eq.trans (congrArg (fun o => Option.recOn (motive := fun _ => ResultT Unit) o _ _) hFound)
      (congrArg (fun b => bIte b _ _) (natEqB_refl ownerAddr)))

theorem checkCopiedSpec_different_owner (m : HandleOwnerMap) (id ownerAddr existingOwner : Nat)
    (hNonzero : natEqB id 0 = Bool.false)
    (hFound : handleOwnerLookup m id = Option.some existingOwner)
    (hDiff : natEqB existingOwner ownerAddr = Bool.false) :
    checkCopiedSpec m id ownerAddr = ResultT.err ZigError.handleCopied :=
  Eq.trans (congrArg (fun b => bIte b _ _) hNonzero)
    (Eq.trans (congrArg (fun o => Option.recOn (motive := fun _ => ResultT Unit) o _ _) hFound)
      (congrArg (fun b => bIte b _ _) hDiff))

noncomputable def maybeShrinkRegistrySpec (s : RegistryState) : RegistryState :=
  let activeCount := listLength (List.filter (fun e => match e.state with | RegistryEntryState.live _ => Bool.true | _ => Bool.false) s.entries)
  let totalCount := listLength s.entries
  bIte (bAnd (natLtB 16 totalCount) (natLtB (Nat.mul activeCount 4) totalCount))
    { entries := List.filter (fun e => match e.state with | RegistryEntryState.live _ => Bool.true | _ => Bool.false) s.entries,
      nextId := s.nextId }
    s

theorem maybeShrinkRegistrySpec_preserves_nextId (s : RegistryState) :
    (maybeShrinkRegistrySpec s).nextId = s.nextId := Eq.refl _

theorem maybeShrinkRegistrySpec_deterministic (s : RegistryState) :
    maybeShrinkRegistrySpec s = maybeShrinkRegistrySpec s := Eq.refl _

