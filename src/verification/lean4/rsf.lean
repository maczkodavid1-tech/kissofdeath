structure RegistryEntry where
  entryId : Nat
  payload : Nat
  acquired : Bool

structure RegistryState where
  entries : List RegistryEntry
  nextId : Nat

def registryInsert (s : RegistryState) (payload : Nat) : RegistryState × Nat :=
  let newId := s.nextId
  let entry : RegistryEntry := { entryId := newId, payload := payload, acquired := false }
  ({ entries := entry :: s.entries, nextId := newId + 1 }, newId)

def registryLookup : List RegistryEntry → Nat → Option RegistryEntry
  | [], _ => Option.none
  | e :: rest, id => if natEqB e.entryId id then Option.some e else registryLookup rest id

def registryAcquire (s : RegistryState) (id : Nat) : ResultT (RegistryState × Nat) :=
  match registryLookup s.entries id with
  | Option.none => ResultT.err ZigError.notInitialized
  | Option.some e =>
    bIte e.acquired (ResultT.err ZigError.invalidModelState)
      (let f := fun (entry : RegistryEntry) => if natEqB entry.entryId id then { entry with acquired := true } else entry
       let newEntries := listMap f s.entries
       ResultT.ok ({ entries := newEntries, nextId := s.nextId }, e.payload))

def registryRelease (s : RegistryState) (id : Nat) : ResultT RegistryState :=
  match registryLookup s.entries id with
  | Option.none => ResultT.err ZigError.notInitialized
  | Option.some e =>
    bIte (bNot e.acquired) (ResultT.err ZigError.invalidModelState)
      (let f := fun (entry : RegistryEntry) => if natEqB entry.entryId id then { entry with acquired := false } else entry
       let newEntries := listMap f s.entries
       ResultT.ok { entries := newEntries, nextId := s.nextId })

def registryRequestDestroy (s : RegistryState) (id : Nat) : ResultT RegistryState :=
  match registryLookup s.entries id with
  | Option.none => ResultT.ok s
  | Option.some e =>
    bIte e.acquired (ResultT.err ZigError.invalidModelState)
      (ResultT.ok { entries := listFilter (fun entry => bNot (natEqB entry.entryId id)) s.entries, nextId := s.nextId })

def registryLiveCount (s : RegistryState) : Nat := listLength s.entries

