  { core with gpuWeightVersion := core.cpuWeightVersion }

def modelGPUCompatibleSpec (fi : FloatInterface) (core : RSFCoreSpec fi) : Bool :=
  bAnd (natLtB 0 (listLength core.layers))
    (listAll (fun lc => bAnd (natEqB lc.dim core.dim)
      (bAnd (fi.eqF lc.clipMin core.cfg.clipMin)
        (fi.eqF lc.clipMax core.cfg.clipMax))) core.layers)

