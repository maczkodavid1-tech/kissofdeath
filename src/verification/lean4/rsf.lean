noncomputable def rsfCoreForward (fi : FloatInterface) (core : RSFCoreSpec fi)
    (x1Row x2Row : List fi.carrier) : List fi.carrier × List fi.carrier :=
  listFoldl (fun acc layer =>
    let result := forwardRowSpec fi layer (Prod.fst acc) (Prod.snd acc)
    result)
    (Prod.mk x1Row x2Row)
    core.layers

noncomputable def rsfCoreInverse (fi : FloatInterface) (core : RSFCoreSpec fi)
    (y1Row y2Row : List fi.carrier) : List fi.carrier × List fi.carrier :=
  listFoldl (fun acc layer =>
    let result := inverseRowSpec fi layer (Prod.fst acc) (Prod.snd acc)
    result)
    (Prod.mk y1Row y2Row)
    (listReverse core.layers)

theorem rsfCoreForward_nil (fi : FloatInterface) (core : RSFCoreSpec fi)
    (h : core.layers = List.nil)
    (x1Row x2Row : List fi.carrier) :
    rsfCoreForward fi core x1Row x2Row = Prod.mk x1Row x2Row :=
  congrArg (fun l => listFoldl _ (Prod.mk x1Row x2Row) l) h

theorem rsfCoreForward_deterministic (fi : FloatInterface) (core : RSFCoreSpec fi)
    (x1Row x2Row : List fi.carrier) :
