noncomputable def tryForwardGPUSpec (fi : FloatInterface) (core : RSFCoreSpec fi)
    (gpuForwardFn : List fi.carrier → Option (List fi.carrier))
    (xData : List fi.carrier) : Bool × List fi.carrier × RSFCoreSpec fi :=
  bIte (bNot core.gpuAvailable)
    (Prod.mk Bool.false (Prod.mk xData core))
    (bIte (bNot (natEqB core.gpuWeightVersion core.cpuWeightVersion))
      (Prod.mk Bool.false (Prod.mk xData (disableGPUSpec fi core)))
      (bIte (bNot core.hasAccel)
        (Prod.mk Bool.false (Prod.mk xData (disableGPUSpec fi core)))
        (Option.recOn (motive := fun _ => Bool × List fi.carrier × RSFCoreSpec fi)
          (gpuForwardFn xData)
          (Prod.mk Bool.false (Prod.mk xData (disableGPUSpec fi core)))
          (fun result => Prod.mk Bool.true (Prod.mk result core)))))

theorem tryForwardGPUSpec_disabled (fi : FloatInterface) (core : RSFCoreSpec fi)
    (gpuFn : List fi.carrier → Option (List fi.carrier))
    (xData : List fi.carrier) (h : core.gpuAvailable = Bool.false) :
    Prod.fst (tryForwardGPUSpec fi core gpuFn xData) = Bool.false :=
  congrArg (fun b => Prod.fst (bIte (bNot b) _ _)) h

theorem tryForwardGPUSpec_version_mismatch (fi : FloatInterface) (core : RSFCoreSpec fi)
    (gpuFn : List fi.carrier → Option (List fi.carrier))
    (xData : List fi.carrier)
    (hAvail : core.gpuAvailable = Bool.true)
    (hVer : natEqB core.gpuWeightVersion core.cpuWeightVersion = Bool.false) :
    Prod.fst (tryForwardGPUSpec fi core gpuFn xData) = Bool.false :=
  Eq.trans (congrArg (fun b => Prod.fst (bIte (bNot b) _ _)) hAvail)
    (congrArg (fun b => Prod.fst (bIte (bNot b) _ _)) hVer)

theorem tryForwardGPUSpec_success_preserves_cpu_weights (fi : FloatInterface) (core : RSFCoreSpec fi)
    (gpuFn : List fi.carrier → Option (List fi.carrier))
    (xData result : List fi.carrier)
    (hAvail : core.gpuAvailable = Bool.true)
    (hVer : natEqB core.gpuWeightVersion core.cpuWeightVersion = Bool.true)
    (hAccel : core.hasAccel = Bool.true)
    (hGpu : gpuFn xData = Option.some result) :
    (Prod.snd (Prod.snd (tryForwardGPUSpec fi core gpuFn xData))).layers = core.layers :=
  Eq.refl _

