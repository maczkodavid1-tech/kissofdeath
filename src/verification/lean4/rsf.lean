structure LayerCoreSpec (fi : FloatInterface) where
  dim : Nat
  sWeight : TensorSpec fi.carrier
  tWeight : TensorSpec fi.carrier
  sBias : TensorSpec fi.carrier
  tBias : TensorSpec fi.carrier
  clipMin : fi.carrier
  clipMax : fi.carrier
  gradMean : Bool
  sWeightGrad : Option (TensorSpec fi.carrier)
  tWeightGrad : Option (TensorSpec fi.carrier)
  sBiasGrad : Option (TensorSpec fi.carrier)
  tBiasGrad : Option (TensorSpec fi.carrier)

structure RSFCoreSpec (fi : FloatInterface) where
  dim : Nat
  numLayers : Nat
  layers : List (LayerCoreSpec fi)
  cfg : RSFConfigSpec fi
  gpuAvailable : Bool
  hasAccel : Bool
  hasF16Buf : Bool
  gpuWeightVersion : Nat
  cpuWeightVersion : Nat

