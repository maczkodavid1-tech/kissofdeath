noncomputable def verifyInvertibleSpec (fi : FloatInterface) (core : RSFCoreSpec fi)
    (xData : List fi.carrier) (absTol relTol : fi.carrier) : ResultT Bool :=
  ResultT.bind (validateComparisonTolerancesSpec fi absTol relTol) (fun _ =>
    let forwardResult := rsfCoreForward fi core (listTake core.dim xData) (listDrop core.dim xData)
    let inverseResult := rsfCoreInverse fi core (Prod.fst forwardResult) (Prod.snd forwardResult)
    ResultT.ok (bAnd
      (listAll (fun i => tolCloseF fi (listGetD (Prod.fst inverseResult) i fi.zeroF)
        (listGetD (listTake core.dim xData) i fi.zeroF) absTol relTol) (listRange core.dim))
      (listAll (fun i => tolCloseF fi (listGetD (Prod.snd inverseResult) i fi.zeroF)
        (listGetD (listDrop core.dim xData) i fi.zeroF) absTol relTol) (listRange core.dim))))

