    verifyInvertibleSpec fi core xData absTol relTol = verifyInvertibleSpec fi core xData absTol relTol := Eq.refl _

noncomputable def tryForwardGPUMultiLayerSpec (fi : FloatInterface) (core : RSFCoreSpec fi)
    (layerGpuFn : LayerCoreSpec fi → List fi.carrier → Option (List fi.carrier))
    (xData : List fi.carrier) : Bool × List fi.carrier × RSFCoreSpec fi :=
  bIte (bNot core.gpuAvailable)
    (Prod.mk Bool.false (Prod.mk xData core))
    (bIte (bNot (natEqB core.gpuWeightVersion core.cpuWeightVersion))
      (Prod.mk Bool.false (Prod.mk xData (disableGPUSpec fi core)))
      (let workResult := listFoldl (fun acc layer =>
        Option.recOn (motive := fun _ => Option (List fi.carrier)) acc
          Option.none
          (fun working => layerGpuFn layer working))
        (Option.some xData) core.layers
       Option.recOn (motive := fun _ => Bool × List fi.carrier × RSFCoreSpec fi) workResult
        (Prod.mk Bool.false (Prod.mk xData (disableGPUSpec fi core)))
        (fun result => Prod.mk Bool.true (Prod.mk result core))))

