theorem natSub_0 (n : Nat) : natSub n 0 = n :=
  match n with | 0 => rfl | _ + 1 => rfl

theorem natSub_self (n : Nat) : natSub n n = 0 :=
  match n with | 0 => rfl | n + 1 => natSub_self n

