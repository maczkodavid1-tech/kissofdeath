def forwardInPlaceBatchSpec (fi : FloatInterface) (lcs : LayerCoreSpec fi)
    (x1 x2 : List fi.carrier) (batchSize : Nat) : List fi.carrier × List fi.carrier :=
  listFoldl (fun acc _ => forwardRowSpec fi lcs acc.1 acc.2) (x1, x2) (List.range batchSize)

def inverseInPlaceBatchSpec (fi : FloatInterface) (lcs : LayerCoreSpec fi)
    (y1 y2 : List fi.carrier) (batchSize : Nat) : List fi.carrier × List fi.carrier :=
  listFoldl (fun acc _ => inverseRowSpec fi lcs acc.1 acc.2) (y1, y2) (List.range batchSize)

