    (hDim : lc.dim = core.dim)
    (d : Nat) (hd : natLtB d core.dim = Bool.true) :
    listGetD (Prod.fst (rsfCoreInverse fi core
      (Prod.fst (rsfCoreForward fi core x1Row x2Row))
