noncomputable def syncAllLayersGPUSpec (fi : FloatInterface) (core : RSFCoreSpec fi) : ResultT (RSFCoreSpec fi) :=
  bIte (bNot core.gpuAvailable)
    (ResultT.err ZigError.noGPUAvailable)
    (bIte (modelGPUCompatibleSpec fi core)
      (ResultT.ok { dim := core.dim, numLayers := core.numLayers, layers := core.layers,
        cfg := core.cfg, gpuAvailable := Bool.true,
        gpuWeightVersion := core.cpuWeightVersion, cpuWeightVersion := core.cpuWeightVersion,
        hasAccel := core.hasAccel, hasF16Buf := core.hasF16Buf })
      (ResultT.err ZigError.gpuUnsupportedConfiguration))

theorem syncAllLayersGPUSpec_sets_version (fi : FloatInterface) (core : RSFCoreSpec fi)
    (hAvail : core.gpuAvailable = Bool.true)
    (hCompat : modelGPUCompatibleSpec fi core = Bool.true) :
    ResultT.bind (syncAllLayersGPUSpec fi core) (fun c => ResultT.ok (natEqB c.gpuWeightVersion c.cpuWeightVersion)) =
    ResultT.ok Bool.true :=
  Eq.trans
    (congrArg (fun b => ResultT.bind (bIte (bNot b) _ _) _) hAvail)
    (Eq.trans
      (congrArg (fun b => ResultT.bind (bIte b _ _) _) hCompat)
      (congrArg ResultT.ok (natEqB_refl core.cpuWeightVersion)))

structure SavedLayerSnapshotSpec (fi : FloatInterface) : Type where
  clipMin : fi.carrier
  clipMax : fi.carrier
  gradMean : Bool
  sWeight : TensorSpec
  tWeight : TensorSpec
  sBias : TensorSpec
  tBias : TensorSpec

structure SavedModelSnapshot (fi : FloatInterface) : Type where
  dim : Nat
  numLayers : Nat
  cfg : RSFConfigSpec fi
  layers : List (SavedLayerSnapshotSpec fi)
  layerCountEq : numLayers = listLength layers

noncomputable def crc32Mask : Nat := 4294967295

noncomputable def crc32Init : Nat := 4294967295

noncomputable def crc32TableEntry (i : Nat) : Nat :=
  Nat.recOn (motive := fun _ => Nat → Nat) 8
    (fun crc => crc)
    (fun _ ih crc =>
      ih (bIte (natEqB (natAnd crc 1) 1)
        (natXor (natShiftR crc 1) 3988292384)
        (natShiftR crc 1)))
    i

noncomputable def crc32Update (crc byte : Nat) : Nat :=
  natXor (natShiftR crc 8) (crc32TableEntry (natAnd (natXor crc byte) 255))

noncomputable def crc32Final (crc : Nat) : Nat := natXor crc crc32Mask

noncomputable def crc32OfList (bytes : List Nat) : Nat :=
  crc32Final (listFoldl crc32Update crc32Init bytes)

theorem crc32_deterministic (bytes : List Nat) : crc32OfList bytes = crc32OfList bytes := Eq.refl _

theorem crc32_update_deterministic (crc byte : Nat) : crc32Update crc byte = crc32Update crc byte := Eq.refl _

theorem crc32Init_def : crc32Init = 4294967295 := Eq.refl _

theorem crc32Final_xors_with_mask (crc : Nat) : crc32Final crc = natXor crc crc32Mask := Eq.refl _

noncomputable def serializeTensorPayload (t : TensorSpec) : List Nat :=
  listAppend (natToU64LE 2)
    (listAppend (natToU64LE (tensorRows t))
      (listAppend (natToU64LE (tensorCols t))
        (listFlatten (listMap natToU32LE t.data))))

noncomputable def serializeLayerPayload (fi : FloatInterface) (layer : SavedLayerSnapshotSpec fi) : List Nat :=
  listAppend (natToU32LE (fi.toBitsU32 layer.clipMin))
    (listAppend (natToU32LE (fi.toBitsU32 layer.clipMax))
      (listAppend (List.cons (encodeBool layer.gradMean) List.nil)
        (listAppend (serializeTensorPayload layer.sWeight)
          (listAppend (serializeTensorPayload layer.tWeight)
            (listAppend (serializeTensorPayload layer.sBias)
              (serializeTensorPayload layer.tBias))))))

noncomputable def serializeSnapshotPayload (fi : FloatInterface) (s : SavedModelSnapshot fi) : List Nat :=
  let magic := List.cons 82 (List.cons 83 (List.cons 70 (List.cons 48 List.nil)))
  let version := natToU32LE 4
  let numLayersBytes := natToU64LE s.numLayers
  let dimBytes := natToU64LE s.dim
  let clipMinBytes := natToU32LE (fi.toBitsU32 s.cfg.clipMin)
  let clipMaxBytes := natToU32LE (fi.toBitsU32 s.cfg.clipMax)
  let gradMeanByte := List.cons (encodeBool s.cfg.gradMean) List.nil
  let maxDimBytes := natToU64LE s.cfg.maxDim
  let maxLayersBytes := natToU64LE s.cfg.maxLayers
  let header := listAppend magic (listAppend version (listAppend numLayersBytes
    (listAppend dimBytes (listAppend clipMinBytes (listAppend clipMaxBytes
      (listAppend gradMeanByte (listAppend maxDimBytes maxLayersBytes)))))))
  let layerPayloads := listFlatten (listMap (serializeLayerPayload fi) s.layers)
  listAppend header layerPayloads

noncomputable def serializeSnapshot (fi : FloatInterface) (s : SavedModelSnapshot fi) : List Nat :=
  let payload := serializeSnapshotPayload fi s
  let crc := crc32OfList payload
  listAppend payload (natToU32LE crc)

theorem serializeSnapshot_deterministic (fi : FloatInterface) (s : SavedModelSnapshot fi) :
    serializeSnapshot fi s = serializeSnapshot fi s := Eq.refl _

noncomputable def parseMagicHeader (bytes : List Nat) : ResultT (List Nat) :=
  ResultT.bind (takeN 4 bytes) (fun p =>
    bIte (bAnd (natEqB (listGetD (Prod.fst p) 0 0) 82)
      (bAnd (natEqB (listGetD (Prod.fst p) 1 0) 83)
        (bAnd (natEqB (listGetD (Prod.fst p) 2 0) 70)
          (natEqB (listGetD (Prod.fst p) 3 0) 48))))
      (ResultT.ok (Prod.snd p))
      (ResultT.err ZigError.badFileFormat))

noncomputable def parseVersionField (bytes : List Nat) : ResultT (List Nat) :=
  ResultT.bind (takeN 4 bytes) (fun p =>
    ResultT.bind (natFromU32LE (Prod.fst p)) (fun ver =>
      bIte (natEqB ver 4)
        (ResultT.ok (Prod.snd p))
        (ResultT.err ZigError.unsupportedVersion)))

theorem parseMagicHeader_err_short : parseMagicHeader List.nil = ResultT.err ZigError.badFileFormat := Eq.refl _

