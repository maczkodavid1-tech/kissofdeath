noncomputable def parseSnapshotFromBytes (fi : FloatInterface) (bs : List Nat) : ResultT (SavedModelSnapshot fi) :=
  ResultT.bind (parseMagicHeader bs) (fun rest1 =>
  ResultT.bind (parseVersionField rest1) (fun rest2 =>
  ResultT.bind (takeN 8 rest2) (fun p_nl =>
  ResultT.bind (natFromU64LE (Prod.fst p_nl)) (fun numLayers =>
  ResultT.bind (takeN 8 (Prod.snd p_nl)) (fun p_dim =>
  ResultT.bind (natFromU64LE (Prod.fst p_dim)) (fun dim =>
  bIte (natEqB numLayers 0) (ResultT.err ZigError.invalidLayerCount)
    (bIte (natEqB dim 0) (ResultT.err ZigError.invalidDimension)
      (ResultT.bind (takeN 4 (Prod.snd p_dim)) (fun p_cmin =>
      ResultT.bind (natFromU32LE (Prod.fst p_cmin)) (fun clipMinBits =>
      ResultT.bind (takeN 4 (Prod.snd p_cmin)) (fun p_cmax =>
      ResultT.bind (natFromU32LE (Prod.fst p_cmax)) (fun clipMaxBits =>
      ResultT.bind (takeN 1 (Prod.snd p_cmax)) (fun p_gm =>
      ResultT.bind (decodeBool (listGetD (Prod.fst p_gm) 0 0)) (fun gradMean =>
      ResultT.bind (takeN 8 (Prod.snd p_gm)) (fun p_md =>
      ResultT.bind (natFromU64LE (Prod.fst p_md)) (fun maxDim =>
      ResultT.bind (takeN 8 (Prod.snd p_md)) (fun p_ml =>
      ResultT.bind (natFromU64LE (Prod.fst p_ml)) (fun maxLayers =>
      let cfg := RSFConfigSpec.mk (fi.fromBitsU32 clipMinBits) (fi.fromBitsU32 clipMaxBits) 0 gradMean maxDim maxLayers
      ResultT.bind (takeN 4 (Prod.snd p_ml)) (fun p_crc =>
      ResultT.bind (natFromU32LE (Prod.fst p_crc)) (fun storedCRC =>
      let payloadBytes := listTake (natSub (listLength bs) 4) bs
      let computedCRC := crc32OfList payloadBytes
      bIte (natEqB computedCRC storedCRC)
        (bIte (natEqB (listLength (Prod.snd p_crc)) 0)
          (ResultT.ok (SavedModelSnapshot.mk dim numLayers cfg List.nil (Eq.refl _)))
          (ResultT.err ZigError.trailingData))
        (ResultT.err ZigError.checksumMismatch))))))))))))))))))))

