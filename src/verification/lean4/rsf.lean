structure ShapeSpec where
  dims : List Nat

structure TensorSpec (α : Type) where
  shape : ShapeSpec
  data : List α
  storageId : Nat
  storageOffset : Nat

def tensorRows {α : Type} (t : TensorSpec α) : Nat :=
  match t.shape.dims with
  | r :: _ => r
  | [] => 0

def tensorCols {α : Type} (t : TensorSpec α) : Nat :=
  match t.shape.dims with
  | _ :: c :: _ => c
  | _ => 0

def tensorExpectedLen {α : Type} (t : TensorSpec α) : Nat :=
  tensorRows t * tensorCols t

def tensorHasShapeSpec {α : Type} (t : TensorSpec α) (r c : Nat) : Bool :=
  bAnd (natEqB (tensorRows t) r) (natEqB (tensorCols t) c)

def tensorsSameShapeSpec {α : Type} (a b : TensorSpec α) : Bool :=
  bAnd (natEqB (tensorRows a) (tensorRows b)) (natEqB (tensorCols a) (tensorCols b))

def tensorsOverlapSpec {α : Type} (a b : TensorSpec α) : Bool :=
  bAnd (natEqB a.storageId b.storageId) (bNot (natEqB a.storageId 0))

def tensorCloneSpec {α : Type} (t : TensorSpec α) (sid : Nat) : TensorSpec α :=
  { shape := t.shape, data := t.data, storageId := sid, storageOffset := 0 }

def zeroTensorSpec (t : TensorSpec Nat) : TensorSpec Nat :=
  { shape := t.shape, data := listReplicate (listLength t.data) 0, storageId := t.storageId, storageOffset := t.storageOffset }

theorem tensorCloneSpec_data {α : Type} (t : TensorSpec α) (sid : Nat) :
    (tensorCloneSpec t sid).data = t.data := rfl

theorem tensorCloneSpec_shape {α : Type} (t : TensorSpec α) (sid : Nat) :
    (tensorCloneSpec t sid).shape = t.shape := rfl

theorem tensorCloneSpec_storageOffset {α : Type} (t : TensorSpec α) (sid : Nat) :
    (tensorCloneSpec t sid).storageOffset = 0 := rfl

theorem tensorCloneSpec_storageId {α : Type} (t : TensorSpec α) (sid : Nat) :
    (tensorCloneSpec t sid).storageId = sid := rfl

