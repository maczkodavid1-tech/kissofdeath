noncomputable def rsfSpecSave (fi : FloatInterface) (rsf : RSFSpec fi) : SavedModelSnapshot fi :=
  { dim := rsf.rsfCore.dim,
    numLayers := listLength rsf.rsfCore.layers,
    cfg := rsf.rsfCore.cfg,
