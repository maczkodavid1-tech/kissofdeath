def tryForwardGPUSpec (fi : FloatInterface) (core : RSFCoreSpec fi)
    (gpuFn : List fi.carrier → Option (List fi.carrier))
    (xData : List fi.carrier) : Bool × List fi.carrier × RSFCoreSpec fi :=
  bIte (bNot core.gpuAvailable) (false, xData, core)
    (match gpuFn xData with
     | Option.none => (false, xData, disableGPUSpec fi core)
     | Option.some result => (true, result, core))

theorem tryForwardGPUSpec_no_gpu (fi : FloatInterface) (core : RSFCoreSpec fi)
    (gpuFn : List fi.carrier → Option (List fi.carrier))
    (xData : List fi.carrier) (h : core.gpuAvailable = false) :
    tryForwardGPUSpec fi core gpuFn xData = (false, xData, core) :=
  congrArg (fun b => bIte (bNot b) (false, xData, core)
    (match gpuFn xData with
     | Option.none => (false, xData, disableGPUSpec fi core)
     | Option.some result => (true, result, core))) h

theorem tryForwardGPUSpec_preserves_input_on_fail (fi : FloatInterface) (core : RSFCoreSpec fi)
    (gpuFn : List fi.carrier → Option (List fi.carrier))
    (xData : List fi.carrier)
    (h : core.gpuAvailable = false) :
    (tryForwardGPUSpec fi core gpuFn xData).2.1 = xData :=
  congrArg (fun r => r.2.1) (tryForwardGPUSpec_no_gpu fi core gpuFn xData h)

def rsf0Magic : List Nat := [82, 83, 70, 48]

def rsf0Version : Nat := 4

def crc32Init : Nat := 4294967295

def crc32Update (crc : Nat) (byte : Nat) : Nat :=
  let idx := natXor (natAnd crc 255) byte
  natXor (natShiftR crc 8) idx

def crc32Final (crc : Nat) : Nat := natXor crc 4294967295

def crc32OfList (bs : List Nat) : Nat :=
  crc32Final (listFoldl crc32Update crc32Init bs)

theorem rsf0Magic_length : listLength rsf0Magic = 4 := rfl
theorem rsf0Magic_byte0 : listGetD rsf0Magic 0 0 = 82 := rfl
theorem rsf0Magic_byte1 : listGetD rsf0Magic 1 0 = 83 := rfl
theorem rsf0Magic_byte2 : listGetD rsf0Magic 2 0 = 70 := rfl
theorem rsf0Magic_byte3 : listGetD rsf0Magic 3 0 = 48 := rfl

def parseMagicHeader (bs : List Nat) : ResultT (List Nat) :=
  match bs with
  | b0 :: b1 :: b2 :: b3 :: rest =>
    bIte (bAnd (natEqB b0 82) (bAnd (natEqB b1 83) (bAnd (natEqB b2 70) (natEqB b3 48))))
      (ResultT.ok rest)
      (ResultT.err ZigError.badFileFormat)
  | _ => ResultT.err ZigError.badFileFormat

def parseVersionField (bs : List Nat) : ResultT (List Nat) :=
  match bs with
  | v0 :: v1 :: v2 :: v3 :: rest =>
    let ver := u32LEToNat v0 v1 v2 v3
    bIte (natEqB ver rsf0Version) (ResultT.ok rest) (ResultT.err ZigError.unsupportedVersion)
  | _ => ResultT.err ZigError.badFileFormat

theorem parseMagicHeader_valid : parseMagicHeader [82, 83, 70, 48] = ResultT.ok [] := rfl
theorem parseMagicHeader_valid_rest (rest : List Nat) :
    parseMagicHeader (82 :: 83 :: 70 :: 48 :: rest) = ResultT.ok rest := rfl
theorem parseMagicHeader_empty : parseMagicHeader [] = ResultT.err ZigError.badFileFormat := rfl
theorem parseMagicHeader_short1 (b : Nat) : parseMagicHeader [b] = ResultT.err ZigError.badFileFormat := rfl

def xavierScale (fi : FloatInterface) (dim : Nat) : fi.carrier :=
  fi.divF fi.oneF (fi.sqrtF (fi.fromNat dim))

def xavierInitSpec (fi : FloatInterface) (dim seed : Nat) : List fi.carrier :=
  listMap (fun i => fi.mulF (xavierScale fi dim) (fi.fromNat (i + seed))) (List.range (dim * dim))

theorem xavierScale_det (fi : FloatInterface) (dim : Nat) : xavierScale fi dim = xavierScale fi dim := rfl
theorem xavierInitSpec_det (fi : FloatInterface) (dim seed : Nat) : xavierInitSpec fi dim seed = xavierInitSpec fi dim seed := rfl

def f16ConvertSpec (fi : FloatInterface) (v : fi.carrier) : fi.carrier := v
def f16RoundtripSpec (fi : FloatInterface) (v : fi.carrier) : fi.carrier := f16ConvertSpec fi v

theorem f16ConvertSpec_id (fi : FloatInterface) (v : fi.carrier) : f16ConvertSpec fi v = v := rfl
theorem f16RoundtripSpec_id (fi : FloatInterface) (v : fi.carrier) : f16RoundtripSpec fi v = v := rfl

def atomicWriteSpec (path contents : List Nat) (sid : Nat) : ResultT Unit :=
  bIte (natEqB (listLength contents) 0) (ResultT.err ZigError.ioError) (ResultT.ok ())

def scratchAllocSpec (n : Nat) : List Nat := listReplicate n 0

theorem scratchAllocSpec_length (n : Nat) : listLength (scratchAllocSpec n) = n :=
  listLength_replicate n 0

def tolCloseF (fi : FloatInterface) (a b absTol relTol : fi.carrier) : Bool :=
  let diff := fi.absF (fi.subF a b)
  bOr (fi.leF diff absTol)
    (fi.leF diff (fi.mulF relTol (fi.absF b)))

theorem tolCloseF_det (fi : FloatInterface) (a b absTol relTol : fi.carrier) :
    tolCloseF fi a b absTol relTol = tolCloseF fi a b absTol relTol := rfl

