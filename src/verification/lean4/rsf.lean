structure HandleOwnerEntry where
  handleId : Nat
  ownerAddr : Nat

structure HandleOwnerMap where
  entries : List HandleOwnerEntry

def handleOwnerLookup : List HandleOwnerEntry → Nat → Option Nat
  | [], _ => Option.none
  | e :: rest, id => if natEqB e.handleId id then Option.some e.ownerAddr else handleOwnerLookup rest id

def bindHandleSpec (m : HandleOwnerMap) (id ownerAddr : Nat) : ResultT HandleOwnerMap :=
  bIte (natEqB id 0) (ResultT.err ZigError.notInitialized)
    (match handleOwnerLookup m.entries id with
     | Option.some _ => ResultT.err ZigError.handleCopied
     | Option.none => ResultT.ok { entries := { handleId := id, ownerAddr := ownerAddr } :: m.entries })

def checkCopiedSpec (m : HandleOwnerMap) (id ownerAddr : Nat) : ResultT Unit :=
  bIte (natEqB id 0) (ResultT.err ZigError.notInitialized)
    (match handleOwnerLookup m.entries id with
     | Option.none => ResultT.err ZigError.notInitialized
     | Option.some stored => bIte (natEqB stored ownerAddr) (ResultT.ok ()) (ResultT.err ZigError.handleCopied))

def shouldDestroyHandleSpec (m : HandleOwnerMap) (id ownerAddr : Nat) : Bool × HandleOwnerMap :=
  bIte (natEqB id 0) (false, m)
    (match handleOwnerLookup m.entries id with
     | Option.none => (false, m)
     | Option.some stored =>
       bIte (natEqB stored ownerAddr)
         (true, { entries := listFilter (fun e => bNot (natEqB e.handleId id)) m.entries })
         (false, m))

def maybeShrinkHandleMapSpec (m : HandleOwnerMap) : HandleOwnerMap := m

theorem maybeShrinkHandleMapSpec_id (m : HandleOwnerMap) : maybeShrinkHandleMapSpec m = m := rfl

def disableGPUSpec (fi : FloatInterface) (core : RSFCoreSpec fi) : RSFCoreSpec fi :=
  { core with gpuAvailable := false, hasAccel := false, hasF16Buf := false, gpuWeightVersion := 0 }

