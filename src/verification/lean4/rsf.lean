noncomputable def uploadLayerToAccelSpec (fi : FloatInterface) (core : RSFCoreSpec fi)
    (layer : LayerCoreSpec fi) : ResultT (RSFCoreSpec fi) :=
  bIte (bNot core.hasAccel) (ResultT.err ZigError.noGPUAvailable)
    (bIte (bNot core.hasF16Buf) (ResultT.err ZigError.allocationFailure)
      (ResultT.ok core))

theorem uploadLayerToAccelSpec_no_accel (fi : FloatInterface) (core : RSFCoreSpec fi) (layer : LayerCoreSpec fi)
    (h : core.hasAccel = Bool.false) :
    uploadLayerToAccelSpec fi core layer = ResultT.err ZigError.noGPUAvailable :=
  congrArg (fun b => bIte (bNot b) _ _) h

theorem uploadLayerToAccelSpec_no_f16_buf (fi : FloatInterface) (core : RSFCoreSpec fi) (layer : LayerCoreSpec fi)
    (hAccel : core.hasAccel = Bool.true)
    (h : core.hasF16Buf = Bool.false) :
    uploadLayerToAccelSpec fi core layer = ResultT.err ZigError.allocationFailure :=
  Eq.trans (congrArg (fun b => bIte (bNot b) _ _) hAccel)
    (congrArg (fun b => bIte (bNot b) _ _) h)

theorem uploadLayerToAccelSpec_ok (fi : FloatInterface) (core : RSFCoreSpec fi) (layer : LayerCoreSpec fi)
    (hAccel : core.hasAccel = Bool.true)
    (hBuf : core.hasF16Buf = Bool.true) :
    uploadLayerToAccelSpec fi core layer = ResultT.ok core :=
  Eq.trans (congrArg (fun b => bIte (bNot b) _ _) hAccel)
    (congrArg (fun b => bIte (bNot b) _ _) hBuf)

