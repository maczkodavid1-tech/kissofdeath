noncomputable def layerGPUCompatibleSpec (fi : FloatInterface) (layer : LayerCoreSpec fi)
    (cfg : RSFConfigSpec fi) (dim : Nat) : Bool :=
  bAnd (natEqB layer.dim dim)
    (bAnd (fi.eqF layer.clipMin cfg.clipMin)
      (bAnd (fi.eqF layer.clipMax cfg.clipMax)
        (bAnd (Bool.recOn (motive := fun _ => Bool) layer.gradMean
          (Bool.recOn (motive := fun _ => Bool) cfg.gradMean Bool.true Bool.false)
          (Bool.recOn (motive := fun _ => Bool) cfg.gradMean Bool.false Bool.true))
          (bAnd (fi.leF (fi.negF (fi.fromBitsU32 1101004800)) layer.clipMin)
            (fi.leF layer.clipMax (fi.fromBitsU32 1101004800))))))

theorem layerGPUCompatibleSpec_dim_mismatch (fi : FloatInterface) (layer : LayerCoreSpec fi)
    (cfg : RSFConfigSpec fi) (dim : Nat)
    (h : natEqB layer.dim dim = Bool.false) :
    layerGPUCompatibleSpec fi layer cfg dim = Bool.false :=
  congrArg (fun b => bAnd b _) h

noncomputable def modelGPUCompatibleSpec (fi : FloatInterface) (core : RSFCoreSpec fi) : Bool :=
  bAnd (natLtB 0 (listLength core.layers))
    (listAll (fun layer => layerGPUCompatibleSpec fi layer core.cfg core.dim) core.layers)

theorem modelGPUCompatibleSpec_empty (fi : FloatInterface) (core : RSFCoreSpec fi)
    (h : core.layers = List.nil) :
    modelGPUCompatibleSpec fi core = Bool.false :=
  congrArg (fun l => bAnd (natLtB 0 (listLength l)) _) h

